    addVideoToPlaylist(key, atpVideo);
    if (curPage==='watch-later') renderWL();
    else if (curPage==='library') renderLibrary();
    closeAtpMenu();
    showToast(`Added to new playlist "${name}"`, 'ok');
}
function closeAtpMenu() { document.getElementById('atpMenu').classList.remove('on'); atpVideo = null; }
function refreshCardWLButtons(id) {
    document.querySelectorAll(`.vc[data-id="${id}"] .vbtn`).forEach(btn => {
        if (btn.title && btn.title.includes('Watch Later')) {
            const inNow = isInPlaylist('WL', id);
            btn.classList.toggle('on', inNow); btn.textContent = inNow?'✓':'⏰';
            btn.title = (inNow?'Remove from':'Add to')+' Watch Later';
