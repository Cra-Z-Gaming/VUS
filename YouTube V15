function randomVideo() {
    const v = S.HOME_VIDEOS[Math.floor(Math.random()*S.HOME_VIDEOS.length)];
    playVideo(v.id, v.title, `https://i.ytimg.com/vi/${v.id}/mqdefault.jpg`);
    showToast(`🎲 ${v.title}`);
}

function copyLink(id, e) {
    if (e) e.stopPropagation();
    const url = `https://youtube.com/watch?v=${id}`;
    navigator.clipboard.writeText(url)
        .then(()=>showToast('Link copied! 🔗','ok'))
        .catch(()=>{ const t=document.createElement('textarea');t.value=url;document.body.appendChild(t);t.select();document.execCommand('copy');document.body.removeChild(t);showToast('Link copied!','ok'); });
}

function searchChannel(channel, e) {
    if (e) e.stopPropagation();
    if (!channel) return;
    document.getElementById('sbox').value = channel;
    activeChip = ''; renderChips();
    performSearch(channel);
}

