function fmtDur(d) {
    const m = d.match(/PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
    if (!m) return '0:00';
    const h = parseInt(m[1]||0), mm = parseInt(m[2]||0), s = parseInt(m[3]||0);
    if (h>0) return `${h}:${String(mm).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    return `${mm}:${String(s).padStart(2,'0')}`;
}

function showSkel(id) {
    const g = document.getElementById(id); g.innerHTML = '';
    for (let i=0; i<12; i++) {
        const s = document.createElement('div'); s.className='vc';
        s.innerHTML='<div class="vthumb sk"></div><div class="vinfo"><div class="vtitle sk" style="height:36px"></div><div class="vmeta sk" style="height:24px;margin-top:6px"></div></div>';
        g.appendChild(s);
    }
}

