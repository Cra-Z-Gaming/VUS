<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>YouTube</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0f0f0f;--bg2:#1a1a1a;--card:#242424;--text:#fff;--text2:#aaa;--accent:#ff0000;--hover:#333;--border:#2e2e2e;--r:12px;--sh:0 8px 32px rgba(0,0,0,.6)}
[data-theme=amoled]{--bg:#000;--bg2:#0d0d0d;--card:#161616;--hover:#222;--border:#1e1e1e}
[data-theme=dim]{--bg:#15192a;--bg2:#1e2438;--card:#252d45;--hover:#2e3855;--border:#2e3855}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;transition:background .25s,color .25s}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}::-webkit-scrollbar-thumb:hover{background:var(--hover)}

/* HEADER */
.header{position:fixed;top:0;left:0;right:0;height:58px;background:var(--bg);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 16px;z-index:1000;gap:12px}
.logo{display:flex;align-items:center;gap:7px;font-size:19px;font-weight:600;letter-spacing:-.03em;cursor:pointer;flex-shrink:0;user-select:none}
.logo-icon{width:30px;height:22px;background:var(--accent);border-radius:4px;position:relative;flex-shrink:0}
.logo-icon::after{content:'▶';position:absolute;top:50%;left:50%;transform:translate(-40%,-50%);color:#fff;font-size:11px}
.search-wrap{flex:1;max-width:560px;position:relative}
.search-row{display:flex}
.sbox{flex:1;height:38px;background:var(--bg2);border:1px solid var(--border);border-radius:19px 0 0 19px;padding:0 14px;color:var(--text);font-size:14px;font-family:inherit;transition:border-color .2s}
.sbox:focus{outline:none;border-color:var(--accent)}
.sbtn{height:38px;min-width:52px;background:var(--bg2);border:1px solid var(--border);border-left:none;border-radius:0 19px 19px 0;color:var(--text);cursor:pointer;font-size:13px;padding:0 13px;transition:background .15s;font-family:inherit}
.sbtn:hover:not(:disabled){background:var(--hover)}
.sbtn:disabled{opacity:.5;cursor:not-allowed}
.sug-box{position:absolute;top:43px;left:0;right:52px;background:var(--card);border:1px solid var(--border);border-radius:10px;overflow:hidden;z-index:2000;box-shadow:var(--sh);display:none}
.sug-box.on{display:block;animation:slideDown .15s ease}
.sug-item{padding:9px 14px;cursor:pointer;font-size:13px;display:flex;align-items:center;gap:10px;color:var(--text2);transition:background .1s}
.sug-item:hover{background:var(--hover);color:var(--text)}
.sug-rm{margin-left:auto;font-size:11px;padding:2px 5px;border-radius:3px;transition:color .1s;line-height:1}
.sug-rm:hover{color:var(--accent)}
.header-right{display:flex;align-items:center;gap:5px;margin-left:auto;flex-shrink:0}
.hbtn{width:34px;height:34px;border-radius:50%;background:transparent;border:none;color:var(--text);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:background .15s;position:relative}
.hbtn:hover{background:var(--hover)}
.badge{position:absolute;top:1px;right:1px;background:var(--accent);color:#fff;font-size:9px;font-weight:700;min-width:14px;height:14px;border-radius:7px;line-height:14px;text-align:center;padding:0 2px;display:none}
.theme-dots{display:flex;gap:5px;align-items:center;padding:0 4px}
.tdot{width:15px;height:15px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform .15s,border-color .15s;flex-shrink:0}
.tdot:hover{transform:scale(1.3)}
.tdot.on{border-color:var(--text)}
.tdot[data-t=dark]{background:#0f0f0f;box-shadow:0 0 0 1px #555}
.tdot[data-t=amoled]{background:#000;box-shadow:0 0 0 1px #888}
.tdot[data-t=dim]{background:#1a1f2e;box-shadow:0 0 0 1px #4a5568}

/* SIDEBAR */
.sidebar{position:fixed;top:58px;left:0;width:232px;height:calc(100vh - 58px);background:var(--bg);border-right:1px solid var(--border);padding:10px 0;overflow-y:auto;z-index:900}
.nav-lbl{padding:12px 20px 4px;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);font-weight:500}
.nav-item{display:flex;align-items:center;padding:9px 20px;color:var(--text);gap:14px;font-size:13px;transition:background .15s;cursor:pointer;border:none;background:none;width:100%;font-family:inherit;letter-spacing:-.01em}
.nav-item:hover{background:var(--hover)}
.nav-item.on{background:var(--card)}
.nav-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);display:none;margin-left:auto;flex-shrink:0}
.nav-dot.on{display:block}
.nav-ct{margin-left:auto;font-size:11px;color:var(--text2);background:var(--bg2);padding:1px 7px;border-radius:9px;display:none}
.nav-ct.on{display:block}

/* FILTERS */
#filterBar{margin:2px 0 8px}
.fg{overflow:hidden;max-height:38px;transition:max-height .2s ease}
.fg.open{max-height:300px}
.fh{display:flex;align-items:center;justify-content:space-between;padding:9px 20px;cursor:pointer;font-size:12px;color:var(--text2);user-select:none;transition:background .1s}
.fh:hover{background:var(--hover);color:var(--text)}
.fa{font-size:9px;transition:transform .2s}
.fg.open .fa{transform:rotate(180deg)}
.fo{display:none;flex-wrap:wrap;gap:5px;padding:2px 14px 10px}
.fg.open .fo{display:flex}
.fp{background:var(--bg2);border:1px solid var(--border);border-radius:16px;padding:3px 10px;font-size:11px;color:var(--text2);cursor:pointer;transition:all .15s;user-select:none}
.fp:hover{background:var(--hover);color:var(--text)}
.fp.on{background:var(--accent);color:#fff;border-color:var(--accent)}
.ci{width:100%;margin-top:5px}
.ci input{width:100%;padding:4px 10px;background:var(--bg2);border:1px solid var(--border);border-radius:14px;color:var(--text);font-size:11px;font-family:inherit}
.ci input:focus{outline:none;border-color:var(--accent)}

/* MAIN */
.main{margin-left:232px;margin-top:58px;padding:20px 24px;min-height:calc(100vh - 58px)}
.pg{display:none}.pg.on{display:block}
.pg-title{font-size:20px;font-weight:600;letter-spacing:-.03em;margin-bottom:12px;display:flex;align-items:center;flex-wrap:wrap;gap:8px}
.res-count{font-size:13px;color:var(--text2);font-weight:400;letter-spacing:0}

/* CATEGORY CHIPS */
.chip-row{display:flex;gap:7px;overflow-x:auto;padding-bottom:14px;scrollbar-width:none;-webkit-overflow-scrolling:touch}
.chip-row::-webkit-scrollbar{display:none}
.chip{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:5px 14px;font-size:12px;color:var(--text);cursor:pointer;white-space:nowrap;transition:all .15s;flex-shrink:0;font-family:inherit}
.chip:hover{background:var(--hover);transform:translateY(-1px)}
.chip.on{background:var(--text);color:var(--bg);border-color:var(--text)}

/* FILTER TAGS */
.ftags{display:none;flex-wrap:wrap;gap:5px;margin-bottom:14px;align-items:center}
.ftags.on{display:flex}
.ftag{background:rgba(255,0,0,.12);color:#ff6b6b;border:1px solid rgba(255,0,0,.25);border-radius:16px;padding:2px 9px;font-size:11px;display:flex;align-items:center;gap:4px}
.ftag button{background:none;border:none;color:#ff6b6b;cursor:pointer;font-size:13px;line-height:1;padding:0}

/* VIDEO GRID */
.vgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(272px,1fr));gap:18px}
.vc{background:var(--card);border-radius:var(--r);overflow:hidden;cursor:pointer;transition:transform .2s,box-shadow .2s;position:relative}
.vc:hover{transform:translateY(-3px);box-shadow:var(--sh)}
.vthumb{width:100%;height:156px;background:var(--bg2);position:relative;overflow:hidden}
.vthumb img{width:100%;height:100%;object-fit:cover;transition:transform .35s}
.vc:hover .vthumb img{transform:scale(1.04)}
.vdur{position:absolute;bottom:7px;right:7px;background:rgba(0,0,0,.85);color:#fff;padding:1px 6px;border-radius:3px;font-size:10px;font-family:'DM Mono',monospace;letter-spacing:.02em}
.vacts{position:absolute;top:7px;right:7px;display:flex;gap:3px;opacity:0;transition:opacity .15s}
.vc:hover .vacts{opacity:1}
.vbtn{width:28px;height:28px;background:rgba(0,0,0,.75);border:none;border-radius:50%;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:background .15s;backdrop-filter:blur(4px)}
.vbtn:hover{background:rgba(0,0,0,.95)}
.vbtn.on{background:var(--accent)}
.v-watched-badge{position:absolute;top:7px;left:7px;background:rgba(0,0,0,.75);color:#888;padding:1px 7px;border-radius:8px;font-size:9px;backdrop-filter:blur(4px);display:none}
.v-watched-badge.on{display:block}
.v-now-playing{position:absolute;top:7px;left:7px;background:rgba(255,0,0,.85);color:#fff;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:600;display:none;align-items:center;gap:4px;backdrop-filter:blur(4px)}
.v-now-playing.on{display:flex}
.vinfo{padding:10px 12px}
.vtitle{font-size:13px;font-weight:500;margin-bottom:5px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.vmeta{font-size:11px;color:var(--text2)}
.vch{cursor:pointer;transition:color .15s;display:inline}
.vch:hover{color:var(--text);text-decoration:underline}
.vviews{margin-top:1px}
.rm-btn{position:absolute;top:7px;right:7px;width:28px;height:28px;background:rgba(0,0,0,.7);border:none;border-radius:50%;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .15s;z-index:10;font-size:12px}
.vc:hover .rm-btn{opacity:1}
.rm-btn:hover{background:var(--accent)}

/* PL-BADGE on cards inside a playlist grid (shows other playlist membership count) */
.pl-badge{position:absolute;bottom:7px;left:7px;background:rgba(0,0,0,.75);color:#ddd;padding:1px 7px;border-radius:8px;font-size:9px;backdrop-filter:blur(4px)}

/* WL WATCHED CHECK */
.wl-footer{padding:0 12px 10px;display:flex;align-items:center;gap:8px}
.wl-check{width:15px;height:15px;border:1px solid var(--border);border-radius:3px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;transition:all .15s}
.wl-check.done{background:#4caf50;border-color:#4caf50}
.wl-check-lbl{font-size:11px;color:var(--text2)}

/* EMPTY */
.empty{grid-column:1/-1;text-align:center;padding:80px 20px;color:var(--text2)}
.empty h3{font-size:18px;margin-bottom:10px;color:var(--text);font-weight:500}
.empty p{font-size:14px;margin-bottom:20px}
.ebtn{padding:9px 20px;background:var(--accent);color:#fff;border:none;border-radius:18px;cursor:pointer;font-size:13px;font-family:inherit;font-weight:500;transition:background .15s}
.ebtn:hover{background:#c00}
.ebtn.sec{background:var(--card);border:1px solid var(--border);color:var(--text)}
.ebtn.sec:hover{background:var(--hover)}

/* SKELETON */
.sk{background:linear-gradient(90deg,var(--card) 40%,var(--hover) 50%,var(--card) 60%);background-size:200% 100%;animation:shim 1.3s infinite;border-radius:4px}
@keyframes shim{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* WATCH LATER / PLAYLIST ACTIONS */
.wl-acts{display:flex;gap:6px;margin-left:auto;flex-wrap:wrap}
.abtn{padding:6px 13px;border:none;border-radius:16px;cursor:pointer;font-size:12px;font-weight:500;font-family:inherit;transition:background .15s,transform .1s;white-space:nowrap}
.abtn:active{transform:scale(.97)}
.a-sec{background:var(--card);color:var(--text);border:1px solid var(--border)}.a-sec:hover{background:var(--hover)}
.a-ok{background:rgba(76,175,80,.15);color:#4caf50;border:1px solid #4caf50}.a-ok:hover{background:rgba(76,175,80,.25)}
.a-bad{background:var(--accent);color:#fff}.a-bad:hover{background:#c00}

/* WL STATS */
.wl-stats{display:flex;background:var(--card);border:1px solid var(--border);border-radius:var(--r);margin-bottom:14px;overflow:hidden}
.wl-stat{flex:1;padding:12px 16px;text-align:center;border-right:1px solid var(--border)}
.wl-stat:last-child{border-right:none}
.wl-sv{font-size:22px;font-weight:600;letter-spacing:-.04em}
.wl-sl{font-size:11px;color:var(--text2);margin-top:2px}

/* WL CONTROLS */
.wl-top{display:flex;gap:8px;margin-bottom:14px;align-items:center;flex-wrap:wrap}
.sel{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:5px 11px;color:var(--text);font-size:12px;font-family:inherit;cursor:pointer;transition:border-color .15s}
.sel:focus{outline:none;border-color:var(--accent)}

/* PANELS */
.panel{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:16px;margin-bottom:16px;display:none}
.panel.on{display:block;animation:slideDown .2s ease}
@keyframes slideDown{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
.panel-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--text2);margin-bottom:10px}
.panel textarea{width:100%;min-height:80px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:12px;font-family:'DM Mono',monospace;padding:8px 10px;resize:vertical;line-height:1.7}
.panel textarea:focus{outline:none;border-color:var(--accent)}
.panel input[type=text]{width:100%;padding:8px 10px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:12px;font-family:inherit}
.panel input[type=text]:focus{outline:none;border-color:var(--accent)}
.panel-hint{font-size:11px;color:var(--text2);margin-top:6px;line-height:1.5}
.panel-hint code{background:var(--bg2);padding:1px 4px;border-radius:3px;font-family:'DM Mono',monospace}
.panel-btns{display:flex;gap:7px;margin-top:10px;flex-wrap:wrap}
.pbtn{padding:6px 13px;border:none;border-radius:13px;cursor:pointer;font-size:12px;font-weight:500;font-family:inherit;transition:background .15s}
.pbtn-p{background:var(--accent);color:#fff}.pbtn-p:hover{background:#c00}
.pbtn-s{background:var(--bg2);color:var(--text);border:1px solid var(--border)}.pbtn-s:hover{background:var(--hover)}
.pbtn-g{background:rgba(76,175,80,.15);color:#4caf50;border:1px solid #4caf50}.pbtn-g:hover{background:rgba(76,175,80,.25)}

/* HISTORY */
.hist-date{font-size:12px;color:var(--text2);font-weight:500;padding:14px 0 8px;border-bottom:1px solid var(--border);margin-bottom:12px;letter-spacing:.03em;text-transform:uppercase}
.hist-section{margin-bottom:28px}

/* PLAYLIST TABS (Library page) */
.pl-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;align-items:center}
.pl-tab{background:var(--card);border:1px solid var(--border);border-radius:18px;padding:6px 12px 6px 14px;font-size:12px;color:var(--text);cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .15s;user-select:none}
.pl-tab:hover{background:var(--hover)}
.pl-tab.on{background:var(--text);color:var(--bg);border-color:var(--text)}
.pl-tab .plct{font-size:10px;opacity:.65}
.pl-dots{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;flex-shrink:0;opacity:.7;transition:opacity .15s,background .15s}
.pl-dots:hover{opacity:1;background:rgba(255,255,255,.15)}
.pl-tab.on .pl-dots:hover{background:rgba(0,0,0,.15)}
.pl-new{background:transparent;border:1px dashed var(--border);border-radius:18px;padding:6px 14px;font-size:12px;color:var(--text2);cursor:pointer;transition:all .15s;font-family:inherit}
.pl-new:hover{background:var(--hover);color:var(--text);border-style:solid}

/* PLAYLIST DROPDOWN MENU (3 dots) */
.pl-menu{position:fixed;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:4px 0;z-index:99000;box-shadow:var(--sh);display:none;min-width:150px}
.pl-menu.on{display:block;animation:fadeIn .1s ease}

/* ADD-TO-PLAYLIST POPOVER on a video card */
.atp-menu{position:fixed;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:6px 0;z-index:99000;box-shadow:var(--sh);display:none;min-width:190px;max-height:260px;overflow-y:auto}
.atp-menu.on{display:block;animation:fadeIn .1s ease}
.atp-item{padding:7px 14px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:8px;color:var(--text);transition:background .1s}
.atp-item:hover{background:var(--hover)}
.atp-check{width:13px;height:13px;border:1px solid var(--border);border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0}
.atp-check.on{background:#4caf50;border-color:#4caf50}
.atp-sep{height:1px;background:var(--border);margin:3px 0}
.atp-new-row{padding:6px 10px;display:flex;gap:5px}
.atp-new-row input{flex:1;background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:4px 8px;color:var(--text);font-size:11px;font-family:inherit}
.atp-new-row input:focus{outline:none;border-color:var(--accent)}
.atp-new-row button{background:var(--accent);color:#fff;border:none;border-radius:6px;padding:0 9px;font-size:11px;cursor:pointer}

/* MINI PLAYER */
.mp{position:fixed;bottom:18px;right:18px;width:360px;background:var(--card);border:1px solid var(--border);border-radius:12px;box-shadow:0 16px 48px rgba(0,0,0,.8);z-index:9500;display:none;overflow:hidden}
.mp.on{display:block;animation:pop .25s cubic-bezier(.34,1.56,.64,1)}
@keyframes pop{from{opacity:0;transform:scale(.85) translateY(16px)}to{opacity:1;transform:scale(1) translateY(0)}}
.mp.dragging{box-shadow:0 24px 64px rgba(0,0,0,.9)}
.mp-hdr{display:flex;align-items:center;padding:7px 8px;gap:6px;background:rgba(0,0,0,.5);cursor:move;user-select:none}
.mp-title{flex:1;font-size:11px;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mp-btn{width:24px;height:24px;background:none;border:none;color:var(--text2);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;border-radius:4px;transition:background .1s,color .1s}
.mp-btn:hover{background:var(--hover);color:var(--text)}
.mp iframe{width:100%;height:202px;border:none;display:block}

/* SHORTCUTS MODAL */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:98000;display:none;align-items:center;justify-content:center;backdrop-filter:blur(5px)}
.modal-bg.on{display:flex;animation:fadeIn .15s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.modal{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px;width:460px;max-width:92vw;max-height:80vh;overflow-y:auto}
.modal h2{font-size:17px;font-weight:600;margin-bottom:18px;letter-spacing:-.03em}
.sc-sec{margin-bottom:14px}
.sc-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--text2);margin-bottom:6px}
.sc-row{display:flex;align-items:center;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:12px}
.sc-row:last-child{border-bottom:none}
.kbd{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:2px 8px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text2)}

/* PROMPT MODAL (rename / new playlist) */
.pmt-box{width:340px}
.pmt-box input{width:100%;padding:9px 12px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:13px;font-family:inherit;margin-top:12px}
.pmt-box input:focus{outline:none;border-color:var(--accent)}
.pmt-box .panel-btns{margin-top:16px}

/* CONTEXT MENU */
.ctxmenu{position:fixed;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:4px 0;z-index:99000;box-shadow:var(--sh);display:none;min-width:178px}
.ctxmenu.on{display:block;animation:fadeIn .1s ease}
.ctx{padding:8px 14px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:9px;color:var(--text);transition:background .1s}
.ctx:hover{background:var(--hover)}
.ctx.red{color:#ff6b6b}
.ctx-sep{height:1px;background:var(--border);margin:3px 0}

/* LOAD MORE */
.lm-wrap{text-align:center;margin-top:24px}
.lm-btn{padding:9px 26px;background:var(--card);border:1px solid var(--border);color:var(--text);border-radius:18px;cursor:pointer;font-size:13px;font-family:inherit;transition:background .15s,transform .15s}
.lm-btn:hover{background:var(--hover);transform:translateY(-1px)}
.lm-btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.lm-locked{font-size:12px;color:var(--text2);padding:9px 0}

/* KEYS / LIBRARY EXTRAS */
.key-row{display:flex;align-items:center;gap:8px;padding:10px 12px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;margin-bottom:8px}
.key-dot{width:9px;height:9px;border-radius:50%;background:#666;flex-shrink:0;transition:background .2s}
.key-dot.ok{background:#4caf50}
.key-dot.bad{background:var(--accent)}
.key-dot.checking{background:#e0a72a;animation:pulse2 .8s infinite}
@keyframes pulse2{0%,100%{opacity:1}50%{opacity:.35}}
.key-name{font-size:12px;font-weight:500;min-width:90px}
.key-val{font-size:11px;color:var(--text2);font-family:'DM Mono',monospace;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.key-active-badge{font-size:9px;background:rgba(76,175,80,.15);color:#4caf50;border:1px solid #4caf50;padding:1px 7px;border-radius:8px;white-space:nowrap}
.key-mini-btn{background:none;border:none;color:var(--text2);cursor:pointer;font-size:13px;padding:4px 6px;border-radius:5px;transition:background .1s,color .1s;flex-shrink:0}
.key-mini-btn:hover{background:var(--hover);color:var(--text)}
.key-mini-btn.red:hover{color:#ff6b6b}
.key-add-row{display:flex;gap:7px;margin-top:8px;flex-wrap:wrap}
.key-add-row input{flex:1;min-width:120px;padding:8px 10px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:12px;font-family:inherit}
.key-add-row input:focus{outline:none;border-color:var(--accent)}
.nores-hint{grid-column:1/-1;text-align:center;padding:60px 20px}
.nores-hint h3{font-size:16px;margin-bottom:8px;font-weight:500}
.nores-hint p{font-size:13px;color:var(--text2);margin-bottom:16px}

/* API KEY HERO */
.key-hero-box{background:linear-gradient(135deg,var(--card),var(--bg2));border:1px solid var(--border);border-radius:16px;padding:26px 28px;position:relative;overflow:hidden}
.key-hero-box::before{content:'';position:absolute;top:-45%;right:-8%;width:240px;height:240px;background:radial-gradient(circle,rgba(255,0,0,.16),transparent 70%);pointer-events:none}

@media(max-width:768px){
    .sidebar{transform:translateX(-100%);transition:transform .3s}.sidebar.mob-open{transform:translateX(0)}
    .main{margin-left:0}
    .vgrid{grid-template-columns:1fr}
    .pg-title{flex-direction:column;align-items:flex-start}
    .mp{width:calc(100vw - 36px)}
