function pmtConfirm() {
    const val = document.getElementById('pmtInput').value.trim();
    if (!val) { showToast('Enter a name', 'err'); return; }
    if (pmtMode === 'create') {
        const key = newPlaylistId();
        playlists[key] = { name: val, locked:false, videos: [] };
        curListKey = key;
        savePlaylists(); renderLibrary();
        showToast(`Playlist "${val}" created`, 'ok');
    } else if (pmtMode === 'rename' && playlists[pmtTarget]) {
        playlists[pmtTarget].name = val;
        savePlaylists(); renderLibrary();
        showToast('Renamed ✓', 'ok');
    }
    closePrompt();
