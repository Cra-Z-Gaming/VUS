   PLAYLISTS — core data helpers
═══════════════════════════════════════════ */
function newPlaylistId() {
    let n = 1;
    while (playlists['PL'+n]) n++;
    return 'PL'+n;
}

function isInPlaylist(plKey, id) {
    return playlists[plKey] && playlists[plKey].videos.some(v => v.id === id);
}

function addVideoToPlaylist(plKey, video) {
    if (!playlists[plKey]) return;
    if (isInPlaylist(plKey, video.id)) return;
    playlists[plKey].videos.push({ id: video.id, title: video.title, thumbnail: video.thumbnail, channel: video.channel||'', addedAt: new Date().toISOString() });
    savePlaylists();
}

function removeVideoFromPlaylist(plKey, id) {
    if (!playlists[plKey]) return;
    playlists[plKey].videos = playlists[plKey].videos.filter(v => v.id !== id);
    savePlaylists();
}

