    let left = r.left, top = r.bottom+4;
    if (left + 190 > window.innerWidth) left = window.innerWidth - 200;
    if (top + 260 > window.innerHeight) top = Math.max(8, r.top - 260);
    menu.style.left = left+'px'; menu.style.top = top+'px';
    menu.classList.add('on');
}
function atpToggle(key) {
    if (!atpVideo) return;
    if (isInPlaylist(key, atpVideo.id)) removeVideoFromPlaylist(key, atpVideo.id);
    else addVideoToPlaylist(key, atpVideo);
    if (curPage==='watch-later') renderWL();
    else if (curPage==='library') renderLibrary();
    refreshCardWLButtons(atpVideo.id);
    openAddToPlaylist(atpVideo.id, atpVideo.title, atpVideo.thumbnail, atpVideo.channel, {stopPropagation(){}, target: document.querySelector(`.vc[data-id="${atpVideo.id}"] .vbtn`) || document.body});
