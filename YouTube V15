/* ═══════════════════════════════════════════
   EXPORT / IMPORT  (one-line format)
   WL=(id,id);PL1="name"=(id,id);PL2="name"=(id)
═══════════════════════════════════════════ */
function escName(n) { return n.replace(/"/g,'\\"'); }
function unescName(n) { return n.replace(/\\"/g,'"'); }

function exportAll() {
    const parts = [];
    Object.keys(playlists).forEach(key => {
        const pl = playlists[key];
        const ids = pl.videos.map(v=>v.id).join(',');
        if (pl.locked) parts.push(`WL=(${ids})`);
        else parts.push(`${key}="${escName(pl.name)}"=(${ids})`);
    });
    return parts.join(';');
}
function exportWL() {
    const ids = allWLVideos().map(v=>v.id).join(',');
    return `WL=(${ids})`;
}
function exportPlaylist(key) {
    const pl = playlists[key];
    if (!pl) return '';
    const ids = pl.videos.map(v=>v.id).join(',');
    return pl.locked ? `WL=(${ids})` : `${key}="${escName(pl.name)}"=(${ids})`;
}

function showPanel(id) {
    ['exportPanel','importPanel','importOnlyPanel','exportPanelLib','importPanelLib','importOnlyPanelLib'].forEach(p => { if(p!==id) closePanel(p); });
    if (id==='exportPanel') document.getElementById('exportArea').value = exportWL();
    if (id==='exportPanelLib') document.getElementById('exportAreaLib').value = curListKey ? exportPlaylist(curListKey) : '';
    document.getElementById(id).classList.toggle('on');
}
function closePanel(id) { document.getElementById(id).classList.remove('on'); }

function copyExport() {
    const a = document.getElementById('exportArea'); a.select();
    navigator.clipboard.writeText(a.value).then(()=>showToast('Copied! ✓','ok')).catch(()=>{document.execCommand('copy');showToast('Copied!','ok');});
}
function copyExportLib() {
    const a = document.getElementById('exportAreaLib'); a.select();
    navigator.clipboard.writeText(a.value).then(()=>showToast('Copied! ✓','ok')).catch(()=>{document.execCommand('copy');showToast('Copied!','ok');});
}

function extractVideoId(str) {
    try { const u=new URL(str); if(u.searchParams.has('v')) return u.searchParams.get('v'); const m=u.pathname.match(/\/(?:embed\/|shorts\/|v\/)?([A-Za-z0-9_-]{11})/); if(m) return m[1]; } catch {}
    if (/^[A-Za-z0-9_-]{11}$/.test(str)) return str; return null;
}

// Parses the WL=(...)...PL1="name"=(...) format. Returns null if it doesn't look like that format at all.
function parseExportString(raw) {
    const blockRe = /(WL|PL\d+)\s*=\s*(?:"((?:[^"\\]|\\.)*)"\s*=\s*)?\(([^)]*)\)/g;
    let m, found = false;
    const blocks = [];
    while ((m = blockRe.exec(raw)) !== null) {
        found = true;
        const tag = m[1], name = m[2] ? unescName(m[2]) : null, idsRaw = m[3];
        const ids = idsRaw.split(',').map(s=>s.trim()).filter(Boolean);
        blocks.push({ tag, name, ids });
    }
    return found ? blocks : null;
}

function runImport(areaId) {
    const raw = document.getElementById(areaId).value.trim();
    if (!raw) { showToast('Nothing to import','err'); return; }

    const blocks = parseExportString(raw);

    if (blocks) {
        // structured import: recreate/merge playlists
        let addedVideos = 0, createdLists = 0;
        const idsNeeded = new Set();
        blocks.forEach(b => b.ids.forEach(id => idsNeeded.add(id)));
        const knownMeta = {}; // id -> {title, thumbnail, channel} filled in after fetch

        const finish = () => {
            blocks.forEach(b => {
                let key;
                if (b.tag === 'WL') key = 'WL';
                else {
                    // find existing playlist with same name, else create new one under next free PL id
                    key = Object.keys(playlists).find(k => !playlists[k].locked && playlists[k].name === b.name);
                    if (!key) { key = newPlaylistId(); playlists[key] = { name: b.name || b.tag, locked:false, videos: [] }; createdLists++; }
                }
                b.ids.forEach(id => {
                    if (isInPlaylist(key, id)) return;
                    const meta = knownMeta[id] || { title:id, thumbnail:`https://i.ytimg.com/vi/${id}/mqdefault.jpg`, channel:'' };
                    playlists[key].videos.push({ id, title: meta.title, thumbnail: meta.thumbnail, channel: meta.channel, addedAt: new Date().toISOString() });
                    addedVideos++;
                });
            });
            savePlaylists();
            closePanel('importPanel'); closePanel('importOnlyPanel'); closePanel('importPanelLib'); closePanel('importOnlyPanelLib');
            if (curPage==='watch-later') renderWL();
            else if (curPage==='library') renderLibrary();
            showToast(`Imported ${addedVideos} video(s) across ${blocks.length} list(s)${createdLists?`, ${createdLists} new`:''}`, 'ok');
        };

        const key = getWorkingKey();
        const idList = [...idsNeeded];
        if (key && idList.length) {
            const batches = [];
            for (let i=0;i<idList.length;i+=50) batches.push(idList.slice(i,i+50));
            Promise.all(batches.map(b => fetch(`https://www.googleapis.com/youtube/v3/videos?part=snippet&id=${b.join(',')}&key=${key}`).then(r=>r.json()).catch(()=>({}))))
                .then(results => {
                    results.forEach(data => (data.items||[]).forEach(item => {
                        knownMeta[item.id] = { title:item.snippet.title, thumbnail:item.snippet.thumbnails.medium?.url||`https://i.ytimg.com/vi/${item.id}/mqdefault.jpg`, channel:item.snippet.channelTitle||'' };
                    }));
                    finish();
                }).catch(finish);
        } else {
            finish(); // no key available — import with placeholder titles (still works, just less pretty)
        }
        return;
    }

    // fallback: plain IDs / URLs -> Watch Later only
    const tokens = raw.split(/[\n,]+/).map(t=>t.trim()).filter(Boolean);
    const newIds=[], skipped=[];
    tokens.forEach(t => {
        const id = extractVideoId(t);
        if (!id) { skipped.push(t); return; }
        if (isInPlaylist('WL', id)) { skipped.push(id+' (dup)'); return; }
        newIds.push(id);
    });
    if (!newIds.length) { showToast('No new valid IDs found','err'); return; }
    const key = getWorkingKey();
    if (!key) {
        newIds.forEach(id => addVideoToPlaylist('WL', {id, title:id, thumbnail:`https://i.ytimg.com/vi/${id}/mqdefault.jpg`, channel:''}));
        closePanel('importPanel'); closePanel('importOnlyPanel'); closePanel('importPanelLib'); closePanel('importOnlyPanelLib');
        if (curPage==='watch-later') renderWL();
        else if (curPage==='library') renderLibrary();
        showToast(`${newIds.length} video(s) imported (no key — titles unavailable)`, 'ok');
        return;
    }
    showToast(`Fetching ${newIds.length} video(s)…`);
    const batches=[];
    for (let i=0; i<newIds.length; i+=50) batches.push(newIds.slice(i,i+50));
    Promise.all(batches.map(b => fetch(`https://www.googleapis.com/youtube/v3/videos?part=snippet&id=${b.join(',')}&key=${key}`).then(r=>r.json())))
        .then(results => {
            let added=0;
            results.forEach(data => {
                (data.items||[]).forEach(item => {
                    addVideoToPlaylist('WL', {id:item.id, title:item.snippet.title, thumbnail:item.snippet.thumbnails.medium?.url||'', channel:item.snippet.channelTitle||''});
                    added++;
                });
            });
            closePanel('importPanel'); closePanel('importOnlyPanel'); closePanel('importPanelLib'); closePanel('importOnlyPanelLib');
            if (curPage==='watch-later') renderWL();
            else if (curPage==='library') renderLibrary();
            showToast(`${added} video${added!==1?'s':''} imported!${skipped.length?` (${skipped.length} skipped)`:''}`, 'ok');
        }).catch(() => showToast('Import failed — check your connection','err'));
}

/* ═══════════════════════════════════════════
   HISTORY
═══════════════════════════════════════════ */
function addToHist(id, title, thumb) {
    hist = [{id, title, thumbnail:thumb, watchedAt:new Date().toISOString()}, ...hist.filter(h=>h.id!==id)].slice(0,200);
    localStorage.setItem('videoHistory', JSON.stringify(hist));
    updateHistCt();
}

function renderHistory() {
    const container = document.getElementById('histGrid');
    if (!hist.length) {
        container.innerHTML = '<div class="empty"><h3>No history yet</h3><p>Videos you watch will appear here.</p><button class="ebtn" onclick="goHome()">Browse Videos</button></div>';
        return;
    }
    const now = new Date(), today = new Date(now.getFullYear(),now.getMonth(),now.getDate());
    const yesterday = new Date(today - 86400000);
    const groups = {};
    hist.forEach(h => {
        const d = new Date(h.watchedAt), day = new Date(d.getFullYear(),d.getMonth(),d.getDate());
        let label;
        if (day.getTime()===today.getTime()) label = 'Today';
        else if (day.getTime()===yesterday.getTime()) label = 'Yesterday';
        else if (now-day < 7*86400000) label = 'This Week';
        else label = day.toLocaleDateString(undefined,{month:'long',year:'numeric'});
        if (!groups[label]) groups[label] = [];
        groups[label].push(h);
    });
    container.innerHTML = '';
    Object.entries(groups).forEach(([label, items]) => {
        const sec = document.createElement('div'); sec.className = 'hist-section';
        sec.innerHTML = `<div class="hist-date">${label}</div>`;
        const grid = document.createElement('div'); grid.className = 'vgrid';
        items.forEach(h => {
            const thumb = h.thumbnail || `https://i.ytimg.com/vi/${h.id}/mqdefault.jpg`;
            const time = new Date(h.watchedAt).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
            grid.appendChild(makeCard(h.id, h.title, '', time, '', thumb, false));
        });
        sec.appendChild(grid); container.appendChild(sec);
    });
}

function clearHistory() {
    if (confirm('Clear all watch history?')) {
        hist=[]; localStorage.setItem('videoHistory',JSON.stringify(hist));
        updateHistCt(); renderHistory();
    }
}

function updateHistCt() {
    const el = document.getElementById('histCt');
    el.textContent = hist.length||'';
    el.classList.toggle('on', hist.length>0);
}

/* ═══════════════════════════════════════════
