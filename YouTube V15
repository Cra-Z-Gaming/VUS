}

/* ═══════════════════════════════════════════
   SEARCH
═══════════════════════════════════════════ */
function bindSearch() {
    const box = document.getElementById('sbox');
    const sug = document.getElementById('sugBox');
    box.addEventListener('keypress', e => { if (e.key==='Enter') { sug.classList.remove('on'); performSearch(); } });
    box.addEventListener('input', () => {
        const v = box.value.trim();
        if (!v) { if (recents.length) renderSuggestions(); else sug.classList.remove('on'); return; }
        const matches = recents.filter(r => r.toLowerCase().startsWith(v.toLowerCase())).slice(0,5);
        matches.length ? renderSuggestions(matches) : sug.classList.remove('on');
    });
    box.addEventListener('focus', () => { if (!box.value.trim() && recents.length) renderSuggestions(); });
    document.addEventListener('click', e => { if (!e.target.closest('.search-wrap')) sug.classList.remove('on'); });
}

function renderSuggestions(list) {
    const sug = document.getElementById('sugBox');
    const items = list || recents.slice(0,6);
    if (!items.length) { sug.classList.remove('on'); return; }
    sug.innerHTML = '<div style="padding:7px 14px 3px;font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--text2)">Recent Searches</div>';
    items.forEach(s => {
        const d = document.createElement('div');
        d.className = 'sug-item';
        d.innerHTML = `<span style="font-size:11px">🕐</span><span style="flex:1">${s}</span><span class="sug-rm">✕</span>`;
        d.querySelector('.sug-rm').onclick = e => { e.stopPropagation(); removeRecent(s); };
        d.onclick = () => { document.getElementById('sbox').value = s; sug.classList.remove('on'); performSearch(s); };
        sug.appendChild(d);
    });
    sug.classList.add('on');
}

function removeRecent(s) {
    recents = recents.filter(r => r !== s);
    localStorage.setItem('recentSearches', JSON.stringify(recents));
    recents.length ? renderSuggestions() : document.getElementById('sugBox').classList.remove('on');
}

function saveRecent(q) {
    recents = [q, ...recents.filter(r => r !== q)].slice(0,10);
    localStorage.setItem('recentSearches', JSON.stringify(recents));
}

function performSearch(forceQ) {
    const q = (forceQ !== undefined ? forceQ : document.getElementById('sbox').value).trim();
    if (!q) { goHome(); return; }
    const btn = document.getElementById('sbtn');
    if (btn.disabled) return;

    const key = getWorkingKey();
    if (!key) { showNoKeyState(q); return; }

    const cacheKey = q.toLowerCase() + '|' + JSON.stringify(filters);
    if (cache[cacheKey]) {
        const c = cache[cacheKey];
        hasSearched = true; curQuery = q;
        _nav('home'); saveRecent(q);
        document.getElementById('homeTitle').innerHTML = `Results for "<em>${q}</em>" <span class="res-count">${c.total?'~'+Number(c.total).toLocaleString()+' results':''}</span>`;
        updateFTags(); _renderCards(c.videos, c.detailMap, false);
        nextPageToken = c.nextPageToken || null;
        document.getElementById('lmWrap').style.display = nextPageToken ? 'block' : 'none';
        showToast('Showing cached results ⚡'); return;
    }

    startCooldown(); hasSearched = true; curQuery = q;
    _nav('home'); saveRecent(q);
    document.getElementById('homeTitle').innerHTML = `Results for "<em>${q}</em>"`;
    updateFTags(); showSkel('homeGrid');
    document.getElementById('lmWrap').style.display = 'none';
    doSearch(q, cacheKey, key);
}

function showNoKeyState(q) {
    const grid = document.getElementById('homeGrid');
    hasSearched = true; curQuery = q;
    _nav('home');
    document.getElementById('homeTitle').innerHTML = `Results for "<em>${q}</em>"`;
    document.getElementById('lmWrap').style.display = 'none';
    grid.innerHTML = `<div class="nores-hint">
        <h3>No API key yet</h3>
        <p>You'll need your own free YouTube API key to search. It only takes a couple minutes.</p>
        <button class="ebtn" onclick="nav('library')">Open Library → Add a Key</button>
    </div>`;
}

function startCooldown() {
    const btn = document.getElementById('sbtn');
    let s = S.COOLDOWN; btn.disabled = true; btn.textContent = s+'s';
    const iv = setInterval(() => { s--; if(s<=0){clearInterval(iv);btn.disabled=false;btn.textContent='🔍';}else btn.textContent=s+'s'; }, 1000);
}

function doSearch(q, cacheKey, key) {
    let url = `https://www.googleapis.com/youtube/v3/search?part=snippet&type=video&maxResults=${S.SEARCH_COUNT}&q=${encodeURIComponent(q)}&key=${key}`;
    if (filters.duration) url += `&videoDuration=${filters.duration}`;
    if (filters.sort)     url += `&order=${filters.sort}`;
    if (filters.live)     url += `&eventType=${filters.live}`;
    if (filters.hd)       url += `&videoDefinition=${filters.hd}`;
    if (filters.time)     url += `&publishedAfter=${new Date(Date.now()-Number(filters.time)*3600000).toISOString()}`;
    fetch(url).then(r=>r.json()).then(d => {
        if (d.error) {
            markKeyBad(key);
            const nextKey = getWorkingKey();
            if (nextKey) { showToast('That key failed — trying another…', 'err'); doSearch(q, cacheKey, nextKey); }
            else { showNoWorkingKeyState(q); }
            return;
        }
        markKeyOk(key);
        if (!d.items || !d.items.length) { showZeroResults(q); return; }
        nextPageToken = d.nextPageToken || null;
        fetchDetails(d.items, cacheKey, d.pageInfo?.totalResults, nextPageToken, key);
    }).catch(() => showErr('homeGrid'));
}

function showZeroResults(q) {
    document.getElementById('homeTitle').innerHTML = `Results for "<em>${q}</em>"`;
    document.getElementById('homeGrid').innerHTML = `<div class="nores-hint"><h3>No videos found</h3><p>Try a different search term.</p></div>`;
    document.getElementById('lmWrap').style.display = 'none';
}

function showNoWorkingKeyState(q) {
    document.getElementById('homeGrid').innerHTML = `<div class="nores-hint">
        <h3>Your key(s) stopped working</h3>
        <p>This can happen if a key hits its daily quota or was entered incorrectly. Check your keys or add a new one.</p>
        <button class="ebtn" onclick="nav('library')">Open Library → Check Keys</button>
    </div>`;
    document.getElementById('lmWrap').style.display = 'none';
}

function fetchDetails(videos, cacheKey, total, npToken, key) {
    const ids = videos.map(v => v.id.videoId).filter(Boolean).join(',');
    if (!ids) return;
    fetch(`https://www.googleapis.com/youtube/v3/videos?part=contentDetails,statistics&id=${ids}&key=${key}`)
        .then(r => r.json()).then(d => {
            const map = {};
            (d.items||[]).forEach(v => { map[v.id] = { duration:fmtDur(v.contentDetails.duration), views:parseInt(v.statistics.viewCount||0) }; });
            if (cacheKey) cache[cacheKey] = {videos, detailMap:map, total, nextPageToken:npToken};
            document.getElementById('homeTitle').innerHTML = `Results for "<em>${curQuery}</em>" <span class="res-count">${total?'~'+Number(total).toLocaleString()+' results':''}</span>`;
            _renderCards(videos, map, false);
            document.getElementById('lmWrap').style.display = npToken ? 'block' : 'none';
        });
}

function loadMore() {
    if (!nextPageToken || !curQuery) return;
    const key = getWorkingKey();
    if (!key) { showNoWorkingKeyState(curQuery); return; }
    const btn = document.getElementById('lmBtn');
    btn.disabled = true; btn.textContent = 'Loading…';
    let url = `https://www.googleapis.com/youtube/v3/search?part=snippet&type=video&maxResults=${S.SEARCH_COUNT}&q=${encodeURIComponent(curQuery)}&pageToken=${nextPageToken}&key=${key}`;
    if (filters.sort) url += `&order=${filters.sort}`;
    fetch(url).then(r=>r.json()).then(d => {
        if (d.error || !d.items) { btn.disabled=false; btn.textContent='Load more videos'; showToast('Failed to load more — check your keys','err'); return; }
        nextPageToken = d.nextPageToken || null;
        const ids = d.items.map(v=>v.id.videoId).filter(Boolean).join(',');
        fetch(`https://www.googleapis.com/youtube/v3/videos?part=contentDetails,statistics&id=${ids}&key=${key}`)
            .then(r=>r.json()).then(dd => {
                const map = {};
                (dd.items||[]).forEach(v => { map[v.id]={duration:fmtDur(v.contentDetails.duration),views:parseInt(v.statistics.viewCount||0)}; });
                _renderCards(d.items, map, true);
                btn.disabled=false; btn.textContent='Load more videos';
                document.getElementById('lmWrap').style.display = nextPageToken ? 'block' : 'none';
            });
    });
}

function _renderCards(videos, map, append) {
    const grid = document.getElementById('homeGrid');
    if (!append) grid.innerHTML = '';
    videos.forEach(v => {
        const id = v.id.videoId;
        const info = map[id] || {duration:'?', views:0};
        const thumb = v.snippet.thumbnails.medium.url;
        grid.appendChild(makeCard(id, v.snippet.title, v.snippet.channelTitle, Number(info.views).toLocaleString()+' views', info.duration, thumb, false));
    });
}

/* ═══════════════════════════════════════════
   FILTERS
═══════════════════════════════════════════ */
function bindFilters() {
    document.querySelectorAll('.fh').forEach(h => {
        h.addEventListener('click', () => {
            const g = h.parentElement, isOpen = g.classList.contains('open');
            document.querySelectorAll('.fg').forEach(fg => fg.classList.remove('open'));
            if (!isOpen) g.classList.add('open');
        });
    });
    document.querySelectorAll('.fp').forEach(pill => {
        pill.addEventListener('click', function() {
            const gEl = this.closest('.fg'), g = gEl.dataset.g;
            gEl.querySelectorAll('.fp').forEach(p => p.classList.remove('on'));
            this.classList.add('on'); filters[g] = this.dataset.v;
            if (g==='live' && this.dataset.v) {
                filters.duration = '';
                document.querySelectorAll('.fg[data-g="duration"] .fp').forEach(p => p.classList.toggle('on', p.dataset.v===''));
                document.getElementById('custDur').value = '';
                showToast('Duration filter cleared — not supported for live events');
            }
            if (g==='duration') document.getElementById('custDur').value = '';
            if (g==='time')     document.getElementById('custDate').value = '';
            updateFTags(); updateFilterDot();
            if (hasSearched && curQuery) { clearTimeout(filterTimer); filterTimer=setTimeout(()=>performSearch(curQuery),400); }
        });
    });
}

function bindCustomInputs() {
    document.getElementById('custDur').addEventListener('change', function() {
        const v = parseInt(this.value);
        if (!isNaN(v) && v>0) {
            filters.duration = v<=4?'short':v>=20?'long':'medium';
            document.querySelectorAll('.fg[data-g="duration"] .fp').forEach(p => p.classList.remove('on'));
            updateFTags(); updateFilterDot();
            if (hasSearched && curQuery) performSearch(curQuery);
        }
    });
    document.getElementById('custDate').addEventListener('change', function() {
        if (!this.value) return;
        const [y,m,d] = this.value.split('-').map(Number);
        filters.time = Math.floor((Date.now()-new Date(y,m-1,d).getTime())/3600000);
        document.querySelectorAll('.fg[data-g="time"] .fp').forEach(p => p.classList.remove('on'));
        updateFTags(); updateFilterDot();
        if (hasSearched && curQuery) performSearch(curQuery);
    });
}

function updateFilterDot() {
    document.getElementById('filtersDot').classList.toggle('on', Object.values(filters).some(v => v!==''));
}

function updateFTags() {
    const bar = document.getElementById('ftags');
    bar.querySelectorAll('.ftag').forEach(t => t.remove());
    const tags = [];
    if (filters.duration) tags.push({g:'duration', label:`Duration: ${S.FILTER_LABELS.duration[filters.duration]||filters.duration}`});
    if (filters.sort)     tags.push({g:'sort',     label:`Sort: ${S.FILTER_LABELS.sort[filters.sort]||filters.sort}`});
    if (filters.live)     tags.push({g:'live',     label:S.FILTER_LABELS.live[filters.live]||filters.live});
    if (filters.hd)       tags.push({g:'hd',       label:'HD only'});
    if (filters.time) {
        const pill = document.querySelector('.fg[data-g="time"] .fp.on');
        tags.push({g:'time', label:`Time: ${(pill&&pill.dataset.v)?pill.textContent:'Custom date'}`});
    }
    tags.forEach(t => {
        const tag = document.createElement('span');
        tag.className = 'ftag';
        tag.innerHTML = `${t.label} <button onclick="clearFilter('${t.g}')">×</button>`;
        bar.appendChild(tag);
    });
    bar.classList.toggle('on', tags.length > 0);
}

function clearFilter(g) {
    filters[g] = '';
    const gEl = document.querySelector(`.fg[data-g="${g}"]`);
    if (gEl) gEl.querySelectorAll('.fp').forEach(p => p.classList.toggle('on', p.dataset.v===''));
    if (g==='duration') document.getElementById('custDur').value = '';
    if (g==='time')     document.getElementById('custDate').value = '';
    updateFTags(); updateFilterDot();
    if (hasSearched && curQuery) { clearTimeout(filterTimer); filterTimer=setTimeout(()=>performSearch(curQuery),400); }
}

