/* ═══════════════════════════════════════════
   CARD BUILDER
═══════════════════════════════════════════ */
function makeCard(id, title, channel, meta, duration, thumb, isPlaylistCard, listKey) {
    const inWL = allWLVideos().some(w => w.id === id);
    const isWatched = !!watched[id];
    const isPlaying = mpVideoId === id;
    const safeTitle = (title || '').replace(/\\/g,'\\\\').replace(/'/g, "\\'");
    const safeCh = (channel || '').replace(/\\/g,'\\\\').replace(/'/g, "\\'");
    const safeThumb = (thumb || '').replace(/\\/g,'\\\\').replace(/'/g, "\\'");

    const card = document.createElement('div');
    card.className = 'vc';
    card.dataset.id = id;
    card.dataset.title = title || '';
    card.dataset.channel = channel || '';
    card.dataset.thumb = thumb || '';

    if (isPlaylistCard) {
        const key = listKey || curListKey || 'WL';
        const list = playlists[key] ? playlists[key].videos : [];
        const entry = list.find(w => w.id === id);
        const removeFn = key === 'WL' ? `removeFromWL('${id}',event)` : `removeFromCurrentList('${id}',event)`;
        card.innerHTML = `
            <div class="vthumb">
                <img src="${thumb}" alt="">
                <button class="rm-btn" onclick="${removeFn}" title="Remove from this list">✕</button>
            </div>
            <div class="vinfo">
                <div class="vtitle">${title}</div>
                <div class="vmeta">
                    <div><span class="vch" onclick="searchChannel('${safeCh}',event)">${channel || ''}</span></div>
                    ${entry ? `<div class="vviews">Added ${new Date(entry.addedAt).toLocaleDateString()}</div>` : ''}
                    <div style="font-size:10px;color:#555;margin-top:2px;font-family:'DM Mono',monospace">${id}</div>
                </div>
            </div>
            <div class="wl-footer">
                <div class="wl-check ${isWatched?'done':''}" onclick="toggleWatched('${id}',event)">${isWatched?'✓':''}</div>
                <span class="wl-check-lbl">${isWatched?'Watched':'Mark as watched'}</span>
            </div>`;
        card.onclick = e => {
            if (['rm-btn','wl-check','vch'].some(c => e.target.classList.contains(c))) return;
            playVideo(id, title, thumb);
        };
    } else {
        card.innerHTML = `
            <div class="vthumb">
                <img src="${thumb}" alt="" id="img-${id}">
                ${duration ? `<div class="vdur">${duration}</div>` : ''}
                <div class="v-watched-badge ${isWatched?'on':''}">Watched</div>
                <div class="v-now-playing ${isPlaying?'on':''}"><span style="animation:pulse 1s infinite">●</span> Playing</div>
                <div class="vacts">
                    <button class="vbtn ${inWL?'on':''}" onclick="toggleWL('${id}','${safeTitle}','${safeThumb}',event)" title="${inWL?'Remove from':'Add to'} Watch Later">${inWL?'✓':'⏰'}</button>
                    <button class="vbtn" onclick="openAddToPlaylist('${id}','${safeTitle}','${safeThumb}','${safeCh}',event)" title="Add to playlist">➕</button>
                    <button class="vbtn" onclick="copyLink('${id}',event)" title="Copy link">🔗</button>
                </div>
            </div>
            <div class="vinfo">
                <div class="vtitle">${title}</div>
                <div class="vmeta">
                    <div><span class="vch" onclick="searchChannel('${safeCh}',event)">${channel || ''}</span></div>
                    <div class="vviews">${meta || ''}</div>
                </div>
            </div>`;
        card.onclick = e => {
            if (['vbtn','vch'].some(c => e.target.classList.contains(c))) return;
            playVideo(id, title, thumb);
        };
        bindThumbCycle(card, id);
    }

    card.addEventListener('contextmenu', e => { e.preventDefault(); showCtx(e, {id, title, channel, thumb}); });
    return card;
}

/* ═══════════════════════════════════════════
   THUMBNAIL HOVER CYCLING
═══════════════════════════════════════════ */
function bindThumbCycle(card, id) {
    let hoverTimer = null, cycleTimer = null, frame = 0;
    const frames = [0,1,2,3].map(n => `https://i.ytimg.com/vi/${id}/${n}.jpg`);
    const img = card.querySelector('img');
    const orig = img.src;
    card.addEventListener('mouseenter', () => {
        hoverTimer = setTimeout(() => {
            frame = 0;
            cycleTimer = setInterval(() => { frame = (frame+1)%frames.length; img.src = frames[frame]; }, 700);
        }, 900);
    });
    card.addEventListener('mouseleave', () => {
        clearTimeout(hoverTimer); clearInterval(cycleTimer); img.src = orig;
    });
}

/* ═══════════════════════════════════════════
   API KEY HELPERS
═══════════════════════════════════════════ */
function getWorkingKey() {
    // returns first key marked ok or unknown (untested keys are attempted optimistically)
    const usable = apiKeys.filter(k => k.status !== 'bad');
    return usable.length ? usable[0].key : null;
}
function markKeyBad(keyStr) {
    const k = apiKeys.find(k => k.key === keyStr);
    if (k) { k.status = 'bad'; saveKeys(); renderKeyList(); }
}
function markKeyOk(keyStr) {
    const k = apiKeys.find(k => k.key === keyStr);
    if (k && k.status !== 'ok') { k.status = 'ok'; saveKeys(); renderKeyList(); }
}

function addKey() {
    const nameInput = document.getElementById('keyNameInput');
    const valInput = document.getElementById('keyValInput');
    const name = nameInput.value.trim() || `Key ${apiKeys.length+1}`;
    const val = valInput.value.trim();
    if (!val) { showToast('Paste a key first', 'err'); return; }
    if (apiKeys.some(k => k.key === val)) { showToast('That key is already saved', 'err'); return; }
    apiKeys.push({ id: 'k'+Date.now(), name, key: val, status: 'unknown' });
    saveKeys(); nameInput.value=''; valInput.value='';
    renderKeyList();
    showToast('Key added ✓', 'ok');
}

function removeKey(id) {
    apiKeys = apiKeys.filter(k => k.id !== id);
    saveKeys(); renderKeyList();
}

function renderKeyList() {
    const wrap = document.getElementById('keyList');
    if (!wrap) return;
    if (!apiKeys.length) {
        wrap.innerHTML = `<div style="font-size:12px;color:var(--text2);padding:10px 0">No keys added yet. Click <strong>Get Key</strong> above for a step-by-step guide, then paste it below.</div>`;
        return;
    }
    const firstOkIdx = apiKeys.findIndex(k => k.status !== 'bad');
    wrap.innerHTML = '';
    apiKeys.forEach((k, i) => {
        const row = document.createElement('div');
        row.className = 'key-row';
        const masked = k.key.length > 10 ? k.key.slice(0,6) + '••••••' + k.key.slice(-4) : k.key;
        row.innerHTML = `
            <div class="key-dot ${k.status==='ok'?'ok':k.status==='bad'?'bad':k.status==='checking'?'checking':''}"></div>
            <div class="key-name">${k.name}</div>
            <div class="key-val">${masked}</div>
            ${i===firstOkIdx ? '<span class="key-active-badge">ACTIVE</span>' : ''}
            <button class="key-mini-btn" onclick="checkOneKey('${k.id}')" title="Check this key">🔄</button>
            <button class="key-mini-btn red" onclick="removeKey('${k.id}')" title="Delete">✕</button>
        `;
        wrap.appendChild(row);
    });
}

function checkOneKey(id) {
    const k = apiKeys.find(k => k.id === id);
    if (!k) return;
    k.status = 'checking'; renderKeyList();
    fetch(`https://www.googleapis.com/youtube/v3/videos?part=id&id=dQw4w9WgXcQ&key=${k.key}`)
        .then(r => r.json())
        .then(d => { k.status = (d.error ? 'bad' : 'ok'); saveKeys(); renderKeyList(); })
        .catch(() => { k.status = 'bad'; saveKeys(); renderKeyList(); });
}

function checkAllKeys() {
    if (!apiKeys.length) { showToast('No keys to check — add one first', 'err'); return; }
    apiKeys.forEach(k => k.status = 'checking');
    renderKeyList();
    Promise.all(apiKeys.map(k =>
        fetch(`https://www.googleapis.com/youtube/v3/videos?part=id&id=dQw4w9WgXcQ&key=${k.key}`)
            .then(r => r.json()).then(d => { k.status = (d.error ? 'bad' : 'ok'); })
            .catch(() => { k.status = 'bad'; })
    )).then(() => { saveKeys(); renderKeyList(); showToast('Key check complete', 'ok'); });
}

/* ═══════════════════════════════════════════
   TUTORIAL (renders the markdown guide as a real HTML page)
═══════════════════════════════════════════ */
function mdToHtml(md) {
    const codeBlocks = [];
    md = md.replace(/```([\s\S]*?)```/g, (m, code) => {
        codeBlocks.push(code.replace(/^[a-zA-Z]*\n/, ''));
        return `\u0000CODE${codeBlocks.length-1}\u0000`;
    });
    const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    md = esc(md);
    md = md.replace(/^###### (.*)$/gm,'<h6>$1</h6>')
           .replace(/^##### (.*)$/gm,'<h5>$1</h5>')
           .replace(/^#### (.*)$/gm,'<h4>$1</h4>')
           .replace(/^### (.*)$/gm,'<h3>$1</h3>')
           .replace(/^## (.*)$/gm,'<h2>$1</h2>')
           .replace(/^# (.*)$/gm,'<h1>$1</h1>');
    md = md.replace(/!\[([^\]]*)\]\(([^)]+)\)/g,'<img alt="$1" src="$2">');
    md = md.replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>');
    md = md.replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>').replace(/\*([^*]+)\*/g,'<em>$1</em>');
    md = md.replace(/`([^`]+)`/g,'<code>$1</code>');
    md = md.replace(/^\s*[-*] (.*)$/gm,'<li>$1</li>');
    md = md.replace(/^\s*\d+\.\s(.*)$/gm,'<li>$1</li>');
    md = md.replace(/(<li>[\s\S]*?<\/li>\n?)+/g, m => `<ul>${m}</ul>`);
    md = md.split(/\n{2,}/).map(block => {
        const t = block.trim();
        if (!t) return '';
        if (/^<(h\d|ul|ol|li|img)/.test(t)) return block;
        if (t.startsWith('\u0000CODE')) return block;
        return `<p>${t.replace(/\n/g,'<br>')}</p>`;
    }).join('\n');
    md = md.replace(/\u0000CODE(\d+)\u0000/g, (m,i) => `<pre><code>${esc(codeBlocks[i])}</code></pre>`);
    return md;
}

async function openTutorial() {
    const win = window.open('', '_blank');
    if (win) {
        win.document.write('<!doctype html><html><head><meta charset="utf-8"><title>Loading…</title></head><body style="background:#0f0f0f;color:#aaa;font-family:sans-serif;padding:40px">Loading tutorial…</body></html>');
        win.document.close();
    }
    try {
        const res = await fetch(S.TUTORIAL_URL);
        if (!res.ok) throw new Error('fetch failed');
        const raw = await res.text();

        // Detect whether the fetched content is already a full HTML page.
        const isHtml = /^\s*<!doctype html/i.test(raw) || /^\s*<html/i.test(raw) || /<\/html>\s*$/i.test(raw.trim());

        const page = isHtml ? raw : (() => {
            const body = mdToHtml(raw);
            return `<!doctype html><html><head><meta charset="utf-8"><title>How to get a YouTube API Key</title>
            <style>
                body{background:#0f0f0f;color:#e8e8e8;font-family:'DM Sans',Arial,sans-serif;max-width:760px;margin:0 auto;padding:48px 24px 80px;line-height:1.7}
                h1,h2,h3,h4{color:#fff;letter-spacing:-.02em;margin:28px 0 12px}
                h1{font-size:28px;border-bottom:1px solid #2e2e2e;padding-bottom:12px}
                h2{font-size:21px} h3{font-size:17px}
                p{margin:12px 0;font-size:15px;color:#ccc}
                a{color:#ff5c5c;text-decoration:none} a:hover{text-decoration:underline}
                code{background:#242424;padding:2px 6px;border-radius:4px;font-family:'DM Mono',monospace;font-size:13px;color:#ffb3b3}
                pre{background:#161616;border:1px solid #2e2e2e;border-radius:8px;padding:14px 16px;overflow-x:auto}
                pre code{background:none;padding:0;color:#ddd}
                ul{padding-left:22px;margin:12px 0} li{margin:6px 0;font-size:15px;color:#ccc}
                img{max-width:100%;border-radius:8px;margin:12px 0;border:1px solid #2e2e2e}
            </style></head><body>${body}</body></html>`;
        })();

        if (win) { win.document.open(); win.document.write(page); win.document.close(); }
        else { const blob = new Blob([page], {type:'text/html'}); window.open(URL.createObjectURL(blob), '_blank'); }
    } catch (e) {
