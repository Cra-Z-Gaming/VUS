function loadPlaylists() {
    let raw = null;
    try { raw = JSON.parse(localStorage.getItem('playlists') || 'null'); } catch {}
    if (raw && raw.WL) return raw;
    // Migrate legacy flat 'watchLater' array if present
    let legacy = [];
    try { legacy = JSON.parse(localStorage.getItem('watchLater') || '[]'); } catch {}
    return { WL: { name:'Watch Later', locked:true, videos:legacy } };
}
function savePlaylists() { localStorage.setItem('playlists', JSON.stringify(playlists)); updateBadge(); updateLibCt(); }
function saveKeys() { localStorage.setItem('apiKeys', JSON.stringify(apiKeys)); }

