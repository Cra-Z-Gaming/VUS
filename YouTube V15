    const channels = new Set(list.map(v => v.channel||'').filter(Boolean)).size;
    document.getElementById('stCount').textContent = list.length;
    document.getElementById('stWatched').textContent = watchedCt;
    document.getElementById('stChannels').textContent = channels || '—';

    const sort = document.getElementById('wlSort').value;
