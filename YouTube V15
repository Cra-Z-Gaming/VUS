let atpVideo = null;
function openAddToPlaylist(id, title, thumb, channel, e) {
    e.stopPropagation();
    atpVideo = { id, title, thumbnail: thumb, channel };
    const menu = document.getElementById('atpMenu');
    const keys = Object.keys(playlists);
    menu.innerHTML = keys.map(key => {
        const pl = playlists[key];
        const checked = isInPlaylist(key, id);
        return `<div class="atp-item" onclick="atpToggle('${key}')"><span class="atp-check ${checked?'on':''}">${checked?'✓':''}</span>${pl.locked?'⏰':'📁'} ${pl.name}</div>`;
    }).join('') + `<div class="atp-sep"></div><div class="atp-new-row">
        <input type="text" id="atpNewName" placeholder="New playlist name">
        <button onclick="atpCreateAndAdd()">Add</button>
    </div>`;
