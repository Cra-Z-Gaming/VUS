function renderWL() {
    closePanel('exportPanel'); closePanel('importPanel'); closePanel('importOnlyPanel');

    const grid = document.getElementById('wlGrid');
    const acts = document.getElementById('wlActs');
    const stats = document.getElementById('wlStats');
    const top = document.getElementById('wlTop');
    const list = allWLVideos();

    if (!list.length) {
        acts.style.display = 'flex'; stats.style.display = 'none'; top.style.display = 'none';
        grid.innerHTML = `<div class="empty"><h3>No videos here yet</h3><p>Click ➕ or ⏰ on any video, or import a string below.</p>
            <button class="ebtn" onclick="goHome()">Browse Videos</button>&nbsp;&nbsp;
            <button class="ebtn sec" onclick="showPanel('importOnlyPanel')">📥 Import</button></div>`;
        return;
    }

    acts.style.display = 'flex'; stats.style.display = 'flex'; top.style.display = 'flex';

