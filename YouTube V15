═══════════════════════════════════════════ */
function playVideo(id, title, thumb) {
    addToHist(id, title, thumb||`https://i.ytimg.com/vi/${id}/mqdefault.jpg`);
    watched[id] = true;
    localStorage.setItem('watchedVideos', JSON.stringify(watched));
    document.querySelectorAll('.v-watched-badge').forEach(el => { if(el.closest('.vc')?.dataset.id===id) el.classList.add('on'); });
    document.querySelectorAll('.v-now-playing').forEach(el => el.classList.remove('on'));
    document.querySelectorAll(`.vc[data-id="${id}"] .v-now-playing`).forEach(el => el.classList.add('on'));
    mpVideoId = id; mpTitle = title;
    document.getElementById('mpTitle').textContent = title;
    document.getElementById('mpFrame').src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&fs=1`;
    document.getElementById('miniPlayer').classList.add('on');
}

function closeMiniPlayer() {
    document.getElementById('mpFrame').src = '';
    document.getElementById('miniPlayer').classList.remove('on');
    document.querySelectorAll('.v-now-playing').forEach(el => el.classList.remove('on'));
    mpVideoId = null;
}

function popOutPlayer() {
    if (!mpVideoId) return;
    const id = mpVideoId, title = mpTitle;
    closeMiniPlayer();
    openPopout(id, title);
}

function openPopout(videoId, title) {
    const safe = (title||'Video').replace(/<|>/g,'');
    const win = window.open('about:blank','vid','width=960,height=580,scrollbars=no,resizable=yes');
    win.document.write(`<!doctype html><html><head><meta charset="utf-8"><title>${safe}</title><style>html,body{margin:0;height:100%;background:#000;display:flex;flex-direction:column;color:#fff;font-family:Arial,sans-serif}#p{flex:1;position:relative}iframe{border:none;width:100%;height:100%;position:absolute;inset:0}#b{height:44px;background:#111;border-bottom:1px solid #222;display:flex;align-items:center;padding:0 12px;font-size:14px}#b span{flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}#b button{padding:5px 12px;background:#f00;color:#fff;border:none;border-radius:4px;cursor:pointer;margin-left:8px;font-size:13px}#b button:hover{background:#c00}</style></head><body><div id="b"><span>${safe}</span><button onclick="window.open('https://www.youtube.com/watch?v=${videoId}','_blank')">Open on YouTube</button></div><div id="p"><iframe src="https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&fs=1" allowfullscreen allow="accelerometer;autoplay;encrypted-media;gyroscope;picture-in-picture"></iframe></div></body></html>`);
    win.document.close();
}

/* MINI PLAYER DRAG */
function initDrag() {
    const mp = document.getElementById('miniPlayer');
    const hdr = document.getElementById('mpHdr');
    hdr.addEventListener('mousedown', e => {
        if (e.target.classList.contains('mp-btn')) return;
        const r = mp.getBoundingClientRect();
        _drag = {ox:e.clientX-r.left, oy:e.clientY-r.top};
        mp.classList.add('dragging');
        mp.style.right='auto'; mp.style.bottom='auto';
        mp.style.left=r.left+'px'; mp.style.top=r.top+'px';
    });
    document.addEventListener('mousemove', e => {
        if (!_drag) return;
        const x = Math.max(0, Math.min(e.clientX-_drag.ox, window.innerWidth-mp.offsetWidth));
        const y = Math.max(0, Math.min(e.clientY-_drag.oy, window.innerHeight-mp.offsetHeight));
        mp.style.left=x+'px'; mp.style.top=y+'px';
    });
    document.addEventListener('mouseup', () => { if(_drag){mp.classList.remove('dragging');_drag=null;} });
}

/* ═══════════════════════════════════════════
   CONTEXT MENU
═══════════════════════════════════════════ */
function bindContextMenu() {
    document.addEventListener('click', () => closeCtx());
    document.getElementById('ctxMenu').addEventListener('click', e => e.stopPropagation());
}

function showCtx(e, video) {
    ctxVideo = video;
    const inWL = isInPlaylist('WL', video.id);
    document.getElementById('ctx-wl').textContent = inWL ? '✅ Remove from Watch Later' : '⏰ Add to Watch Later';
    document.getElementById('ctx-ch').style.display = video.channel ? '' : 'none';
    const menu = document.getElementById('ctxMenu');
    menu.style.left = Math.min(e.clientX, window.innerWidth-186)+'px';
    menu.style.top  = Math.min(e.clientY, window.innerHeight-210)+'px';
    menu.classList.add('on');
}

function closeCtx() { document.getElementById('ctxMenu').classList.remove('on'); }

function ctxAction(action) {
    if (!ctxVideo) return;
    const {id, title, channel, thumb} = ctxVideo;
    if      (action==='watch')   playVideo(id, title, thumb);
    else if (action==='copy')    copyLink(id);
    else if (action==='channel') searchChannel(channel);
    else if (action==='yt')      window.open(`https://youtube.com/watch?v=${id}`,'_blank');
    else if (action==='wl') {
        if (isInPlaylist('WL', id)) { removeVideoFromPlaylist('WL', id); showToast('Removed from Watch Later'); }
        else { addVideoToPlaylist('WL', {id,title,thumbnail:thumb,channel:channel||''}); showToast('Added to Watch Later','ok'); }
        if (curPage==='watch-later') renderWL();
        refreshCardWLButtons(id);
    }
    else if (action==='atp') {
        const fakeBtn = document.querySelector(`.vc[data-id="${id}"] .vbtn`) || document.body;
        const r = fakeBtn.getBoundingClientRect ? fakeBtn.getBoundingClientRect() : {left:200,bottom:200,right:220};
        openAddToPlaylist(id, title, thumb, channel, { stopPropagation(){}, target: fakeBtn });
    }
    closeCtx();
}

/* ═══════════════════════════════════════════
   KEYBOARD SHORTCUTS
═══════════════════════════════════════════ */
function bindKeyboard() {
    document.addEventListener('keydown', e => {
        const tag = document.activeElement.tagName;
        if (['INPUT','TEXTAREA','SELECT'].includes(tag)) return;
        switch(e.key) {
            case '/':  e.preventDefault(); document.getElementById('sbox').focus(); break;
            case 'h':  if (!e.shiftKey) goHome(); break;
            case 'H':  nav('history'); break;
            case 'w':  nav('watch-later'); break;
            case 'r':  randomVideo(); break;
            case 'q':  closeMiniPlayer(); break;
            case 'p':  popOutPlayer(); break;
            case 'S':  if (curPage==='watch-later') shuffleWL(); else if (curPage==='library') shuffleLibList(); break;
            case '?':  openShortcuts(); break;
            case 'Escape': closeShortcuts(); break;
        }
    });
    document.getElementById('sbox').addEventListener('keydown', e => {
        if (e.key==='Escape') { e.target.value=''; e.target.blur(); document.getElementById('sugBox').classList.remove('on'); goHome(); }
    });
}

function openShortcuts()  { document.getElementById('shortcutsModal').classList.add('on'); }
function closeShortcuts(e){ if (!e||e.target===document.getElementById('shortcutsModal')) document.getElementById('shortcutsModal').classList.remove('on'); }

