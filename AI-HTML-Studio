// ── KEY POOL STATE ───────────────────────────────────────────────
// keyPool: all valid (non-empty, non-duplicate) keys fetched from GitHub
// activeKeyIndex: which key we're currently using
// exhaustedKeys: Set of keys that returned 401 this session
let keyPool         = [];
let activeKeyIndex  = -1;
let exhaustedKeys   = new Set();
let poolFetchedAt   = 0;   // timestamp of last successful fetch
let poolFetchInFlight = false;

// ── "OTHER" MODEL LIST STATE ──────────────────────────────────────
// otherModels: array of model id strings fetched from GroqModels file (one per line)
let otherModels          = [];
let otherModelsFetchedAt = 0;
let otherModelsFetchInFlight = false;
let otherPreferredModel  = localStorage.getItem('otherPreferredModel') || '';

async function fetchOtherModels() {
  if (otherModelsFetchInFlight) return;
  otherModelsFetchInFlight = true;
  const $count = document.getElementById('otherModelCount');
  if ($count) $count.textContent = 'Fetching model list…';
  try {
    const res = await fetch(MODELS_LIST_URL + '?nocache=' + Date.now());
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const raw = await res.text();
    // One model id per line — same format as the keys file
    const fresh = [...new Set(
      raw.split('\n')
         .map(m => m.trim())
         .filter(m => m.length > 0 && !m.startsWith('#'))
    )];
    otherModels = fresh;
    otherModelsFetchedAt = Date.now();
    if ($count) $count.textContent = `${otherModels.length} model${otherModels.length !== 1 ? 's' : ''} loaded`;
    populateOtherModelSelect();
  } catch (err) {
    if ($count) $count.textContent = `Fetch failed: ${err.message}`;
  } finally {
    otherModelsFetchInFlight = false;
  }
}

async function refreshOtherModels() {
  await fetchOtherModels();
}

function populateOtherModelSelect() {
  const $sel = document.getElementById('otherModelSelect');
  if (!$sel) return;
  if (otherModels.length === 0) {
    $sel.innerHTML = `<option value="">(no models loaded)</option>`;
    return;
  }
  $sel.innerHTML = otherModels.map(id => `<option value="${id}">${id}</option>`).join('');
  // Keep previously chosen preferred model if it's still in the list, else default to first
  if (otherPreferredModel && otherModels.includes(otherPreferredModel)) {
    $sel.value = otherPreferredModel;
  } else {
    otherPreferredModel = otherModels[0];
    localStorage.setItem('otherPreferredModel', otherPreferredModel);
    $sel.value = otherPreferredModel;
  }
}

