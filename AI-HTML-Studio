function getModelChain() {
  if (effort === 'other') {
    const ids = otherPreferredModel
      ? [otherPreferredModel, ...otherModels]
      : [...otherModels];
    return [...new Set(ids)];
  }
  const pool = effort === 'low' ? FAST_MODELS : HIGH_MODELS;
  const preferredId = effort === 'low' ? fastModel : HIGH_MODELS[0].id;
  const ids = [preferredId, ...pool.map(m => m.id)];
  return [...new Set(ids)];
}

