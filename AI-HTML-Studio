function updateLines() {
  const n = $code.value.split('\n').length;
  $lines.textContent = Array.from({length: n}, (_, i) => i + 1).join('\n');
  $lines.scrollTop = $code.scrollTop;
  $status.textContent = `${n} lines · ${$code.value.length} chars`;
}

$code.addEventListener('input', () => {
  localStorage.setItem('code', $code.value);
  updateLines();
  if (autoOn) {
    clearTimeout(autoTimer);
    autoTimer = setTimeout(runCode, 400);
  }
});

$code.addEventListener('scroll', () => {
  $lines.scrollTop = $code.scrollTop;
});

$code.addEventListener('keydown', e => {
  if (e.key === 'Tab') {
    e.preventDefault();
    const s = $code.selectionStart;
    $code.value = $code.value.slice(0, s) + '  ' + $code.value.slice($code.selectionEnd);
    $code.selectionStart = $code.selectionEnd = s + 2;
    updateLines();
  }
  if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); runCode(); }
  if ((e.ctrlKey || e.metaKey) && e.key === 's')     { e.preventDefault(); exportFile(); }
});

function runCode() {
  localStorage.setItem('code', $code.value);
  const doc = $preview.contentDocument || $preview.contentWindow.document;
  doc.open(); doc.write($code.value); doc.close();
}

function setAutoState(on) {
  autoOn = on;
  $autoBtn.classList.toggle('on', on);
  $autoBtn.textContent = on ? '⟳ Auto ON' : '⟳ Auto OFF';
  localStorage.setItem('auto', on);
}

function toggleAuto() { setAutoState(!autoOn); }

function openTab() {
  const w = window.open('about:blank', '_blank');
  if (!w) return;
  w.document.open(); w.document.write($code.value); w.document.close();
}

function exportFile() {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([$code.value], {type: 'text/html'}));
  a.download = 'index.html';
  a.click();
}

function importFile(e) {
  const f = e.target.files[0];
  if (!f) return;
  const r = new FileReader();
  r.onload = ev => { $code.value = ev.target.result; updateLines(); runCode(); };
  r.readAsText(f);
  e.target.value = '';
}

function resetEditor() {
  if (!confirm('Reset to default template?')) return;
  $code.value = DEFAULT;
  updateLines();
  runCode();
}

