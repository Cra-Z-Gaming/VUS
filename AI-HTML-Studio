// ── PANE / WINDOW DRAGGING & RESIZING ───────────────────────────
function disablePreviewPointerEvents() { $preview.style.pointerEvents = 'none'; }
function enablePreviewPointerEvents()  { $preview.style.pointerEvents = ''; }

function setupHResizer() {
  $hResizer.addEventListener('mousedown', e => {
    e.preventDefault();
    const startX = e.clientX;
    const startW = $previewPane.getBoundingClientRect().width;
    document.body.style.userSelect = 'none';
    $hResizer.classList.add('dragging');
    disablePreviewPointerEvents();

    function onMove(ev) {
      const dx = startX - ev.clientX;
      let newW = startW + dx;
      const maxW = $leftCol.getBoundingClientRect().width - 200;
      newW = Math.max(200, Math.min(maxW, newW));
      $previewPane.style.width = newW + 'px';
    }
    function onUp() {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      document.body.style.userSelect = '';
      $hResizer.classList.remove('dragging');
      enablePreviewPointerEvents();
      localStorage.setItem('previewWidth', $previewPane.style.width);
    }
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  });
}

function makeDraggable(handle, panel) {
  handle.addEventListener('mousedown', e => {
    if (e.target.closest('button')) return;
    e.preventDefault();
    const startX = e.clientX, startY = e.clientY;
    const rect = panel.getBoundingClientRect();
    const startLeft = rect.left, startTop = rect.top;
    document.body.style.userSelect = 'none';
    disablePreviewPointerEvents();

    function onMove(ev) {
      let left = startLeft + (ev.clientX - startX);
      let top  = startTop  + (ev.clientY - startY);
      left = Math.max(0, Math.min(window.innerWidth  - panel.offsetWidth, left));
      top  = Math.max(40, Math.min(window.innerHeight - 40, top));
      panel.style.left = left + 'px';
      panel.style.top  = top  + 'px';
    }
    function onUp() {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      document.body.style.userSelect = '';
      enablePreviewPointerEvents();
      saveAIPaneState();
    }
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  });
}

function makeResizable(handle, panel) {
  handle.addEventListener('mousedown', e => {
    e.preventDefault(); e.stopPropagation();
    const startX = e.clientX, startY = e.clientY;
    const rect = panel.getBoundingClientRect();
    const startW = rect.width, startH = rect.height;
    document.body.style.userSelect = 'none';
    disablePreviewPointerEvents();

    function onMove(ev) {
      const w = Math.max(280, Math.min(window.innerWidth  - rect.left, startW + (ev.clientX - startX)));
      const h = Math.max(220, Math.min(window.innerHeight - rect.top,  startH + (ev.clientY - startY)));
      panel.style.width  = w + 'px';
      panel.style.height = h + 'px';
    }
    function onUp() {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
      document.body.style.userSelect = '';
      enablePreviewPointerEvents();
      if (!aiMinimized) saveAIPaneState();
    }
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  });
}

function saveAIPaneState() {
  const r = $aiPane.getBoundingClientRect();
  localStorage.setItem('aiPane', JSON.stringify({ left: r.left, top: r.top, width: r.width, height: r.height }));
}

function restoreAIPane() {
  let saved = null;
  try { saved = JSON.parse(localStorage.getItem('aiPane') || 'null'); } catch (e) { saved = null; }

  if (saved) {
    $aiPane.style.width  = saved.width  + 'px';
    $aiPane.style.height = saved.height + 'px';
    $aiPane.style.left   = Math.max(0, Math.min(saved.left, window.innerWidth  - 280)) + 'px';
    $aiPane.style.top    = Math.max(40, Math.min(saved.top,  window.innerHeight - 200)) + 'px';
  } else {
    const w = 360, h = window.innerHeight - 50;
    $aiPane.style.width  = w + 'px';
    $aiPane.style.height = h + 'px';
    $aiPane.style.left   = (window.innerWidth - w - 10) + 'px';
    $aiPane.style.top    = '44px';
  }
}

window.addEventListener('resize', () => {
  const r = $aiPane.getBoundingClientRect();
  $aiPane.style.left = Math.max(0, Math.min(r.left, window.innerWidth  - 100)) + 'px';
  $aiPane.style.top  = Math.max(40, Math.min(r.top,  window.innerHeight - 100)) + 'px';
