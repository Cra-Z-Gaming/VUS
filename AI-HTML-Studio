  const topic = $topic.value.trim() || 'HTML';

  const prompts = {
    explain:       `Explain **${topic}** clearly with beginner-friendly examples.`,
    problem:       `Give me a beginner HTML practice problem about **${topic}**. Do not give the answer yet.`,
    howto:         `Teach me step-by-step how to use **${topic}** in HTML.`,
    hint:          `Give me just one helpful hint about **${topic}**. Do not give the full solution.`,
    solution:      `Show the full solution for **${topic}** with explanations.`,
    bestPractices: `What are the HTML best practices for **${topic}**?`,
    explainCode:   `Explain the code currently in my editor, section by section.`,
    findMistake:   `Find and explain all mistakes in the code currently in my editor. Don't rewrite it — just explain each issue.`,
    improve:       `Improve the code currently in my editor while keeping the same functionality. Explain each change.`,
    accessibility: `Review the code currently in my editor for accessibility issues and how to fix them.`,
    semantic:      `Convert the code currently in my editor to proper semantic HTML5 and explain each change.`,
    optimize:      `Optimize the code currently in my editor for performance and clean structure. Explain each change.`,
  };

  return prompts[type] || `Tell me about **${topic}**.`;
}

function quick(type) {
  localStorage.setItem('topic', $topic.value);
  callAI(getPrompt(type));
}

function focusInput() { $input.focus(); }

function sendMessage() {
  const text = $input.value.trim();
  if (!text) return;
  $input.value = '';
  $input.style.height = 'auto';
  callAI(text);
}

function setModelStatus(text, warn) {
  $modelStatusRow.textContent = text || '';
  $modelStatusRow.classList.toggle('warn', !!warn);
}

// Single attempt against one model + one API key.
// Rejects with an Error that has .status set on auth failure.
async function tryModel(modelId, apiKey, dynamicSystem, apiMessages) {
  const res = await fetch(API_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${apiKey}` },
    body: JSON.stringify({
      model: modelId,
      max_tokens: 2048,
      temperature: 0.7,
      messages: [{ role: 'system', content: dynamicSystem }, ...apiMessages]
    })
  });

  if (!res.ok) {
    let msg = `HTTP ${res.status}`;
    try {
      const e = await res.json();
      if (e?.error?.message) msg = e.error.message;
    } catch (_) {}
    const err = new Error(msg);
    err.status = res.status;
    throw err;
  }

  return res.json();
}

async function callAI(userMsg) {
  const currentKey = activeKey();
  if (!currentKey) {
    // Pool is empty and no manual key — try fetching the pool first
    await fetchKeyPool();
    if (!activeKey()) {
      addMsg('ai', '⚠️ No API key available. Click **🔑 API Key** to enter one manually, or check your key pool file on GitHub.');
      openKeyModal(false);
      return;
    }
  }

  const isEdit = editModeOn;
  const codeSnapshot = $code.value;

  addMsg('user', userMsg);
  history.push({ role: 'user', content: userMsg });

  const loadEl = document.createElement('div');
  loadEl.className = 'msg ai';
  loadEl.innerHTML = `<div class="msg-label">AI Tutor</div><div class="msg-body"><span class="spin"></span>Thinking…<div class="retry-trail" id="retryTrail"></div></div>`;
  $chat.appendChild(loadEl);
  $chat.scrollTop = $chat.scrollHeight;
  const $retryTrail = loadEl.querySelector('#retryTrail');

  try {
    let dynamicSystem = SYSTEM;

    if (isEdit) {
      dynamicSystem += `\n\nThe user's HTML editor currently contains the following COMPLETE file:\n\`\`\`html\n${codeSnapshot}\n\`\`\`` + EDIT_SYSTEM_SUFFIX;
    } else if (codeContextOn) {
      const codeSnippet = codeSnapshot.length > 8000 ? codeSnapshot.slice(0, 8000) + '\n<!-- …truncated… -->' : codeSnapshot;
      dynamicSystem += `\n\nThe user's HTML editor currently contains the following code. It updates live as they type, so always treat this as their CURRENT code — even if they don't paste or mention it themselves:\n\`\`\`html\n${codeSnippet}\n\`\`\``;
    }

    const apiMessages = history.slice(-16).map(m => ({ role: m.role, content: m.content }));

    const modelChain = getModelChain();

    if (effort === 'other' && modelChain.length === 0) {
      loadEl.remove();
      setModelStatus('');
      addMsg('ai', `⚠️ No models loaded from the "Other" list yet. Click **↺ Refresh list** next to the Other model dropdown, or check that your GroqModels file has at least one model id.`);
      return;
    }

    let data = null, usedModel = null;
    const attemptLog = [];

    // Outer loop: try each API key. Inner loop: try each model.
    // On 401 we burn the key and rotate; on other errors we try the next model.
    outerLoop: while (true) {
      const key = activeKey();
      if (!key) break; // all keys exhausted

      for (let i = 0; i < modelChain.length; i++) {
        const modelId = modelChain[i];
        setModelStatus(`Trying ${modelLabel(modelId)}…`, false);

        try {
          data = await tryModel(modelId, key, dynamicSystem, apiMessages);
          usedModel = modelId;
          attemptLog.push({ id: modelId, ok: true });
          break outerLoop; // success!
        } catch (err) {
          attemptLog.push({ id: modelId, ok: false, msg: err.message });

          if (err.status === 401) {
            // Bad key — mark it exhausted, rotate, and restart the model loop with fresh key
            const hadNext = markCurrentKeyExhausted();
            if (!hadNext) break outerLoop; // truly out of keys
            // Update the retry trail to show key rotation
            if ($retryTrail) {
              $retryTrail.innerHTML = `<span class="fail">✗ Key rotated (auth failed)</span>`;
            }
            break; // break inner for-loop, outer while picks up with new key
          }

          // Non-auth error — update trail and try next model
          if ($retryTrail) {
            $retryTrail.innerHTML = attemptLog.map(a =>
              a.ok ? `<span class="ok">✓ ${modelLabel(a.id)}</span>`
                   : `<span class="fail">✗ ${modelLabel(a.id)}</span>`
            ).join(' → ');
          }
        }
      }
    }

    loadEl.remove();
    setModelStatus('');

    if (!data) {
      // Check if it was a total key exhaustion
      if (!activeKey() && keyPool.length > 0) {
        setKeyStatus('error', `All ${keyPool.length} pool key${keyPool.length !== 1 ? 's' : ''} exhausted — enter a key manually or refresh pool`);
        addMsg('ai', `❌ All API keys in the pool have been exhausted (returned 401). You can:\n\n- Click **↺ Refresh** in the key status bar to reload the pool from GitHub\n- Click **🔑 API Key** to enter a key manually`);
      } else {
        const lines = attemptLog.map(a => `✗ ${modelLabel(a.id)}: ${a.msg}`).join('\n');
        addMsg('ai', `❌ All models failed:\n\n${lines}`);
      }
      return;
    }

    const reply = data?.choices?.[0]?.message?.content || '(empty response)';
    const isFallback = usedModel !== modelChain[0];

    lastAI = reply;
    const histEntry = { role: 'assistant', content: reply, model: usedModel, fallback: isFallback };
    if (isEdit) { histEntry.isEdit = true; histEntry.codeSnapshot = codeSnapshot; }
    history.push(histEntry);
    if (history.length > 20) history = history.slice(-20);
    localStorage.setItem('chat', JSON.stringify(history));

    // Update key status to confirm which key index is working
    if (activeKeyIndex >= 0 && keyPool.length > 1) {
      setKeyStatus('ok', `Active: pool key ${activeKeyIndex + 1}/${keyPool.length}`);
    }

    addMsg('ai', reply, isEdit ? codeSnapshot : null, usedModel, isFallback);

  } catch (err) {
    loadEl.remove();
    setModelStatus('');
    addMsg('ai', `❌ Network error: ${err.message}`);
  }
}

// ── LINE DIFF (LCS-based) ─────────────────────────────────────────
function diffLines(oldStr, newStr) {
  const oldLines = oldStr.split('\n');
  const newLines = newStr.split('\n');
  const m = oldLines.length, n = newLines.length;

  if (m * n > 4_000_000) {
    const ops = [];
    oldLines.forEach(l => ops.push({ type: 'del', line: l }));
    newLines.forEach(l => ops.push({ type: 'add', line: l }));
    return ops;
  }

  const dp = Array.from({ length: m + 1 }, () => new Int32Array(n + 1));
  for (let i = m - 1; i >= 0; i--) {
    for (let j = n - 1; j >= 0; j--) {
      dp[i][j] = oldLines[i] === newLines[j] ? dp[i + 1][j + 1] + 1 : Math.max(dp[i + 1][j], dp[i][j + 1]);
    }
  }

  const ops = [];
  let i = 0, j = 0;
  while (i < m && j < n) {
    if (oldLines[i] === newLines[j]) { ops.push({ type: 'same', line: oldLines[i] }); i++; j++; }
    else if (dp[i + 1][j] >= dp[i][j + 1]) { ops.push({ type: 'del', line: oldLines[i] }); i++; }
    else { ops.push({ type: 'add', line: newLines[j] }); j++; }
  }
  while (i < m) { ops.push({ type: 'del', line: oldLines[i] }); i++; }
  while (j < n) { ops.push({ type: 'add', line: newLines[j] }); j++; }
  return ops;
}

function renderDiffBlock(oldCode, newCode) {
  const ops = diffLines(oldCode, newCode);
  const CONTEXT = 3;
  const n = ops.length;
  const show = new Array(n).fill(false);
  let addCount = 0, delCount = 0;
  ops.forEach((op, idx) => {
    if (op.type === 'add') addCount++;
    if (op.type === 'del') delCount++;
    if (op.type !== 'same') {
      for (let k = Math.max(0, idx - CONTEXT); k <= Math.min(n - 1, idx + CONTEXT); k++) show[k] = true;
    }
  });

  let body = '';
  let oldLn = 1, newLn = 1, i = 0;
  while (i < n) {
    if (!show[i]) {
      let j = i;
      while (j < n && !show[j]) j++;
      const count = j - i;
      body += `<div class="diff-collapsed">⋯ ${count} unchanged line${count > 1 ? 's' : ''} ⋯</div>`;
      for (let k = i; k < j; k++) { oldLn++; newLn++; }
      i = j;
      continue;
    }
    const op = ops[i];
    if (op.type === 'same') {
      body += `<div class="diff-line ctx"><span class="diff-ln">${oldLn}</span><span class="diff-code">${esc(op.line)}</span></div>`;
      oldLn++; newLn++;
    } else if (op.type === 'del') {
      body += `<div class="diff-line del"><span class="diff-ln">${oldLn}</span><span class="diff-code">− ${esc(op.line)}</span></div>`;
      oldLn++;
    } else {
      body += `<div class="diff-line add"><span class="diff-ln">${newLn}</span><span class="diff-code">+ ${esc(op.line)}</span></div>`;
      newLn++;
    }
    i++;
  }

  const id = editIdCounter++;
  pendingEdits[id] = { newCode };

  if (addCount === 0 && delCount === 0) {
    return `<div class="diff-wrap" data-edit-id="${id}"><div class="diff-header"><span>📝 Proposed changes</span><span class="diff-stats">no changes detected</span></div></div>`;
  }

  return `<div class="diff-wrap" data-edit-id="${id}">
    <div class="diff-header"><span>📝 Proposed changes</span><span class="diff-stats"><span class="add-count">+${addCount}</span> <span class="del-count">−${delCount}</span></span></div>
    <div class="diff-body">${body}</div>
    <div class="diff-actions">
      <button class="diff-apply" onclick="applyEdit(${id})">✅ Apply Changes</button>
      <button class="diff-discard" onclick="discardEdit(${id})">✖ Discard</button>
    </div>
  </div>`;
}

function applyEdit(id) {
  const data = pendingEdits[id];
  if (!data || data.done) return;
  $code.value = data.newCode;
  localStorage.setItem('code', $code.value);
  updateLines();
  runCode();
  data.done = true;
  markDiffDone(id, 'applied');
}

function discardEdit(id) {
  const data = pendingEdits[id];
  if (!data || data.done) return;
  data.done = true;
  markDiffDone(id, 'discarded');
}

function markDiffDone(id, state) {
  const wrap = document.querySelector(`.diff-wrap[data-edit-id="${id}"]`);
  if (!wrap) return;
  wrap.classList.add('diff-' + state);
  const actions = wrap.querySelector('.diff-actions');
  if (actions) {
    actions.innerHTML = state === 'applied'
      ? '<span class="diff-status applied">✅ Applied to editor</span>'
      : '<span class="diff-status discarded">✖ Discarded</span>';
  }
}

// ── CHAT RENDERING ───────────────────────────────────────────────
function addMsg(role, text, editSnapshot, modelId, isFallback) {
  const div = document.createElement('div');
  div.className = `msg ${role}`;
  const label = role === 'user' ? 'You' : 'AI Tutor';
  let body;
  if (role === 'user') {
    body = `<div class="msg-body">${esc(text)}</div>`;
  } else if (editSnapshot != null) {
    body = `<div class="msg-body">${mdWithDiff(text, editSnapshot)}</div>`;
  } else {
    body = `<div class="msg-body">${md(text)}</div>`;
  }
  let tag = '';
  if (role === 'ai' && modelId) {
    tag = `<div class="model-tag${isFallback ? ' fallback' : ''}">${isFallback ? '⤷ fell back to ' : 'via '}${modelLabel(modelId)}</div>`;
  }
  div.innerHTML = `<div class="msg-label">${label}</div>${tag}${body}`;
  $chat.appendChild(div);
  $chat.scrollTop = $chat.scrollHeight;

  div.querySelectorAll('.code-wrap button').forEach(btn => {
    btn.onclick = () => {
      const pre = btn.closest('.code-wrap').querySelector('pre');
      navigator.clipboard.writeText(pre.textContent).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy', 1500);
      });
    };
  });
}

function clearChat() {
  history = [];
  lastAI  = '';
  localStorage.removeItem('chat');
  $chat.innerHTML = '';
  pendingEdits = {};
}

function restoreChat() {
  history.forEach(m => addMsg(m.role === 'assistant' ? 'ai' : 'user', m.content, m.isEdit ? m.codeSnapshot : null, m.model, m.fallback));
  const last = [...history].reverse().find(m => m.role === 'assistant');
  if (last) lastAI = last.content;
  if (!history.length) {
    addMsg('ai', `Welcome! Type a topic and click a button to get started.\n\nAPI keys are loaded automatically — no setup needed.`);
  }
}

// ── MARKDOWN ─────────────────────────────────────────────────────
function esc(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function splitCodeParts(text) {
  const parts = [];
  const re = /```(\w*)\n?([\s\S]*?)```/g;
  let last = 0, m;
  while ((m = re.exec(text)) !== null) {
    if (m.index > last) parts.push({ t: 'text', v: text.slice(last, m.index) });
    parts.push({ t: 'code', lang: m[1] || 'html', v: m[2].trimEnd() });
    last = re.lastIndex;
  }
  parts.push({ t: 'text', v: text.slice(last) });
  return parts;
}

function mdText(v) {
  let t = esc(v);
  t = t.replace(/^### (.+)$/gm, '<h3>$1</h3>');
  t = t.replace(/^## (.+)$/gm,  '<h2>$1</h2>');
  t = t.replace(/^# (.+)$/gm,   '<h1>$1</h1>');
  t = t.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  t = t.replace(/\*(.+?)\*/g,     '<em>$1</em>');
  t = t.replace(/`([^`]+)`/g,     '<code>$1</code>');
  t = t.replace(/^&gt; (.+)$/gm,  '<blockquote>$1</blockquote>');
  t = t.replace(/^[\*\-] (.+)$/gm,'<li>$1</li>');
  t = t.replace(/^\d+\. (.+)$/gm, '<li>$1</li>');
  t = t.replace(/\n{2,}/g, '</p><p>');
  t = t.replace(/\n/g, '<br>');
  return `<p>${t}</p>`;
}

function md(text) {
  return splitCodeParts(text).map(p => {
    if (p.t === 'code') {
      return `<div class="code-wrap"><div class="code-top"><span>${esc(p.lang)}</span><button>Copy</button></div><pre>${esc(p.v)}</pre></div>`;
    }
    return mdText(p.v);
  }).join('');
}

function mdWithDiff(text, oldCode) {
  let usedDiff = false;
  return splitCodeParts(text).map(p => {
    if (p.t === 'code') {
      if (!usedDiff) {
        usedDiff = true;
        return renderDiffBlock(oldCode, p.v);
      }
      return `<div class="code-wrap"><div class="code-top"><span>${esc(p.lang)}</span><button>Copy</button></div><pre>${esc(p.v)}</pre></div>`;
    }
    return mdText(p.v);
  }).join('');
}

// ── INPUT AUTO-RESIZE & ENTER TO SEND ───────────────────────────
$input.addEventListener('input', () => {
  $input.style.height = 'auto';
  $input.style.height = Math.min($input.scrollHeight, 80) + 'px';
});
$input.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});
document.addEventListener('keydown', e => {
  if ((e.ctrlKey||e.metaKey) && e.key==='l') { e.preventDefault(); clearChat(); }
});

// ── START ────────────────────────────────────────────────────────
init();
</script>
