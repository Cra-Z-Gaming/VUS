<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AI HTML Learning Studio</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:      #0d1117;
  --bg2:     #161b22;
  --bg3:     #21262d;
  --border:  #30363d;
  --text:    #e6edf3;
  --muted:   #8b949e;
  --dim:     #484f58;
  --green:   #3fb950;
  --blue:    #58a6ff;
  --red:     #f85149;
  --yellow:  #d29922;
  --mono:    'Consolas', 'Fira Code', monospace;
  --ui:      system-ui, sans-serif;
}

html, body { height: 100vh; overflow: hidden; background: var(--bg); color: var(--text); font-family: var(--ui); font-size: 13px; }

/* ── LAYOUT ── */
#app {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

#toolbar {
  flex-shrink: 0;
  height: 40px;
  display: flex; align-items: center; gap: 6px; padding: 0 10px;
  background: var(--bg2); border-bottom: 1px solid var(--border);
}

#main { position: relative; flex: 1; overflow: hidden; }

#left-col {
  position: absolute; inset: 0;
  display: flex; flex-direction: row;
  overflow: hidden;
}

#editor-pane { flex: 1; min-width: 200px; display: flex; flex-direction: column; overflow: hidden; }

#h-resizer {
  flex-shrink: 0; width: 6px; cursor: col-resize;
  background: var(--bg2); border-left: 1px solid var(--border); border-right: 1px solid var(--border);
  position: relative;
}
#h-resizer::after {
  content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 3px; height: 36px; border-radius: 2px; background: var(--dim);
}
#h-resizer:hover::after, #h-resizer.dragging::after { background: var(--blue); }

#preview-pane { flex-shrink: 0; width: 42%; min-width: 200px; display: flex; flex-direction: column; overflow: hidden; }

/* ── FLOATING / DRAGGABLE AI PANEL ── */
#ai-pane {
  position: fixed;
  display: flex; flex-direction: column;
  background: var(--bg); border: 1px solid var(--border); border-radius: 8px;
  box-shadow: 0 12px 32px rgba(0,0,0,0.55);
  overflow: hidden;
  z-index: 50;
  min-width: 280px; min-height: 220px;
}
#ai-pane-header { cursor: move; user-select: none; gap: 6px; }
#ai-pane-header .right { font-size: 10px; color: var(--dim); margin-left: auto; }
#aiMinimizeBtn { padding: 1px 7px; font-size: 12px; line-height: 1.3; cursor: pointer; }
#ai-pane-body { display: flex; flex-direction: column; flex: 1; overflow: hidden; min-height: 0; }
#ai-resize-handle {
  position: absolute; right: 1px; bottom: 1px; width: 18px; height: 18px;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; color: var(--dim); cursor: nwse-resize; line-height: 1;
}
#ai-resize-handle:hover { color: var(--blue); }

/* ── KEY STATUS INDICATOR ── */
#keyStatusBar {
  display: flex; align-items: center; gap: 6px;
  padding: 4px 8px;
  background: var(--bg2); border-bottom: 1px solid var(--border);
  font-size: 10.5px; color: var(--dim); flex-shrink: 0;
}
#keyStatusDot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--dim); flex-shrink: 0;
}
#keyStatusDot.ok     { background: var(--green); }
#keyStatusDot.warn   { background: var(--yellow); }
#keyStatusDot.error  { background: var(--red); }
#keyStatusDot.loading { background: var(--blue); animation: pulse 1s ease-in-out infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
#keyStatusText { flex: 1; }
#keyStatusRefreshBtn {
  padding: 2px 6px; font-size: 10px; cursor: pointer;
  background: var(--bg3); border: 1px solid var(--border); border-radius: 4px; color: var(--muted);
}
#keyStatusRefreshBtn:hover { border-color: var(--blue); color: var(--blue); }

/* ── TOOLBAR BUTTONS ── */
button {
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: 5px;
  background: var(--bg3);
  color: var(--text);
  font-size: 12px;
  cursor: pointer;
  font-family: var(--ui);
  white-space: nowrap;
}
button:hover { border-color: var(--muted); }
button.green { background: var(--green); border-color: var(--green); color: #000; font-weight: 600; }
button.green:hover { opacity: 0.9; }
button.on { border-color: var(--blue); color: var(--blue); }
.sep { width: 1px; height: 20px; background: var(--border); margin: 0 2px; }
label.btn { padding: 4px 10px; border: 1px solid var(--border); border-radius: 5px; background: var(--bg3); color: var(--text); font-size: 12px; cursor: pointer; }
label.btn:hover { border-color: var(--muted); }
#fileInput { display: none; }

/* ── PANE HEADERS ── */
.pane-bar {
  display: flex; align-items: center; gap: 6px;
  padding: 0 10px; height: 30px;
  background: var(--bg2); border-bottom: 1px solid var(--border);
  flex-shrink: 0; font-size: 11px; color: var(--muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.6px;
}
.pane-bar span.right { margin-left: auto; font-weight: 400; text-transform: none; letter-spacing: 0; color: var(--dim); font-size: 11px; }

/* ── CODE EDITOR ── */
#editor-body {
  flex: 1; display: flex; overflow: hidden; min-height: 0;
}

#line-nums {
  padding: 8px 6px 8px 10px;
  background: var(--bg);
  color: var(--dim);
  font-family: var(--mono);
  font-size: 13px;
  line-height: 1.6;
  text-align: right;
  user-select: none;
  white-space: pre;
  overflow: hidden;
  border-right: 1px solid var(--border);
  min-width: 38px;
}

#code {
  flex: 1;
  background: var(--bg);
  color: var(--text);
  border: none; outline: none;
  padding: 8px 12px;
  font-family: var(--mono);
  font-size: 13px;
  line-height: 1.6;
  resize: none;
  overflow: auto;
  white-space: pre;
  tab-size: 2;
}

/* ── PREVIEW ── */
#preview { flex: 1; border: none; background: white; }

/* ── AI PANE ── */
#ai-buttons {
  padding: 8px;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}

#topic-row { display: flex; gap: 6px; align-items: center; margin-bottom: 7px; }
#topic-row label { font-size: 11px; color: var(--muted); white-space: nowrap; }
#topic {
  flex: 1; background: var(--bg3); color: var(--text);
  border: 1px solid var(--border); border-radius: 5px;
  padding: 4px 8px; font-size: 12px; font-family: var(--ui); outline: none;
}
#topic:focus { border-color: var(--blue); }

#toggle-row { display: flex; gap: 6px; margin-bottom: 7px; }
#toggle-row button { flex: 1; }

#codeContextBtn { }
#effort-row { display: flex; gap: 6px; align-items: center; margin-bottom: 7px; }
#effort-row label { font-size: 11px; color: var(--muted); white-space: nowrap; }
.effort-btn {
  flex: 1; display: flex; flex-direction: column; align-items: center; gap: 1px;
  padding: 5px 4px;
}
.effort-btn .effort-sub { font-size: 9px; color: var(--dim); }
.effort-btn.active { border-color: var(--blue); color: var(--blue); background: var(--bg2); }
.effort-btn.active .effort-sub { color: var(--blue); }

#fastModelRow { margin-bottom: 7px; }
#fastModelRow select {
  width: 100%; background: var(--bg3); color: var(--text);
  border: 1px solid var(--border); border-radius: 5px;
  padding: 5px 8px; font-size: 11.5px; font-family: var(--ui); outline: none; cursor: pointer;
}
#fastModelRow select:focus { border-color: var(--blue); }

#otherModelRow { margin-bottom: 7px; }
#otherModelRow select {
  width: 100%; background: var(--bg3); color: var(--text);
  border: 1px solid var(--border); border-radius: 5px;
  padding: 5px 8px; font-size: 11.5px; font-family: var(--ui); outline: none; cursor: pointer;
  margin-bottom: 5px;
}
#otherModelRow select:focus { border-color: var(--blue); }
#otherModelRow .other-meta {
  display: flex; align-items: center; justify-content: space-between;
  font-size: 10.5px; color: var(--dim);
}
#otherModelRow .other-meta button {
  padding: 2px 7px; font-size: 10px;
}

#modelStatusRow {
  font-size: 10.5px; color: var(--dim); margin-bottom: 7px; min-height: 13px;
}
#modelStatusRow.warn { color: #d29922; }

#qa-header {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 11px; color: var(--muted); cursor: pointer; padding: 4px 2px; user-select: none;
}
#qa-header:hover { color: var(--blue); }

.btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
.qbtn {
  padding: 5px 6px; font-size: 11px; text-align: left;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 5px; color: var(--text); cursor: pointer;
  font-family: var(--ui); overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.qbtn:hover { border-color: var(--blue); color: var(--blue); }
.qbtn.full { grid-column: 1 / -1; }

/* ── CHAT ── */
#chat {
  flex: 1; overflow-y: auto; padding: 10px; display: flex; flex-direction: column; gap: 10px; min-height: 0;
}

.msg { display: flex; flex-direction: column; gap: 3px; }
.msg-label { font-size: 10px; color: var(--dim); padding: 0 2px; }
.msg.user .msg-label { color: var(--blue); }
.msg.ai   .msg-label { color: var(--green); }
.msg-body {
  padding: 8px 10px; border-radius: 6px; border: 1px solid var(--border);
  font-size: 12.5px; line-height: 1.6; background: var(--bg2);
}
.msg.user .msg-body { background: var(--bg3); }

.msg-body p { margin: 4px 0; }
.msg-body h1,.msg-body h2,.msg-body h3 { color: var(--blue); margin: 8px 0 4px; }
.msg-body h1 { font-size: 15px; }
.msg-body h2 { font-size: 14px; }
.msg-body h3 { font-size: 13px; }
.msg-body ul,.msg-body ol { margin: 4px 0 4px 16px; }
.msg-body li { margin: 2px 0; }
.msg-body strong { color: var(--text); }
.msg-body em { color: #d29922; }
.msg-body code { background: #0d1117; color: #79c0ff; padding: 1px 5px; border-radius: 4px; font-family: var(--mono); font-size: 11.5px; }
.msg-body blockquote { border-left: 3px solid var(--blue); padding: 3px 8px; margin: 4px 0; color: var(--muted); background: var(--bg3); border-radius: 0 4px 4px 0; }
.code-wrap { margin: 6px 0; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
.code-top { display: flex; justify-content: space-between; align-items: center; padding: 3px 8px; background: var(--bg3); font-size: 10px; color: var(--dim); }
.code-top button { padding: 2px 7px; font-size: 10px; }
.code-wrap pre { margin: 0; padding: 10px; background: #0d1117; font-family: var(--mono); font-size: 12px; line-height: 1.6; overflow-x: auto; color: var(--text); }

.model-tag {
  font-size: 9.5px; color: var(--dim); padding: 0 2px 2px;
  font-family: var(--mono);
}
.model-tag.fallback { color: #d29922; }

.retry-trail { font-size: 10.5px; color: var(--dim); padding: 2px; line-height: 1.5; }
.retry-trail .fail { color: var(--red); }
.retry-trail .ok { color: var(--green); }

/* ── DIFF / EDIT VIEW ── */
.diff-wrap { margin: 6px 0; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
.diff-header { display: flex; justify-content: space-between; align-items: center; padding: 5px 9px; background: var(--bg3); font-size: 10.5px; color: var(--muted); font-weight: 600; }
.diff-stats { font-family: var(--mono); font-weight: 400; }
.diff-stats .add-count { color: var(--green); }
.diff-stats .del-count { color: var(--red); }
.diff-body { max-height: 320px; overflow: auto; background: #0d1117; font-family: var(--mono); font-size: 11.5px; line-height: 1.55; }
.diff-line { display: flex; white-space: pre; }
.diff-ln { flex-shrink: 0; width: 34px; text-align: right; padding: 0 6px; color: var(--dim); user-select: none; border-right: 1px solid var(--border); }
.diff-code { padding: 0 8px; white-space: pre-wrap; word-break: break-word; flex: 1; }
.diff-line.add { background: rgba(63, 185, 80, 0.15); }
.diff-line.add .diff-code { color: #7ee08a; }
.diff-line.del { background: rgba(248, 81, 73, 0.15); }
.diff-line.del .diff-code { color: #ff9d97; }
.diff-line.ctx .diff-code { color: var(--muted); }
.diff-collapsed { text-align: center; padding: 4px 0; color: var(--dim); font-size: 10.5px; font-family: var(--ui); background: var(--bg2); }
.diff-actions { display: flex; gap: 6px; padding: 7px 9px; background: var(--bg3); border-top: 1px solid var(--border); }
.diff-actions button { flex: 1; }
.diff-apply { background: var(--green); border-color: var(--green); color: #000; font-weight: 600; }
.diff-apply:hover { opacity: 0.9; }
.diff-discard { color: var(--red); border-color: var(--red); }
.diff-discard:hover { background: rgba(248, 81, 73, 0.1); }
.diff-status { font-size: 11.5px; font-weight: 600; padding: 2px 0; }
.diff-status.applied { color: var(--green); }
.diff-status.discarded { color: var(--red); }
.diff-wrap.diff-applied .diff-body, .diff-wrap.diff-discarded .diff-body { opacity: 0.55; }

/* spinner */
.spin { display: inline-block; width: 12px; height: 12px; border: 2px solid var(--border); border-top-color: var(--green); border-radius: 50%; animation: spin .7s linear infinite; margin-right: 6px; vertical-align: middle; }
@keyframes spin { to { transform: rotate(360deg); } }

/* ── CHAT INPUT ── */
#chat-input-area {
  padding: 8px; background: var(--bg2); border-top: 1px solid var(--border); flex-shrink: 0;
}
#input-row { display: flex; gap: 6px; }
#user-input {
  flex: 1; background: var(--bg3); color: var(--text);
  border: 1px solid var(--border); border-radius: 5px;
  padding: 6px 9px; font-size: 12.5px; font-family: var(--ui);
  outline: none; resize: none; min-height: 32px; max-height: 80px;
  line-height: 1.5;
}
#user-input:focus { border-color: var(--blue); }
#send-btn { width: 34px; height: 34px; padding: 0; display: flex; align-items: center; justify-content: center; background: var(--green); border-color: var(--green); border-radius: 5px; color: #000; flex-shrink: 0; }
#send-btn:hover { opacity: 0.85; }

/* ── API KEY MODAL ── */
#keyModalOverlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.6);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
}
#keyModal {
  background: var(--bg2); border: 1px solid var(--border); border-radius: 10px;
  width: 420px; max-width: 90vw; padding: 20px;
  box-shadow: 0 16px 40px rgba(0,0,0,0.6);
}
#keyModal h2 { font-size: 15px; margin-bottom: 8px; color: var(--text); }
#keyModal p { font-size: 12px; color: var(--muted); line-height: 1.5; margin-bottom: 12px; }
#keyModal a { color: var(--blue); }
#keyModalInput {
  width: 100%; background: var(--bg3); color: var(--text);
  border: 1px solid var(--border); border-radius: 6px;
  padding: 8px 10px; font-size: 13px; font-family: var(--mono);
  outline: none; margin-bottom: 12px;
}
#keyModalInput:focus { border-color: var(--blue); }
#keyModalActions { display: flex; gap: 8px; }
#keyModalActions button { flex: 1; padding: 7px 10px; }
#keyModalError { font-size: 11.5px; color: var(--red); margin-top: -4px; margin-bottom: 10px; min-height: 14px; }

/* scrollbars */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
</head>
<body>
<div id="app">

  <!-- TOOLBAR -->
  <div id="toolbar">
    <button class="green" onclick="runCode()">▶ Run</button>
    <button id="autoBtn" class="on" onclick="toggleAuto()">⟳ Auto</button>
    <div class="sep"></div>
    <button onclick="openTab()">↗ New Tab</button>
    <input type="file" id="fileInput" accept=".html,.htm" onchange="importFile(event)">
    <label for="fileInput" class="btn">⬆ Import</label>
    <button onclick="exportFile()">⬇ Export</button>
    <button onclick="resetEditor()" style="color:var(--red)">↺ Reset</button>
    <div class="sep"></div>
    <button onclick="clearChat()">🗑 Clear Chat</button>
    <button onclick="openKeyModal(true)">🔑 API Key</button>
  </div>

  <!-- MAIN AREA -->
  <div id="main">

    <div id="left-col">
      <!-- EDITOR PANE -->
      <div id="editor-pane">
        <div class="pane-bar">
          Editor
          <span class="right" id="status">0 lines · 0 chars</span>
        </div>
        <div id="editor-body">
          <div id="line-nums">1</div>
          <textarea id="code" spellcheck="false" autocorrect="off" autocomplete="off"></textarea>
        </div>
      </div>

      <div id="h-resizer" title="Drag to resize editor / preview width"></div>

      <!-- PREVIEW PANE -->
      <div id="preview-pane">
        <div class="pane-bar">Preview</div>
        <iframe id="preview" sandbox="allow-scripts allow-same-origin allow-forms"></iframe>
      </div>
    </div>

    <!-- FLOATING / DRAGGABLE / MINIMIZABLE AI PANE -->
    <div id="ai-pane">
      <div class="pane-bar" id="ai-pane-header">
        <span>AI Tutor</span>
        <button id="aiMinimizeBtn" onclick="toggleAIMinimize(event)" title="Minimize / Restore">─</button>
        <span class="right">⠿ drag</span>
      </div>

      <div id="ai-pane-body">

        <!-- KEY STATUS BAR -->
        <div id="keyStatusBar">
          <div id="keyStatusDot" class="loading"></div>
          <span id="keyStatusText">Fetching API keys…</span>
          <button id="keyStatusRefreshBtn" onclick="refreshKeyPool()" title="Reload keys from GitHub">↺ Refresh</button>
        </div>

        <div id="ai-buttons">
          <div id="topic-row">
            <label>Topic:</label>
            <input id="topic" type="text" placeholder="e.g. Forms, Grid, Flexbox…">
          </div>

          <div id="toggle-row">
            <button id="codeContextBtn" class="on" onclick="toggleCodeContext()">📄 Reads Code: ON</button>
            <button id="editModeBtn" onclick="toggleEditMode()">✏️ Edit Mode: OFF</button>
          </div>

          <div id="effort-row">
            <label>Effort:</label>
            <button class="effort-btn" id="effortLowBtn" onclick="setEffort('low')">⚡ Low<span class="effort-sub">instant</span></button>
            <button class="effort-btn" id="effortHighBtn" onclick="setEffort('high')">🧠 High<span class="effort-sub">versatile</span></button>
            <button class="effort-btn" id="effortOtherBtn" onclick="setEffort('other')">🔀 Other<span class="effort-sub">custom list</span></button>
          </div>

          <div id="fastModelRow">
            <select id="fastModelSelect" onchange="setFastModel(this.value)"></select>
          </div>

          <div id="otherModelRow">
            <select id="otherModelSelect" onchange="setOtherPreferredModel(this.value)"></select>
            <div class="other-meta">
              <span id="otherModelCount">0 models loaded</span>
              <button id="otherModelRefreshBtn" onclick="refreshOtherModels()">↺ Refresh list</button>
            </div>
          </div>

          <div id="modelStatusRow"></div>

          <div id="qa-header" onclick="toggleQuickActions()">
            <span>Quick Actions</span><span id="qa-chevron">▾</span>
          </div>
          <div class="btn-grid" id="btn-grid">
            <button class="qbtn" onclick="quick('explain')">📖 Explain Topic</button>
            <button class="qbtn" onclick="quick('problem')">✏️ Practice Problem</button>
            <button class="qbtn" onclick="quick('howto')">🛠 How To</button>
            <button class="qbtn" onclick="quick('hint')">💡 Give Hint</button>
            <button class="qbtn" onclick="quick('explainCode')">🔍 Explain My Code</button>
            <button class="qbtn" onclick="quick('findMistake')">🐛 Find Mistake</button>
            <button class="qbtn" onclick="quick('improve')">⚡ Improve Code</button>
            <button class="qbtn" onclick="quick('accessibility')">♿ Accessibility</button>
            <button class="qbtn" onclick="quick('semantic')">🏷 Semantic HTML</button>
            <button class="qbtn" onclick="quick('bestPractices')">⭐ Best Practices</button>
            <button class="qbtn" onclick="quick('optimize')">🚀 Optimize</button>
            <button class="qbtn" onclick="quick('solution')">✅ Show Solution</button>
            <button class="qbtn full" onclick="quickEdit()">🪄 Ask AI to Edit My Code</button>
            <button class="qbtn full" onclick="focusInput()">💬 Ask Anything…</button>
          </div>
        </div>

        <div id="chat"></div>

        <div id="chat-input-area">
          <div id="input-row">
            <textarea id="user-input" rows="1" placeholder="Ask anything about HTML…"></textarea>
            <button id="send-btn" onclick="sendMessage()">➤</button>
          </div>
        </div>
      </div>

      <div id="ai-resize-handle" title="Drag to resize">⤡</div>
    </div>

  </div>

</div>

<!-- API KEY MODAL (last-resort / manual override) -->
<div id="keyModalOverlay" style="display:none;">
  <div id="keyModal">
    <h2>🔑 Manual API Key</h2>
    <p>
      All keys from the pool have been exhausted or are invalid. Paste a Groq API key
      manually to continue — it will be stored in this tab's local storage and used
      alongside the pool on your next visit. Get a free key at
      <a href="https://console.groq.com/keys" target="_blank" rel="noopener">console.groq.com/keys</a>.
    </p>
    <input id="keyModalInput" type="password" placeholder="gsk_..." autocomplete="off" spellcheck="false">
    <div id="keyModalError"></div>
    <div id="keyModalActions">
      <button onclick="closeKeyModal()" id="keyModalCancelBtn">Cancel</button>
      <button class="green" onclick="saveKeyFromModal()">Save Key</button>
    </div>
  </div>
</div>

<script>
// ── CONFIG ──────────────────────────────────────────────────────
const KEY_POOL_URL    = 'https://raw.githubusercontent.com/Cra-Z-Gaming/VUS/refs/heads/main/GroqAPIKeys';
