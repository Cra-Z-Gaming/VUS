// Manual override key (stored in localStorage, used as last resort)
let manualApiKey = localStorage.getItem('groqApiKey') || '';

// Returns the currently active key, or '' if none available.
function activeKey() {
  if (activeKeyIndex >= 0 && activeKeyIndex < keyPool.length) {
    return keyPool[activeKeyIndex];
  }
  return manualApiKey || '';
}

// Advance to the next key in the pool that isn't exhausted.
// Returns true if a new key was found, false if all are exhausted.
function rotateToNextKey() {
  for (let i = 0; i < keyPool.length; i++) {
    const idx = (activeKeyIndex + 1 + i) % keyPool.length;
    if (!exhaustedKeys.has(keyPool[idx])) {
      activeKeyIndex = idx;
      setKeyStatus('ok', `Key rotated — using pool key ${activeKeyIndex + 1}/${keyPool.length}`);
      return true;
    }
  }
  // Try manual key as last resort
  if (manualApiKey && !exhaustedKeys.has(manualApiKey)) {
    activeKeyIndex = -1; // signals "use manualApiKey"
    setKeyStatus('warn', 'Pool exhausted — using manual key');
    return true;
  }
  activeKeyIndex = -1;
  return false;
}

// Mark the current key as bad and rotate.
function markCurrentKeyExhausted() {
  const bad = activeKey();
  if (bad) exhaustedKeys.add(bad);
  return rotateToNextKey();
}

// Fetch (or re-fetch) the key pool from GitHub.
async function fetchKeyPool() {
  if (poolFetchInFlight) return;
  poolFetchInFlight = true;
  setKeyStatus('loading', 'Fetching API keys…');
  try {
    const res = await fetch(KEY_POOL_URL + '?nocache=' + Date.now());
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const raw = await res.text();
    // File is plain text, one key per line — split on newlines (NOT JSON).
    const fresh = [...new Set(
      raw.split('\n')
         .map(k => k.trim())
         .filter(k => k.length > 0)
    )];
    if (fresh.length === 0) throw new Error('No keys found in pool file');
    keyPool = fresh;
    poolFetchedAt = Date.now();
    // Re-clear exhausted set on refresh so newly-added keys get a shot
    exhaustedKeys = new Set();
    // Pick a random starting key
    activeKeyIndex = Math.floor(Math.random() * keyPool.length);
    setKeyStatus('ok', `Pool ready — ${keyPool.length} key${keyPool.length !== 1 ? 's' : ''} available`);
  } catch (err) {
    // Couldn't fetch — fall back to manual key if present
    if (manualApiKey) {
      setKeyStatus('warn', `Pool fetch failed — using manual key (${err.message})`);
    } else {
      setKeyStatus('error', `Pool fetch failed: ${err.message} — click 🔑 to add a key manually`);
    }
  } finally {
    poolFetchInFlight = false;
  }
}

async function refreshKeyPool() {
  exhaustedKeys = new Set(); // clear exhausted list so we retry everything
  await fetchKeyPool();
}

