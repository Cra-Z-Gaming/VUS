<!DOCTYPE html>
<html>
<head>
<style>
body {
    font-family: Arial, sans-serif;
}

/* vertical stack */
.panel {
    width: 320px;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

/* row container */
.row {
    display: flex;
    align-items: center;
}

/* left status box */
.key {
    width: 90px;
    height: 55px;
    border-radius: 12px;
    background: #777;
    color: white;
    font-weight: bold;

    display: flex;
    align-items: center;
    justify-content: center;

    z-index: 1;
}

/* colors */
.green { background: #2ecc71; }
.red { background: #e74c3c; }

/* right button */
.big-button {
    height: 55px;
    flex: 1;

    border-radius: 12px;
    background: #333;
    color: white;
    text-decoration: none;
    font-weight: bold;

    display: flex;
    align-items: center;
    justify-content: center;

    margin-left: -20px;
    padding-left: 20px;

    z-index: 0;
    transition: 0.15s;
}

.big-button:hover {
    background: #444;
}
</style>
</head>

<body>

<div class="panel">

    <div class="row">
        <div id="k1" class="key">K1</div>
        <a class="big-button" href="https://link1.com">Link 1</a>
    </div>

    <div class="row">
        <div id="k2" class="key">K2</div>
        <a class="big-button" href="https://link2.com">Link 2</a>
    </div>

    <div class="row">
        <div id="k3" class="key">K3</div>
        <a class="big-button" href="https://link3.com">Link 3</a>
    </div>

    <!-- NEW 4TH OPTION -->
    <div class="row">
        <div id="k4" class="key">K4</div>
        <a class="big-button" href="https://link4.com">Link 4</a>
    </div>

</div>

<script>
async function checkKey(id, key) {
    try {
        let url = `https://www.googleapis.com/youtube/v3/search?part=snippet&q=test&maxResults=1&key=${key}`;
        let res = await fetch(url);

        if (res.ok) {
            document.getElementById(id).className = "key green";
        } else {
            document.getElementById(id).className = "key red";
        }

    } catch (e) {
        document.getElementById(id).className = "key red";
    }
}

/* YOUR KEYS HERE */
checkKey("k1", "AIzaSyBoB_nYoUAJch5FP-UAjbhMRF5MZqpwMa0");
checkKey("k2", "AIzaSyAvuFrMdGJeBUzf7PXDYoPxKn9ohXOi-UI");
checkKey("k3", "AIzaSyAlwjZuIeTDpm1rPG5ZlCaji2UxLGeDFkE");
checkKey("k4", "AIzaSyChzXm8i27Ozi2grJUupvgv4f33Mqimg-Q");
</script>

</body>
</html>
