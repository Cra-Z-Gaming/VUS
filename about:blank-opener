<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>File & URL Opener</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #0f172a;
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
            min-height: 100vh;
        }

        h1 {
            font-size: 24px;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 13px;
            color: #64748b;
            margin-bottom: 40px;
        }

        .section {
            width: 100%;
            max-width: 500px;
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 16px;
        }

        .section-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #64748b;
            margin-bottom: 12px;
        }

        input[type="file"] {
            display: none;
        }

        input[type="text"] {
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px solid #334155;
            background: #0f172a;
            color: white;
            font-size: 14px;
            margin-bottom: 12px;
        }

        input[type="text"]::placeholder {
            color: #64748b;
        }

        input[type="text"]:focus {
            outline: none;
            border-color: #22c55e;
        }

        .file-label {
            display: block;
            width: 100%;
            padding: 10px 14px;
            border-radius: 8px;
            border: 1px dashed #334155;
            background: #0f172a;
            color: #94a3b8;
            font-size: 14px;
            cursor: pointer;
            text-align: center;
            transition: border-color 0.2s, color 0.2s;
            margin-bottom: 12px;
        }

        .file-label:hover {
            border-color: #22c55e;
            color: white;
        }

        .file-label.selected {
            border-color: #22c55e;
            color: #22c55e;
        }

        button {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: none;
            background: #22c55e;
            color: black;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }

        button:hover {
            background: #16a34a;
        }

        button:disabled {
            background: #1e3a2a;
            color: #4b7a5a;
            cursor: default;
        }

        #toast {
            position: fixed;
            bottom: 24px;
            left: 50%;
            transform: translateX(-50%) translateY(60px);
            background: #ef4444;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 14px;
            opacity: 0;
            transition: opacity 0.3s, transform 0.3s;
            pointer-events: none;
            z-index: 999;
        }

        #toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
    </style>
</head>

<body>

    <h1>File & URL Opener</h1>
    <p class="subtitle">Open local files or embed a site in about:blank</p>

    <!-- File Section -->
    <div class="section">
        <div class="section-label">Open Local File</div>

        <label class="file-label" id="fileLabel" for="fileInput">
            Click to choose any file
        </label>

        <input type="file" id="fileInput" onchange="fileSelected()" />

        <button id="fileBtn" onclick="openFile()" disabled>
            Open File
        </button>
    </div>

    <!-- URL Section -->
    <div class="section">
        <div class="section-label">Open URL</div>

        <input type="text" id="urlInput" placeholder="Enter full URL (e.g., https://example.com)">

        <button onclick="launchSite()">
            Open Page
        </button>
    </div>

    <div id="toast"></div>

    <script>
        let selectedFile = null;
        let toastTimer = null;

        function showToast(msg) {
            const toast = document.getElementById("toast");
            toast.textContent = msg;
            toast.classList.add("show");
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => toast.classList.remove("show"), 3000);
        }

        function writeToBlank(html) {
            const win = window.open("about:blank", "_blank");

            if (!win) {
                showToast("Popup blocked — allow popups for this page");
                return;
            }

            win.document.open();
            win.document.write(html);
            win.document.close();
        }

        function fileSelected() {
            const input = document.getElementById("fileInput");
            selectedFile = input.files[0] || null;

            const label = document.getElementById("fileLabel");
            const btn = document.getElementById("fileBtn");

            if (selectedFile) {
                label.textContent = selectedFile.name;
                label.classList.add("selected");
                btn.disabled = false;
            } else {
                label.textContent = "Click to choose any file";
                label.classList.remove("selected");
                btn.disabled = true;
            }
        }

        function openFile() {
            if (!selectedFile) return;

            const reader = new FileReader();
            reader.onerror = () => showToast("Failed to read file");

            if (/\.(html|htm)$/i.test(selectedFile.name)) {
                reader.onload = e => writeToBlank(e.target.result);
            } else {
                reader.onload = e => {
                    const escaped = e.target.result
                        .replace(/&/g, "&amp;")
                        .replace(/</g, "&lt;")
                        .replace(/>/g, "&gt;");

                    const html = `
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>${selectedFile.name}</title>
<style>
  body { margin: 0; background: #0f172a; color: #e2e8f0; font-family: monospace; font-size: 14px; }
  pre { padding: 20px; white-space: pre-wrap; word-break: break-word; margin: 0; }
  header { padding: 10px 20px; background: #111827; border-bottom: 1px solid #1f2937; font-size: 13px; color: #64748b; }
</style>
</head>
<body>
<header>${selectedFile.name}</header>
<pre>${escaped}</pre>
</body>
</html>`;

                    writeToBlank(html);
                };
            }

            reader.readAsText(selectedFile);
        }

        function launchSite() {
            let targetUrl = document.getElementById('urlInput').value.trim();

            if (!targetUrl) {
                showToast("Enter a URL first");
                return;
            }

            if (!/^https?:\/\//i.test(targetUrl)) {
                targetUrl = 'https://' + targetUrl;
            }

            const win = window.open('about:blank', '_blank');

            if (!win) {
                showToast("Popup blocked — allow popups for this page");
                return;
            }

            const doc = win.document;
            doc.body.style.margin = '0';
            doc.body.style.padding = '0';
            doc.body.style.overflow = 'hidden';

            const iframe = doc.createElement('iframe');
            iframe.src = targetUrl;
            iframe.style.width = '100vw';
            iframe.style.height = '100vh';
            iframe.style.border = 'none';
            iframe.style.display = 'block';

            doc.body.appendChild(iframe);
        }
    </script>

</body>
</html>
