  allgames:  { id: "allgames",  label: "All Games", emoji: "🗂", games: [], isVirtual: true },
  favorites: { id: "favorites", label: "Favs", emoji: "⭐", games: [] },
  external:  { id: "external",  label: "External", emoji: "🌐", games: [], isExternal: true }
};

/* ── State ─────────────────────────────────────────── */
let activePack = "vusl";
let favorites  = new Set(JSON.parse(localStorage.getItem("vusl15-favs") || "[]"));

// External pack manifest is just filenames — actual HTML content lives in IndexedDB.
// (localStorage kept small on purpose; never stash game HTML there.)
PACKS.external.games = JSON.parse(localStorage.getItem("vusl17-ext-manifest") || "[]");

function saveExternalManifest() {
  localStorage.setItem("vusl17-ext-manifest", JSON.stringify(PACKS.external.games));
}

// statusMap: "packId:filename" → "unknown"|"loading"|"cached"|"failed"
// Use a NUL-ish separator that can't appear in filenames/pack ids to avoid
// ambiguity if either ever contains a colon.
const SEP = "\u0001";
function idbKey(packId, filename) { return packId + SEP + filename; }
function splitKey(key) {
  const i = key.indexOf(SEP);
  return [key.slice(0, i), key.slice(i + 1)];
}

const statusMap = new Map();

// ① PERF: O(1) card DOM lookup — populated in renderGrid, cleared on re-render
const cardNodeCache = new Map(); // key → card HTMLElement

// Queue
const loadQueue   = [];
const activeLoads = new Set();
const MAX_PAR     = 25;

let loadingAll    = false;
let loadAllTarget = 0;
let loadAllSettled = 0;
let retryTimer    = null;

/* ── Cached element refs (⑦) ──────────────────────── */
const $statusLine   = document.getElementById("statusLine");
const $progressWrap = document.getElementById("progressWrap");
const $progressFill = document.getElementById("progressFill");
const $retryBtn      = document.getElementById("retryBtn");
const $loadAllBtn     = document.getElementById("loadAllBtn");
const $refreshBtn     = document.getElementById("refreshBtn");
const $gameArea      = document.getElementById("gameArea");
const $countLabel   = document.getElementById("countLabel");
const $search        = document.getElementById("search");
const $packTabs      = document.getElementById("packTabs");
const $toast          = document.getElementById("toast");
const $notifBanner   = document.getElementById("notifBanner");
const $confirmModal  = document.getElementById("confirmModal");
const $confirmTitle  = document.getElementById("confirmTitle");
const $confirmBody   = document.getElementById("confirmBody");
const $confirmSkip   = document.getElementById("confirmSkip");
const $confirmOverwrite = document.getElementById("confirmOverwrite");
const $fileInputFiles  = document.getElementById("fileInputFiles");
const $fileInputFolder = document.getElementById("fileInputFolder");

/* ── Helpers ────────────────────────────────────────── */
function prettyName(filename) {
  const base = filename.replace(/\.(html|htm)$/i, "");
  return base.replace(/(\D)(\d+)$/, "$1 $2");
}

function statusIcon(s) {
  return s === "cached"  ? "✔" :
         s === "loading" ? "⏳" :
         s === "failed"  ? "❌" : "○";
}

function esc(s = "") {
  return String(s)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;")
    .replace(/>/g,"&gt;").replace(/"/g,"&quot;");
}

/* ── IndexedDB ──────────────────────────────────────── */
let db;
async function initDB() {
  return new Promise((res, rej) => {
    const r = indexedDB.open("VUSL_V17_DB", 1);
    r.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains("html")) d.createObjectStore("html");
    };
    r.onsuccess = e => { db = e.target.result; res(); };
    r.onerror   = e => rej(e);
  });
}

function dbGet(key) {
  return new Promise(res => {
    const r = db.transaction("html","readonly").objectStore("html").get(key);
    r.onsuccess = () => res(r.result || null);
    r.onerror   = () => res(null);
  });
}

function dbPut(key, html) {
  return new Promise(res => {
    const r = db.transaction("html","readwrite").objectStore("html").put(html, key);
    r.onsuccess = () => res(true);
    r.onerror   = () => res(false);
  });
}

/* Batch write — one transaction for many key/value pairs.
   Far faster than N separate dbPut() transactions, which is
   what made multi-file uploads feel slow. */
function dbPutMany(entries) { // entries: [[key, html], ...]
  return new Promise((res, rej) => {
    const tx    = db.transaction("html", "readwrite");
    const store = tx.objectStore("html");
    for (const [key, html] of entries) store.put(html, key);
    tx.oncomplete = () => res(true);
    tx.onerror    = () => rej(tx.error);
  });
}

function dbDelete(key) {
  return new Promise(res => {
    const r = db.transaction("html","readwrite").objectStore("html").delete(key);
    r.onsuccess = () => res(true);
    r.onerror   = () => res(false);
  });
}

function dbGetAllKeys() {
  return new Promise(res => {
    const r = db.transaction("html","readonly").objectStore("html").getAllKeys();
    r.onsuccess = () => res(r.result || []);
    r.onerror   = () => res([]);
  });
}

function dbClearAll() {
  return new Promise(res => {
    const tx = db.transaction("html","readwrite");
    tx.objectStore("html").clear();
    tx.oncomplete = res;
  });
}

/* ── Cache Scan (⑤ O(1) Set lookup) ────────────────── */
async function scanCache() {
  const cachedKeys = new Set(await dbGetAllKeys());
  for (const [pid, pack] of Object.entries(PACKS)) {
    if (pid === "favorites") continue;
    for (const fn of pack.games) {
      const k = idbKey(pid, fn);
      if (statusMap.get(k) === "loading") continue; // never downgrade loading
      statusMap.set(k, cachedKeys.has(k) ? "cached" : (statusMap.get(k) === "failed" ? "failed" : "unknown"));
    }
  }
}

/* ⓓ Manual refresh — re-scans IndexedDB and rebuilds the whole screen
 * (tabs + grid + status line) so newly downloaded/uploaded games show
 * their correct outline immediately. Shows a brief full-screen overlay
 * so it's unmistakable that something actually happened, rather than
 * a silent DOM patch a user might miss. */
let refreshOverlayEl = null;
function showRefreshOverlay(msg) {
  if (!refreshOverlayEl) {
    refreshOverlayEl = document.createElement("div");
    refreshOverlayEl.id = "refreshOverlay";
    refreshOverlayEl.style.cssText = `
      position:fixed; inset:0; background:rgba(10,10,13,.72);
      display:flex; align-items:center; justify-content:center;
      z-index:9700; font-family:var(--display); font-size:14px;
      font-weight:800; letter-spacing:1px; color:var(--accent);
      flex-direction:column; gap:10px;
    `;
    document.body.appendChild(refreshOverlayEl);
  }
  refreshOverlayEl.innerHTML = `<div style="font-size:26px;animation:spin .8s linear infinite">⟳</div><div>${esc(msg)}</div>`;
  refreshOverlayEl.style.display = "flex";
}
function hideRefreshOverlay() {
  if (refreshOverlayEl) refreshOverlayEl.style.display = "none";
}

async function fullScreenRefresh(reason) {
  showRefreshOverlay(reason || "Refreshing…");
  await scanCache();
  renderPackTabs();
  renderGrid();
  refreshStatus();
  // small delay so the overlay is actually perceptible even when the
  // scan/render finish near-instantly on a fast machine
  await new Promise(r => setTimeout(r, 260));
  hideRefreshOverlay();
}

async function manualRefresh() {
  $refreshBtn.disabled = true;
  $refreshBtn.textContent = "⟳ …";
  await fullScreenRefresh("Refreshing cache status…");
  $refreshBtn.disabled = false;
  $refreshBtn.textContent = "⟳ Refresh";
  toast("Refreshed cache status", "info", 1400);
}

/* ── Toast & Notif ──────────────────────────────────── */
let toastTmr;
function toast(msg, type = "success", ms = 2400) {
  $toast.textContent = msg;
  $toast.className   = "show " + type;
  clearTimeout(toastTmr);
  toastTmr = setTimeout(() => { $toast.className = ""; }, ms);
}

function showBanner(msg, ms = 4000) {
  $notifBanner.textContent   = msg;
  $notifBanner.style.display = "block";
  setTimeout(() => { $notifBanner.style.display = "none"; }, ms);
}

/* ── Confirm Modal (Promise-based) ─────────────────── */
function askConfirm(title, body, { confirmLabel = "Overwrite", skipLabel = "Skip duplicates" } = {}) {
  return new Promise(resolve => {
    $confirmTitle.textContent = title;
    $confirmBody.textContent  = body;
    $confirmSkip.textContent  = skipLabel;
    $confirmOverwrite.textContent = confirmLabel;
    $confirmModal.style.display = "flex";

    function cleanup(result) {
      $confirmModal.style.display = "none";
      $confirmSkip.onclick = null;
      $confirmOverwrite.onclick = null;
      resolve(result);
    }
    $confirmSkip.onclick      = () => cleanup("skip");
    $confirmOverwrite.onclick = () => cleanup("overwrite");
  });
}

/* ── Progress Bar ───────────────────────────────────── */
function setProgress(pct) {
  if (pct <= 0) { $progressWrap.style.display = "none"; $progressFill.style.width = "0%"; return; }
  $progressWrap.style.display = "block";
  $progressFill.style.width   = Math.min(100, pct).toFixed(1) + "%";
  if (pct >= 100) setTimeout(() => setProgress(0), 600);
}

/* ── Status Line (⑦ no getElementById per call) ────── */
function refreshStatus() {
  const games   = getActiveGames();
  const total   = games.length;
  let cached = 0, failed = 0;
  for (const [pid, fn] of games) {
    const s = statusMap.get(idbKey(pid, fn));
    if (s === "cached") cached++;
    else if (s === "failed") failed++;
  }
  const loading = activeLoads.size;
  const parts   = [`${total} games`, `${cached} cached`];
  if (loading) parts.push(`${loading} loading`);
  if (failed)  parts.push(`${failed} failed`);
  $statusLine.textContent = parts.join(" · ");
  $retryBtn.style.display = failed > 0 ? "" : "none";
}

/* ── Get Games for Active Pack ─────────────────────── */
function getActiveGames() {
  if (activePack === "favorites") {
    return [...favorites].map(k => splitKey(k));
  }
  if (activePack === "allgames") {
    // Combine every real pack (not favorites/allgames itself) into one list.
    const combined = [];
    for (const [pid, pack] of Object.entries(PACKS)) {
      if (pid === "favorites" || pid === "allgames") continue;
      for (const fn of pack.games) combined.push([pid, fn]);
    }
    return combined;
  }
  return (PACKS[activePack]?.games || []).map(fn => [activePack, fn]);
}

/* ── Pack Tabs ──────────────────────────────────────── */
function renderPackTabs() {
  const frag = document.createDocumentFragment();
  const ids  = Object.keys(PACKS); // vusl, favorites, external (external renders last => far right)
  ids.forEach((id, idx) => {
    const pack  = PACKS[id];
    const count = id === "favorites" ? favorites.size : (pack.games?.length || 0);
    const tab   = document.createElement("div");
    tab.className = "pack-tab"
      + (id === activePack ? " active" : "")
      + (idx === ids.length - 1 ? " pinned-right" : "")
      + (id === "allgames" ? " tab-allgames" : "");
    tab.innerHTML = `${pack.emoji} ${pack.label} <span class="tab-badge">${count}</span>`;
    tab.onclick   = () => switchPack(id);
    frag.appendChild(tab);
  });
  $packTabs.innerHTML = "";
  $packTabs.appendChild(frag);
}

function switchPack(id) {
  activePack = id;
  $search.value = "";
  renderPackTabs();
  renderGrid();
  refreshStatus();
}

/* ── Search Debounce (③) ─────────────────────────────── */
let searchDebounceTimer = null;
let searchRafId = null;
$search.addEventListener("input", () => {
  clearTimeout(searchDebounceTimer);
  searchDebounceTimer = setTimeout(() => {
    if (searchRafId) cancelAnimationFrame(searchRafId);
    searchRafId = requestAnimationFrame(renderGrid);
  }, 120);
});

/* ── Grid Render (② DocumentFragment, cache clear) ── */
function renderGrid() {
  cardNodeCache.clear();

  const frag  = document.createDocumentFragment();
  const query = $search.value.trim().toLowerCase();

  // External pack empty state (upload UI)
  if (activePack === "external" && PACKS.external.games.length === 0) {
    $gameArea.innerHTML = "";
    $gameArea.appendChild(makeExtUploadPanel());
    $countLabel.textContent = "0 games";
    return;
  }

  // Favorites empty state
  if (activePack === "favorites" && favorites.size === 0) {
    const e = document.createElement("div");
    e.className = "empty-state";
    e.innerHTML = `<div class="big">⭐</div><h2>No favorites yet</h2><p>Click the ☆ on any game to star it.<br>Starred games appear here across all packs.</p>`;
    $gameArea.innerHTML = "";
    $gameArea.appendChild(e);
    $countLabel.textContent = "0 games";
    return;
  }

  const all = getActiveGames();
  const filtered = query
    ? all.filter(([, fn]) => prettyName(fn).toLowerCase().includes(query))
    : all;

  $countLabel.textContent = filtered.length + " game" + (filtered.length !== 1 ? "s" : "");

  // Show upload row above the grid on the external tab even when non-empty
  if (activePack === "external") {
    frag.appendChild(makeExtUploadBar());
  }

  if (filtered.length === 0) {
    const e = document.createElement("div");
    e.className = "empty-state";
    e.innerHTML = `<div class="big">🔍</div><h2>No results</h2><p>No games match "<strong>${esc(query)}</strong>"</p>`;
    $gameArea.innerHTML = "";
    $gameArea.appendChild(frag);
    $gameArea.appendChild(e);
    return;
  }

  // Group by first letter
  const groups = {};
  for (const pair of filtered) {
    const letter = (prettyName(pair[1])[0] || "#").toUpperCase();
    (groups[letter] = groups[letter] || []).push(pair);
  }

  for (const letter of Object.keys(groups).sort()) {
    const sec  = document.createElement("div");
    sec.className = "section";
    const head = document.createElement("div");
    head.className   = "section-head";
    head.textContent = letter;
    const grid = document.createElement("div");
    grid.className   = "game-grid";
    for (const pair of groups[letter]) grid.appendChild(makeCard(...pair));
    sec.appendChild(head);
    sec.appendChild(grid);
    frag.appendChild(sec);
  }

  $gameArea.innerHTML = "";
  $gameArea.appendChild(frag);
}

/* ── Game Card ──────────────────────────────────────── */
function makeCard(packId, filename) {
  const key    = idbKey(packId, filename);
  const status = statusMap.get(key) || "unknown";
  const isFav  = favorites.has(key);
  const isExt  = packId === "external";

  const card = document.createElement("div");
  card.className   = "game-card " + status;
  card.dataset.key = key;

  const si = document.createElement("span");
  si.className   = "card-status";
  si.textContent = statusIcon(status);

  const nm = document.createElement("span");
  nm.className   = "card-name";
  nm.textContent = prettyName(filename);
  nm.title       = filename;



  const star = document.createElement("span");
  star.className   = "card-star" + (isFav ? " on" : "");
  star.textContent = isFav ? "⭐" : "☆";
  star.title       = isFav ? "Remove from favorites" : "Add to favorites";
  star.addEventListener("click", e => { e.stopPropagation(); toggleFav(packId, filename); });

  card.appendChild(si);
  card.appendChild(nm);

  if (activePack === "allgames") {
    const tag = document.createElement("span");
    tag.className   = "card-source-tag";
    tag.textContent = PACKS[packId]?.emoji || "";
    tag.title       = PACKS[packId]?.label || packId;
    card.appendChild(tag);
  }

  card.appendChild(star);

  if (isExt) {
    const rm = document.createElement("span");
    rm.className   = "card-remove";
    rm.textContent = "🗑";
    rm.title       = "Remove uploaded game";
    rm.addEventListener("click", e => { e.stopPropagation(); removeExternalGame(filename); });
    card.appendChild(rm);
  }

  card.addEventListener("click", () => launchGame(packId, filename));

  cardNodeCache.set(key, card);
  return card;
}

/* ① setCardStatus — O(1) via cardNodeCache ──────────── */
function setCardStatus(key, status) {
  statusMap.set(key, status);
  const card = cardNodeCache.get(key);
  if (!card) return;
  card.className = "game-card " + status;
  const si = card.querySelector(".card-status");
  if (si) si.textContent = statusIcon(status);
  refreshStatus();
}

/* ── Favorites ──────────────────────────────────────── */
function toggleFav(packId, filename) {
  const key    = idbKey(packId, filename);
  const wasFav = favorites.has(key);
  if (wasFav) { favorites.delete(key); toast("Removed from favorites", "info"); }
  else         { favorites.add(key);   toast("⭐ Added to favorites", "success"); }
  localStorage.setItem("vusl15-favs", JSON.stringify([...favorites]));

  const card = cardNodeCache.get(key);
  if (card) {
    const star = card.querySelector(".card-star");
    if (star) {
      star.className   = "card-star" + (favorites.has(key) ? " on" : "");
      star.textContent = favorites.has(key) ? "⭐" : "☆";
    }
  }
  renderPackTabs();
}

/* ══════════════════════════════════════════════════════
   ⓐⓑ External Tab — file/folder upload, merge not overwrite
════════════════════════════════════════════════════════ */

function makeExtUploadBar() {
  const bar = document.createElement("div");
  bar.className = "ext-upload-row";
  bar.style.marginBottom = "14px";
  bar.innerHTML = `
    <button class="btn btn-secondary" id="btnUploadFiles">📄 Upload Files</button>
    <button class="btn btn-secondary" id="btnUploadFolder">📁 Upload Folder</button>
  `;
  bar.querySelector("#btnUploadFiles").onclick  = () => $fileInputFiles.click();
  bar.querySelector("#btnUploadFolder").onclick = () => $fileInputFolder.click();
  return bar;
}

function makeExtUploadPanel() {
  const wrap = document.createElement("div");
  wrap.className = "empty-state";
  wrap.innerHTML = `
    <div class="big">🌐</div>
    <h2>External Pack</h2>
    <p>Upload your own HTML games from files or an entire folder. They're stored locally and play offline just like the built-in packs.</p>
    <div class="ext-config">
      <div class="ext-upload-row">
        <button class="btn btn-primary" id="btnUploadFilesEmpty">📄 Upload Files</button>
        <button class="btn btn-primary" id="btnUploadFolderEmpty">📁 Upload Folder</button>
      </div>
      <p class="ext-note">Accepts .html / .htm files. Uploading again later adds new games — it won't erase what's already here.</p>
    </div>
  `;
  wrap.querySelector("#btnUploadFilesEmpty").onclick  = () => $fileInputFiles.click();
  wrap.querySelector("#btnUploadFolderEmpty").onclick = () => $fileInputFolder.click();
  return wrap;
}

async function handleExternalUpload(fileList) {
  const htmlFiles = [...fileList].filter(f => /\.(html?|HTML?)$/.test(f.name));
  if (htmlFiles.length === 0) {
    toast("No .html/.htm files found in selection", "error");
    return;
  }

  const existing = new Set(PACKS.external.games);
  const duplicates = htmlFiles.filter(f => existing.has(f.name));
  let mode = "skip"; // default safe behavior when there are dupes
  if (duplicates.length > 0) {
    mode = await askConfirm(
      "Duplicate files found",
      `${duplicates.length} of ${htmlFiles.length} file${htmlFiles.length > 1 ? "s" : ""} share a name with games already uploaded. Skip duplicates (keep existing versions) or overwrite them with the new files?`
    );
  }

  // Decide which files actually get written before touching disk at all.
  const toWrite = [];
  let added = 0, overwritten = 0, skipped = 0;
  for (const file of htmlFiles) {
    const isDup = existing.has(file.name);
    if (isDup && mode === "skip") { skipped++; continue; }
    toWrite.push(file);
    if (isDup) overwritten++;
    else { added++; existing.add(file.name); PACKS.external.games.push(file.name); }
  }

  showRefreshOverlay(`Storing ${toWrite.length} game${toWrite.length !== 1 ? "s" : ""}…`);

  // Read every file's text in parallel (previously one-at-a-time,
  // serialized behind each IndexedDB write).
  const texts = await Promise.all(toWrite.map(f => f.text()));

  // Single IndexedDB transaction for the whole batch instead of one
  // transaction per file — this is the main reason uploads felt slow.
  const entries = toWrite.map((file, i) => [idbKey("external", file.name), texts[i]]);
  await dbPutMany(entries);
  for (const [key] of entries) statusMap.set(key, "cached");

  saveExternalManifest();

  // ⓔ Always do a full visible refresh after upload — regardless of which
  // tab the user is currently on — so games show as cached immediately
  // without needing to click a tab. Previously this silently patched the
  // DOM, which could look like nothing happened if the user wasn't
  // already looking at the External tab.
  await fullScreenRefresh("Finishing up…");

  const parts = [];
  if (added)       parts.push(`${added} added`);
  if (overwritten) parts.push(`${overwritten} overwritten`);
  if (skipped)     parts.push(`${skipped} skipped`);
  toast(`✔ Upload complete — ${parts.join(", ")}`, "success", 3200);
}

$fileInputFiles.addEventListener("change", e => {
  if (e.target.files.length) handleExternalUpload(e.target.files);
  e.target.value = ""; // allow re-selecting the same file later
});
$fileInputFolder.addEventListener("change", e => {
  if (e.target.files.length) handleExternalUpload(e.target.files);
  e.target.value = "";
});

async function removeExternalGame(filename) {
  const key = idbKey("external", filename);
  await dbDelete(key);
  statusMap.delete(key);
  PACKS.external.games = PACKS.external.games.filter(f => f !== filename);
  saveExternalManifest();
  favorites.delete(key);
  localStorage.setItem("vusl15-favs", JSON.stringify([...favorites]));
  renderPackTabs();
  renderGrid();
  refreshStatus();
  toast(`Removed "${prettyName(filename)}"`, "info");
}

/* ── Launch Game ────────────────────────────────────── */
async function launchGame(packId, filename) {
  const key = idbKey(packId, filename);

  // External games have no network fallback — they only exist in IndexedDB.
  if (packId === "external") {
    const cached = await dbGet(key);
    if (cached) { openGame(cached, ""); return; }
    toast("This uploaded game is missing from storage — try re-uploading it", "error");
    setCardStatus(key, "failed");
    return;
  }

  const cached = await dbGet(key);
  if (cached) {
    const base = resolveSource(filename);
    openGame(cached, base);
    return;
  }
  setCardStatus(key, "loading");
  try {
    const { html, base } = await fetchGame(packId, filename);
    await dbPut(key, html);
    setCardStatus(key, "cached");
    openGame(html, base);
  } catch {
    setCardStatus(key, "failed");
    toast("Failed to load — check network connection", "error");
    scheduleAutoRetry();
  }
}

function openGame(html, base) {
  const w = window.open("about:blank");
  w.document.open();
  if (base) w.document.write(`<base href="${base}">`);
  w.document.write(html);
  w.document.close();
}

/* ── Fetch (network packs only) ─────────────────────── */
async function fetchGame(packId, filename) {
  const base = resolveSource(filename);
  const r    = await fetch(base + filename);
  if (!r.ok) throw new Error("HTTP " + r.status);
  const html = await r.text();
  return { html, base };
}

/* ── Load Queue ─────────────────────────────────────── */
function enqueue(packId, filename, front = false) {
  if (packId === "external") return; // external games are already local, never queued
  const key = idbKey(packId, filename);
  const s   = statusMap.get(key);
  if (s === "cached" || s === "loading") return;
  if (loadQueue.some(q => q.packId === packId && q.filename === filename)) return;
  const entry = { packId, filename };
  if (front) loadQueue.unshift(entry); else loadQueue.push(entry);
}

function processQueue() {
  while (activeLoads.size < MAX_PAR && loadQueue.length > 0) {
    const item = loadQueue.shift();
    const key  = idbKey(item.packId, item.filename);
    if (statusMap.get(key) === "cached") { processQueue(); return; }

    activeLoads.add(key);
    setCardStatus(key, "loading");

    fetchGame(item.packId, item.filename)
      .then(({ html }) => dbPut(key, html).then(() => {
        setCardStatus(key, "cached");
        activeLoads.delete(key);
        tickLoadAll();
        processQueue();
      }))
      .catch(() => {
        setCardStatus(key, "failed");
        activeLoads.delete(key);
        scheduleAutoRetry();
        tickLoadAll();
        processQueue();
      });
  }
}

/* ── Load All ───────────────────────────────────────── */
async function startLoadAll() {
  if (loadingAll) return;

  if (activePack === "external") {
    toast("External games are already stored locally — nothing to load", "info");
    return;
  }

  const uncached = getActiveGames().filter(([pid, fn]) =>
    pid !== "external" && statusMap.get(idbKey(pid, fn)) !== "cached"
  );
  if (uncached.length === 0) { toast("✔ All games already cached", "success"); return; }

  loadingAll     = true;
  loadAllTarget  = uncached.length;
  loadAllSettled = 0;

  $loadAllBtn.disabled    = true;
  $loadAllBtn.textContent = "⏳ Loading…";
  setProgress(1);

  for (const [pid, fn] of uncached) enqueue(pid, fn);
  processQueue();
}

function tickLoadAll() {
  if (!loadingAll) return;
  loadAllSettled++;
  setProgress((loadAllSettled / loadAllTarget) * 100);
  if (loadAllSettled >= loadAllTarget) finishLoadAll();
}

function finishLoadAll() {
  loadingAll = false;
  $loadAllBtn.disabled    = false;
  $loadAllBtn.textContent = "⬇ Load All";
  setProgress(100);
  showBanner("✔ All Games Loaded — Offline Ready!", 4500);
  refreshStatus();
}

/* ── Auto Retry ─────────────────────────────────────── */
function scheduleAutoRetry() {
  clearTimeout(retryTimer);
  retryTimer = setTimeout(retryFailed, 30_000);
}

function retryFailed() {
  let count = 0;
  for (const [key, s] of statusMap.entries()) {
    if (s !== "failed") continue;
    const [packId, filename] = splitKey(key);
    if (packId === "external") continue; // nothing to retry — no network source
    statusMap.set(key, "unknown");
    enqueue(packId, filename, true);
    count++;
  }
  if (count > 0) {
    processQueue();
    toast(`↺ Retrying ${count} failed game${count > 1 ? "s" : ""}…`, "info");
  } else {
    toast("Nothing to retry", "info");
  }
}

/* ── Clear Cache ────────────────────────────────────── */
async function clearCache() {
  const hasExternal = PACKS.external.games.length > 0;
  if (hasExternal) {
    const mode = await askConfirm(
      "Clear cache",
      "This will also permanently delete your uploaded External games, since they can't be re-downloaded. Keep external uploads, or clear everything?",
      { confirmLabel: "Clear everything", skipLabel: "Keep external uploads" }
    );
    if (mode === "skip") {
      // Clear only non-external entries
      const keys = await dbGetAllKeys();
      for (const k of keys) {
        const [pid] = splitKey(k);
        if (pid !== "external") await dbDelete(k);
      }
      for (const [pid, pack] of Object.entries(PACKS)) {
        if (pid === "favorites" || pid === "external") continue;
        for (const fn of pack.games) statusMap.set(idbKey(pid, fn), "unknown");
      }
      renderGrid();
      refreshStatus();
      toast("Cache cleared (external uploads kept)", "info");
      return;
    }
  }

  await dbClearAll();
  statusMap.clear();
  PACKS.external.games = [];
  saveExternalManifest();
  for (const [pid, pack] of Object.entries(PACKS)) {
    if (pid === "favorites") continue;
    for (const fn of pack.games) statusMap.set(idbKey(pid, fn), "unknown");
  }
  renderPackTabs();
  renderGrid();
  refreshStatus();
  toast("Cache cleared", "info");
}

/* ── ⑥ Tab-focus rescan ──────────────────────────────── */
document.addEventListener("visibilitychange", () => {
  if (document.visibilityState === "visible") {
    scanCache().then(() => { renderGrid(); refreshStatus(); });
  }
});

/* ── Init ───────────────────────────────────────────── */
async function init() {
  await initDB();
  for (const [pid, pack] of Object.entries(PACKS)) {
    if (pid === "favorites") continue;
    for (const fn of pack.games) statusMap.set(idbKey(pid, fn), "unknown");
  }
  await scanCache();
  renderPackTabs();
  renderGrid();
  refreshStatus();
}

init();
</script>
