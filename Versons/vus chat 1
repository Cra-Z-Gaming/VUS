  const remaining = MAX_CHARS - $msgInput.value.length;
  $charCounter.textContent = remaining;
  $charCounter.classList.toggle("warn", remaining <= 50 && remaining > 10);
  $charCounter.classList.toggle("limit", remaining <= 10);
