/* ── Join screen rendering ──────────────────────────────────────────
 * The join card has three possible views:
 *  1. renderJoinReturning() — shown when a name is saved from a previous
 *     visit: "Continue as X?" with Yes / "No, use a different name".
 *  2. renderJoinNameEntry() — manual name entry, plus a "Join as Guest"
 *     shortcut for first-time visitors. Also reused for rename.
 * attemptJoin() does the actual validation + Firebase claim + transition
 * into the chat screen, shared by both entry paths.
 */

function randomGuestName() {
  const n = Math.floor(Math.random() * 999) + 1; // 1–999
  return "Guest " + n;
}

async function attemptJoin(rawName, isRename, errEl, submitBtn) {
  // Collapse runs of consecutive spaces into a single space so
  // "John  Doe" and "John Doe" can't both exist as distinct names
  // while looking identical in the UI.
  const name = rawName.trim().replace(/ {2,}/g, " ");
  if (!name) {
    errEl.textContent = "Enter a name to continue.";
    return;
  }
  if (name.length > 24) {
    errEl.textContent = "Name is too long (max 24 characters).";
    return;
  }

  // If unchanged during a rename, no need to re-check/re-claim anything.
  if (isRename && name === myName) {
    $chatScreen.style.display = "flex";
    $joinScreen.style.display = "none";
    return;
  }

  if (submitBtn) submitBtn.disabled = true;
  errEl.textContent = "";
  try {
    const taken = await ChatBackend.isNameTaken(name);
    if (taken) {
      errEl.textContent = "That name is already used.";
      if (submitBtn) submitBtn.disabled = false;
      return;
    }
  } catch (e) {
    errEl.textContent = "Couldn't check name availability — try again.";
    if (submitBtn) submitBtn.disabled = false;
    return;
  }
  if (submitBtn) submitBtn.disabled = false;

  // If renaming mid-session, make sure the old name's typing entry (if any)
  // is cleared before we start writing under the new name.
  if (isRename && isCurrentlyTyping) {
    ChatBackend.clearTyping();
    isCurrentlyTyping = false;
  }
  // Old typing ref is tied to the old name — reset so a new one gets
  // created under the new name next time the user types.
  ChatBackend._myTypingRef = null;

  myName = name;
  localStorage.setItem(NAME_STORAGE_KEY, name);
  ChatBackend.claimPresence(myName);
  $youAre.textContent = "You: " + name;
  $changeNameBtn.style.display = "inline-block";
  $joinScreen.style.display = "none";
  $chatScreen.style.display = "flex";
  $msgInput.focus();
  scrollToBottom();
}

