/* ── Mod Menu (hidden behind the status dot) ──────────────────────────
 * IMPORTANT: this is a client-side-only gate. The "password" check runs
 * in the browser, so it is visible to anyone who opens dev tools or reads
 * this file's source — it is a deterrent against casual misuse, not real
 * security. Do not treat this as an access-control mechanism.
 *
 * Images are entirely SESSION-LOCAL and PER-BROWSER-TAB:
 *  - There is no room-wide "images enabled" setting anymore, and nothing
 *    is written to Firebase about this. It lives only in the
 *    imagesEnabledForMe variable below.
 *  - It always starts false on every fresh page load, for everyone,
 *    including whoever knows the code — the code has to be re-entered
 *    each session, and the toggle has to be turned on again each time.
 *  - The upload button ($uploadImageBtn) is display:none from the moment
 *    the page loads and stays that way unless BOTH modMenuUnlocked is
 *    true AND imagesEnabledForMe is true. No other user, and no future
 *    visit by the same person, ever sees it without redoing both steps.
 */
const MOD_MENU_CODE = "2212";
let modMenuUnlocked = false;
let imagesEnabledForMe = false; // session-local only, never persisted, never shared

function updateUploadButtonVisibility() {
  const visible = modMenuUnlocked && imagesEnabledForMe;
  $uploadImageBtn.style.display = visible ? "inline-block" : "none";
}

function renderModMenuLogin() {
