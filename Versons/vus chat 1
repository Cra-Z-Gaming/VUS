<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VUS Chat</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body {
    background: #0f172a;
    color: #f1f5f9;
    font-family: Arial, sans-serif;
    display: flex;
    flex-direction: column;
  }

  /* ── Header ── */
  .chat-header {
    padding: 18px 21px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 24px;
    font-weight: 500;
    border-bottom: 1.5px solid #1f2937;
    flex-shrink: 0;
  }
  .chat-header .room-name { color: #94a3b8; font-size: 18px; font-weight: 400; }
  .chat-online-dot {
    display: inline-block;
    width: 10.5px;
    height: 10.5px;
    border-radius: 50%;
    background: #22c55e;
    margin-right: 7.5px;
  }
  .chat-online-dot.offline { background: #ef4444; }

  /* ── Join screen (asks for a name before entering) ── */
  #joinScreen {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  #joinCard {
    width: 100%;
    max-width: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  #joinScreen h2 { font-size: 19px; font-weight: 500; margin-bottom: 2px; text-align: center; }
  #joinScreen p { font-size: 13.5px; color: #94a3b8; text-align: center; margin-bottom: 4px; line-height: 1.4; }
  #nameInput {
    width: 100%;
    padding: 10px 13px;
    background: #1e293b;
    border: 1.5px solid #334155;
    border-radius: 9px;
    color: #f1f5f9;
    font-size: 15px;
    outline: none;
  }
  #nameInput:focus { border-color: #22c55e; }
  #joinBtn {
    width: 100%;
    padding: 10px 13px;
    background: #22c55e;
    border: none;
    border-radius: 9px;
    color: #000;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
  }
  #joinBtn:hover { background: #4ade80; }
  #joinBtn:disabled { opacity: .5; cursor: not-allowed; }
  #joinError { font-size: 13px; color: #ef4444; min-height: 18px; }
  .join-secondary-btn {
    width: 100%;
    padding: 9px 13px;
    background: transparent;
    border: 1.5px solid #334155;
    border-radius: 9px;
    color: #94a3b8;
    font-size: 14px;
    cursor: pointer;
  }
  .join-secondary-btn:hover { color: #f1f5f9; border-color: #475569; }
  .join-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    color: #475569;
    font-size: 12px;
  }
  .join-divider::before, .join-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: #334155;
  }

  /* ── Chat screen ── */
  #chatScreen { display: none; flex: 1; flex-direction: column; min-height: 0; }
  #messages {
    flex: 1;
    overflow-y: auto;
    padding: 18px 21px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  #messages::-webkit-scrollbar { width: 7.5px; }
  #messages::-webkit-scrollbar-thumb { background: #334155; border-radius: 4.5px; }

  .msg { max-width: 82%; display: flex; flex-direction: column; gap: 3px; }
  .msg.mine { align-self: flex-end; align-items: flex-end; }
  .msg-meta { font-size: 16.5px; color: #64748b; padding: 0 6px; }
  .msg-bubble {
    background: #1e293b;
    border: 1.5px solid #334155;
    border-radius: 15px;
    padding: 12px 16.5px;
    font-size: 20.2px;
    line-height: 1.4;
    word-break: break-word;
    white-space: pre-wrap;
  }
  .msg.mine .msg-bubble { background: #14532d; border-color: #166534; }
  .msg.system { align-self: center; max-width: 100%; }
  .msg.system .msg-bubble {
    background: transparent;
    border: none;
    color: #64748b;
    font-size: 17.2px;
    font-style: italic;
    padding: 3px;
  }

  #emptyState {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #475569;
    font-size: 19.5px;
    text-align: center;
    padding: 30px;
  }

  /* ── Toolbar (auto-scroll / clear chat) ── */
  #toolbar {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 9px;
    padding: 9px 21px;
    border-top: 1.5px solid #1f2937;
    flex-shrink: 0;
  }
  .toolbar-btn {
    background: transparent;
    border: 1.5px solid #334155;
    color: #94a3b8;
    font-size: 15.8px;
    padding: 6px 12px;
    border-radius: 9px;
    cursor: pointer;
  }
  .toolbar-btn:hover { color: #f1f5f9; border-color: #475569; }
  .toolbar-btn.active {
    background: rgba(34,197,94,.12);
    border-color: #22c55e;
    color: #4ade80;
  }
  #jumpToBottomBtn {
    display: none;
    background: #1e293b;
    border: 1.5px solid #334155;
    color: #f1f5f9;
    font-size: 15.8px;
    padding: 6px 14px;
    border-radius: 20px;
    cursor: pointer;
    align-self: center;
    margin: 0 auto 6px auto;
  }
  #jumpToBottomBtn:hover { border-color: #475569; }

  /* ── Composer ── */
  #composer {
    display: flex;
    gap: 12px;
    padding: 15px 18px;
    border-top: 1.5px solid #1f2937;
    flex-shrink: 0;
    align-items: flex-end;
  }
  #composerInputWrap {
    flex: 1;
    display: flex;
  }
  #msgInput {
    padding: 13.5px 18px;
    background: #1e293b;
    border: 1.5px solid #334155;
    border-radius: 12px;
    color: #f1f5f9;
    font-size: 20.2px;
    outline: none;
    resize: none;
    max-height: 135px;
    font-family: inherit;
    width: 100%;
  }
  #msgInput:focus { border-color: #22c55e; }
  #charCounter {
    font-size: 14.5px;
    color: #64748b;
  }
  #charCounter.warn { color: #f59e0b; }
  #charCounter.limit { color: #ef4444; }
  #sendBtn {
    padding: 0 24px;
    height: 51px;
    background: #22c55e;
    border: none;
    border-radius: 12px;
    color: #000;
    font-weight: 600;
    font-size: 19.5px;
    cursor: pointer;
    flex-shrink: 0;
  }
  #sendBtn:hover { background: #4ade80; }
  #sendBtn:disabled { opacity: .5; cursor: not-allowed; }

  #connError {
    display: none;
    padding: 12px 21px;
    background: rgba(239,68,68,.1);
    border-top: 1.5px solid rgba(239,68,68,.3);
    color: #ef4444;
    font-size: 17.2px;
    flex-shrink: 0;
  }
  #changeNameBtn:hover { color: #f1f5f9 !important; border-color: #475569 !important; }
  #sendBtn.cooldown { background: #334155; color: #64748b; cursor: not-allowed; }
</style>
</head>
<body>

<div class="chat-header" style="position:relative;display:grid;grid-template-columns:1fr auto 1fr;align-items:center">
  <div style="position:relative;justify-self:start;display:flex;align-items:center;gap:6px">
    <span id="onlineDot" class="chat-online-dot offline" style="cursor:pointer;display:inline-block;padding:10px;margin:-10px;vertical-align:middle"></span>
    <span id="onlineCount" style="font-size:14.5px;color:#64748b;margin-left:8px"></span>
    <div id="globalClearPanel" style="display:none;position:absolute;top:28px;left:-10px;background:#1e293b;border:1.5px solid #334155;border-radius:10px;padding:12px;z-index:10;width:240px;font-size:15px;font-weight:400"></div>
  </div>
  <div style="justify-self:center">VUS Chat</div>
  <div style="font-size:16.5px;color:#475569;display:flex;align-items:center;gap:12px;justify-self:end">
    <span id="youAre"></span>
    <button id="changeNameBtn" style="display:none;background:transparent;border:1.5px solid #334155;color:#64748b;font-size:15.8px;padding:4.5px 10.5px;border-radius:9px;cursor:pointer">Change name</button>
  </div>
</div>

<div id="connError"></div>

<!-- Join screen: ask for a display name before entering the room.
     Content is built dynamically in JS depending on whether a previous
     name is saved (renderJoinReturning / renderJoinNameEntry). -->
<div id="joinScreen">
  <div id="joinCard"></div>
</div>

<!-- Chat screen: shown after joining -->
<div id="chatScreen">
  <div id="messages"></div>
  <div id="emptyState" style="display:none">No messages yet — say hi!</div>
  <button id="jumpToBottomBtn">↓ Jump to latest</button>
  <div id="typingBar" style="display:none;padding:6px 21px;font-size:17.2px;color:#64748b;font-style:italic;flex-shrink:0"></div>
  <div id="toolbar">
    <button id="uploadImageBtn" class="toolbar-btn" style="display:none">📎 Image</button>
    <input id="imageFileInput" type="file" accept="image/*" style="display:none">
    <span id="charCounter">500</span>
    <div style="flex:1"></div>
    <button id="autoScrollBtn" class="toolbar-btn active">Auto Scroll: On</button>
    <button id="clearChatBtn" class="toolbar-btn">Clear Chat</button>
  </div>
  <div id="composer">
    <div id="composerInputWrap">
      <textarea id="msgInput" rows="1" placeholder="Type a message…" maxlength="500"></textarea>
    </div>
    <button id="sendBtn">Send</button>
  </div>
</div>

<!--
  ═══════════════════════════════════════════════════════════
  FIREBASE SETUP REQUIRED — read this before this chat will work
  ═══════════════════════════════════════════════════════════
  1. Go to https://console.firebase.google.com and create a free project.
  2. In the project, go to "Build" → "Realtime Database" → "Create Database".
     Start in TEST MODE for now (anyone can read/write — fine for a small
     public chat room, but you can lock it down later with Firebase rules).
  3. Go to Project Settings (gear icon) → General → "Your apps" → click the
     "</>" web icon to register a web app. It'll give you a config object
     that looks like the FIREBASE_CONFIG placeholder below.
  4. Copy that object and paste it in place of FIREBASE_CONFIG below.
  5. That's it — no server to run, this connects directly from the browser.

  Room name: change ROOM_ID below if you want multiple separate chat rooms
  (e.g. one for VUS Hub, one for VUSL) using the same Firebase project.
  ═══════════════════════════════════════════════════════════
-->
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.2/firebase-database-compat.js"></script>
<script>
/* ── Fill this in with your real Firebase project config ── */
const FIREBASE_CONFIG = {
  apiKey: "AIzaSyDxMfGQ_xk-au8YgOvaFO2R9LxAe-pa9Rg",
  authDomain: "vus-chat.firebaseapp.com",
  databaseURL: "https://vus-chat-default-rtdb.firebaseio.com",
  projectId: "vus-chat",
  storageBucket: "vus-chat.firebasestorage.app",
  messagingSenderId: "134456894391",
  appId: "1:134456894391:web:bdf28487bf2b2eae593e32"
};

/* Change this to run multiple separate chat rooms off one Firebase project */
const ROOM_ID = "vus-hub-main";

/* Only keep the most recent N messages loaded/rendered, to keep things fast
   even after thousands of messages accumulate over time. */
const MAX_MESSAGES = 200;

const MAX_CHARS = 500;

/* ══════════════════════════════════════════════════════════
   Backend abstraction layer.
   Every actual Firebase call is isolated in this one object so
   that swapping to a different backend later (Supabase, a custom
   server, etc.) only means rewriting the functions below —
   nothing in the UI code below needs to change.
   ══════════════════════════════════════════════════════════ */
const ChatBackend = {
  _db: null,
  _ref: null,
  _typingRef: null,
  _myTypingRef: null,
  _connectedRef: null,
  _presenceRef: null,
  _myPresenceRef: null,
  _myLeaveEventRef: null,
  _nameColorsRef: null,

  init() {
    firebase.initializeApp(FIREBASE_CONFIG);
    this._db = firebase.database();
    this._ref = this._db.ref("rooms/" + ROOM_ID + "/messages");
    this._typingRef = this._db.ref("rooms/" + ROOM_ID + "/typing");
    this._presenceRef = this._db.ref("rooms/" + ROOM_ID + "/presence");
    this._nameColorsRef = this._db.ref("rooms/" + ROOM_ID + "/nameColors");
    this._connectedRef = this._db.ref(".info/connected");
  },

  // Calls onStatus(true/false) whenever the connection state changes
  watchConnection(onStatus) {
    this._connectedRef.on("value", snap => onStatus(snap.val() === true));
  },

  // Calls onMessage(msgObject) for every existing + new message
  watchMessages(onMessage) {
    this._ref.limitToLast(MAX_MESSAGES).on("child_added", snap => {
      onMessage({ id: snap.key, ...snap.val() });
    });
  },

  // Sends an already-compressed base64 data URL as a message. No Firebase
  // Storage involved — this stays on the free Spark plan, at the cost of
  // bulkier message payloads than a real file host would give you. The
  // image is compressed/resized client-side (see compressImageFile)
  // before this is ever called, to keep that payload size reasonable.
  async sendImage(name, dataUrl) {
    const color = await this.getNameColor(name);
    return this._ref.push({
      name: name,
      imageData: dataUrl,
      ts: firebase.database.ServerValue.TIMESTAMP,
      ...(color ? { bubble: color.bubble, textColor: color.text } : {})
    });
  },

  // Sends one message. If this name has a locked-in color, it's baked
  // into the message itself at send time — so changing your color later
  // only affects messages sent after the change, never past ones.
  async send(name, text) {
    const color = await this.getNameColor(name);
    return this._ref.push({
      name: name,
      text: text,
      ts: firebase.database.ServerValue.TIMESTAMP,
      ...(color ? { bubble: color.bubble, textColor: color.text } : {})
    });
  },

  // ── Per-name bubble color (write-once) ──
  // Colors live at nameColors/<sanitizedName> and are visible to everyone,
  // since messages carry them. A name can only claim a color once —
  // claimColor() checks for an existing record first and rejects if one
  // is already there, so this is enforced globally (any tab, any device),
  // not just locally.
  async getNameColor(name) {
    const snap = await this._nameColorsRef.child(this._safeKey(name)).get();
    return snap.exists() ? snap.val() : null;
  },

  async claimColor(name, bubble, text) {
    const key = this._safeKey(name);
    const ref = this._nameColorsRef.child(key);
    const existing = await ref.get();
    if (existing.exists()) {
      return { ok: false, reason: "already-set" };
    }
    await ref.set({ bubble, text });
    return { ok: true };
  },

  // ── Presence / name reservation ──
  // Each connected client claims presence/<sanitizedName> for as long as
  // their tab is open, with onDisconnect() cleanup so a closed/crashed tab
  // frees the name automatically. isNameTaken() reads this list once
  // (a plain .get(), not a live subscription) right before joining/renaming
  // so we're checking against the current state at the moment of the attempt.
  async isNameTaken(name) {
    const snap = await this._presenceRef.get();
    const val = snap.val() || {};
    const key = this._safeKey(name);
    return Object.prototype.hasOwnProperty.call(val, key);
  },

  // Posts join/leave messages to the room feed itself (not just updating
  // presence data), so they show up inline in the chat like any other
  // message — just rendered without a bubble via msg.system.
  claimPresence(name) {
    // Release any previous claim first (e.g. on rename) — this does NOT
    // post a "left" message, since renaming isn't actually leaving.
    this.releasePresence();
    this._myPresenceRef = this._presenceRef.child(this._safeKey(name));

    // onDisconnect() can only set/remove a VALUE at a ref — it can't push
    // a new message directly. So on disconnect we write a "leave event"
    // marker here; watchLeaveEvents() (wired once, globally) listens for
    // these and turns each one into an actual system message in the feed.
    // This is the only reliable way to detect a real disconnect (closed
    // tab, crash, lost connection) — client-side-only code can't run once
    // the tab is actually gone.
    const leaveEventRef = this._db.ref("rooms/" + ROOM_ID + "/leaveEvents").push();
    leaveEventRef.onDisconnect().set({ name, ts: firebase.database.ServerValue.TIMESTAMP });
    this._myLeaveEventRef = leaveEventRef;

    this._myPresenceRef.onDisconnect().remove();
    this._myPresenceRef.set(true);

    this._ref.push({
      system: true,
      text: name + " joined",
      ts: firebase.database.ServerValue.TIMESTAMP
    });
  },

  releasePresence() {
    if (this._myPresenceRef) {
      this._myPresenceRef.remove();
      this._myPresenceRef = null;
    }
    // Cancel the pending onDisconnect leave-event write, since we're
    // leaving on purpose right now (e.g. renaming) rather than actually
    // disconnecting — we don't want a stray "X left" firing later.
    if (this._myLeaveEventRef) {
      this._myLeaveEventRef.onDisconnect().cancel();
      this._myLeaveEventRef = null;
    }
  },

  // Listens for leave-event markers written by onDisconnect() (see
  // claimPresence above) and turns each one into a normal system message
  // in the chat feed, then clears the marker so it's a one-shot.
  watchLeaveEvents() {
    const leaveEventsRef = this._db.ref("rooms/" + ROOM_ID + "/leaveEvents");
    leaveEventsRef.on("child_added", snap => {
      const val = snap.val();
      if (!val) return;
      this._ref.push({
        system: true,
        text: val.name + " left",
        ts: firebase.database.ServerValue.TIMESTAMP
      });
      snap.ref.remove();
    });
  },

  // Calls onCount(number) any time the set of currently-connected names
  // changes. Reuses the same presence/ node that isNameTaken() checks, so
  // this count reflects exactly who's actively holding a name claim right
  // now (including guests) — not total visits or messages sent.
  watchPresenceCount(onCount) {
    this._presenceRef.on("value", snap => {
      const val = snap.val() || {};
      onCount(Object.keys(val).length);
    });
  },

  // ── Typing presence ──
  // Each connected client writes to typing/<sanitizedName> while actively
  // typing, with a server timestamp so everyone can sort by "who started
  // typing first" (insertion order) rather than alphabetically. Removing
  // the node (on send/clear/disconnect) is what makes someone drop out of
  // the indicator immediately.

  setTyping(name) {
    if (!this._myTypingRef) {
      this._myTypingRef = this._typingRef.child(this._safeKey(name));
      // Auto-clear this client's typing entry if they lose connection
      // (closed tab, network drop, etc.) instead of leaving a stale
      // "X is typing" forever.
      this._myTypingRef.onDisconnect().remove();
    }
    this._myTypingRef.set({ name: name, ts: firebase.database.ServerValue.TIMESTAMP });
  },

  clearTyping() {
    if (this._myTypingRef) this._myTypingRef.remove();
  },

  // Calls onChange(sortedArrayOfNames) any time the typing set changes.
  // excludeNameFn is a function (not a plain string) so this always reads
  // the *current* value of myName — important since the name can change
  // mid-session via "Change name" and this listener is only attached once.
  watchTyping(onChange, excludeNameFn) {
    this._typingRef.on("value", snap => {
      const val = snap.val() || {};
      const currentExclude = excludeNameFn();
      const entries = Object.values(val)
        .filter(e => e && e.name !== currentExclude)
        .sort((a, b) => (a.ts || 0) - (b.ts || 0))
        .map(e => e.name);
      onChange(entries);
    });
  },

  _safeKey(name) {
    // Firebase keys can't contain ".", "#", "$", "[", "]", or "/"
    return name.replace(/[.#$\[\]/]/g, "_");
  }
};

/* ── DOM refs ── */
const $joinScreen  = document.getElementById("joinScreen");
const $joinCard    = document.getElementById("joinCard");
const $chatScreen  = document.getElementById("chatScreen");
const $messages    = document.getElementById("messages");
const $emptyState  = document.getElementById("emptyState");
const $msgInput    = document.getElementById("msgInput");
const $sendBtn     = document.getElementById("sendBtn");
const $onlineDot   = document.getElementById("onlineDot");
const $onlineCount = document.getElementById("onlineCount");
const $connError   = document.getElementById("connError");
const $youAre      = document.getElementById("youAre");
const $changeNameBtn = document.getElementById("changeNameBtn");
const $typingBar     = document.getElementById("typingBar");
const $autoScrollBtn = document.getElementById("autoScrollBtn");
const $clearChatBtn  = document.getElementById("clearChatBtn");
const $uploadImageBtn = document.getElementById("uploadImageBtn");
const $imageFileInput = document.getElementById("imageFileInput");
const $jumpToBottomBtn = document.getElementById("jumpToBottomBtn");
const $charCounter    = document.getElementById("charCounter");
const $globalClearPanel = document.getElementById("globalClearPanel");

let myName = "";
let messageCount = 0;
let autoScroll = true;

const NAME_STORAGE_KEY = "vusChatName";
const SEND_COOLDOWN_MS = 3000;
let lastSentAt = 0;
let cooldownTimer = null;

let isCurrentlyTyping = false;
let typingStopTimer = null;

function esc(s = "") {
  return String(s)
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function formatTime(ts) {
  if (!ts) return "";
  const d = new Date(ts);
  return d.toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" });
}

function isNearBottom() {
  return $messages.scrollHeight - $messages.scrollTop - $messages.clientHeight < 120;
}

function scrollToBottom() {
  requestAnimationFrame(() => { $messages.scrollTop = $messages.scrollHeight; });
  $jumpToBottomBtn.style.display = "none";
}

function renderMessage(msg) {
  $emptyState.style.display = "none";

  if (msg.system) {
    const sysEl = document.createElement("div");
    sysEl.className = "msg system";
    const sysBubble = document.createElement("div");
    sysBubble.className = "msg-bubble";
    sysBubble.textContent = msg.text;
    sysEl.appendChild(sysBubble);
    $messages.appendChild(sysEl);
    messageCount++;
    if (autoScroll) scrollToBottom();
    return;
  }

  const mine = msg.name === myName;
  const el = document.createElement("div");
  el.className = "msg" + (mine ? " mine" : "");

  const meta = document.createElement("div");
  meta.className = "msg-meta";
  meta.textContent = (mine ? "You" : esc(msg.name)) + (msg.ts ? " · " + formatTime(msg.ts) : "");

  const bubble = document.createElement("div");
  bubble.className = "msg-bubble";

  if (msg.imageData) {
    // Image messages carry a base64 data URL directly (no Firebase Storage
    // — that needs the paid Blaze plan). Capped width/height keeps a large
    // photo from blowing out the layout; clicking opens it full-size in a
    // new tab.
    const link = document.createElement("a");
    link.href = msg.imageData;
    link.target = "_blank";
    link.rel = "noopener noreferrer";
    const img = document.createElement("img");
    img.src = msg.imageData;
    img.alt = "Shared image";
    img.style.cssText = "max-width:100%;max-height:280px;border-radius:10px;display:block";
    link.appendChild(img);
    bubble.appendChild(link);
    bubble.style.padding = "6px";
  } else {
    bubble.textContent = msg.text; // textContent, not innerHTML — avoids any HTML injection
  }

  // Color is baked into the message at send time (see ChatBackend.send),
  // so it's visible to everyone and reflects whatever color was locked in
  // at the moment this specific message was sent — changing your color
  // later never repaints older messages. Only applied to text bubbles;
  // image bubbles keep the default background so photos aren't tinted.
  if (!msg.imageData) {
    if (msg.bubble) bubble.style.background = msg.bubble;
    if (msg.textColor) bubble.style.color = msg.textColor;
  }

  el.appendChild(meta);
  el.appendChild(bubble);
  $messages.appendChild(el);

  messageCount++;
  // Trim old messages from the DOM once we exceed the cap, so long-running
  // sessions don't slowly bloat memory/layout cost.
  while (messageCount > MAX_MESSAGES) {
    const first = $messages.querySelector(".msg");
    if (!first) break;
    first.remove();
    messageCount--;
  }

  // Auto-scroll to the bottom only if the "Auto Scroll" toggle is on and
  // the user was already near the bottom (or it's their own message) —
  // so someone scrolling up to read history doesn't get yanked down.
  if (autoScroll && (isNearBottom() || mine)) {
    scrollToBottom();
  } else if (!isNearBottom()) {
    $jumpToBottomBtn.style.display = "block";
  }
}

function setConnectionStatus(isOnline) {
