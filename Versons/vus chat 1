function updateSendButtonState() {
  const elapsed = Date.now() - lastSentAt;
  const remaining = SEND_COOLDOWN_MS - elapsed;
  if (remaining > 0) {
    $sendBtn.disabled = true;
    $sendBtn.classList.add("cooldown");
    $sendBtn.textContent = Math.ceil(remaining / 1000) + "s";
    clearTimeout(cooldownTimer);
    cooldownTimer = setTimeout(updateSendButtonState, 250);
  } else {
    $sendBtn.disabled = false;
    $sendBtn.classList.remove("cooldown");
    $sendBtn.textContent = "Send";
  }
}

function sendMessage() {
  if (Date.now() - lastSentAt < SEND_COOLDOWN_MS) return; // still cooling down
  const text = $msgInput.value.trim();
  if (!text) return;

  lastSentAt = Date.now();
  updateSendButtonState();
  stopTyping(); // sending counts as "done typing" — clears you from the indicator

  ChatBackend.send(myName, text)
    .then(() => {
      $msgInput.value = "";
      autosizeInput();
      updateCharCounter();
      // Sending your own message should always bring you to the bottom.
      autoScroll = true;
      setAutoScrollUI();
    })
    .catch(() => {
      $connError.textContent = "Message failed to send — check your connection.";
      $connError.style.display = "block";
    })
    .finally(() => { $msgInput.focus(); });
}

function autosizeInput() {
  $msgInput.style.height = "auto";
  $msgInput.style.height = Math.min($msgInput.scrollHeight, 135) + "px";
}

const MAX_IMAGE_SOURCE_BYTES = 15 * 1024 * 1024; // reject absurdly large source files outright
const IMAGE_MAX_DIMENSION = 1000; // px, longest side after resize
const IMAGE_JPEG_QUALITY = 0.7;

// Resizes + re-encodes an image file entirely in the browser (canvas ->
// JPEG data URL), since we're storing images directly in Realtime
// Database rather than a file host. This keeps each message's payload
// from being an untouched multi-MB photo — a typical phone photo comes
// down to a few hundred KB after this.
function compressImageFile(file) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const reader = new FileReader();
    reader.onerror = () => reject(new Error("Couldn't read file"));
    reader.onload = () => {
      img.onerror = () => reject(new Error("Couldn't decode image"));
      img.onload = () => {
        let { width, height } = img;
        if (width > IMAGE_MAX_DIMENSION || height > IMAGE_MAX_DIMENSION) {
          const scale = IMAGE_MAX_DIMENSION / Math.max(width, height);
          width = Math.round(width * scale);
          height = Math.round(height * scale);
        }
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext("2d");
        ctx.drawImage(img, 0, 0, width, height);
        resolve(canvas.toDataURL("image/jpeg", IMAGE_JPEG_QUALITY));
      };
      img.src = reader.result;
    };
    reader.readAsDataURL(file);
  });
}

function sendImageFile(file) {
  // Hard gate: images can only ever be sent by this browser tab if the
  // mod code has been entered successfully this session. This function
  // is also only reachable via $uploadImageBtn, which stays hidden
  // (display:none) until modMenuUnlocked flips true — but we double-check
  // here too, since it's cheap and it's the actual send path.
  if (!modMenuUnlocked) return;

  if (!file) return;
  if (!file.type.startsWith("image/")) {
    $connError.textContent = "That file isn't an image.";
    $connError.style.display = "block";
    return;
  }
  if (file.size > MAX_IMAGE_SOURCE_BYTES) {
    $connError.textContent = "Image is too large.";
    $connError.style.display = "block";
    return;
  }
  if (Date.now() - lastSentAt < SEND_COOLDOWN_MS) return; // same cooldown as text messages

  lastSentAt = Date.now();
  updateSendButtonState();
  $uploadImageBtn.disabled = true;
  $uploadImageBtn.textContent = "Uploading…";

  compressImageFile(file)
    .then(dataUrl => ChatBackend.sendImage(myName, dataUrl))
    .then(() => {
      autoScroll = true;
      setAutoScrollUI();
    })
    .catch(() => {
      $connError.textContent = "Image failed to send — check your connection.";
      $connError.style.display = "block";
    })
    .finally(() => {
      $uploadImageBtn.disabled = false;
      $uploadImageBtn.textContent = "📎 Image";
      $imageFileInput.value = "";
    });
}

$uploadImageBtn.addEventListener("click", () => {
  if (!modMenuUnlocked) return; // extra guard, button shouldn't even be visible
  $imageFileInput.click();
});
$imageFileInput.addEventListener("change", () => {
  const file = $imageFileInput.files[0];
  sendImageFile(file);
});

