  closeBtn.addEventListener("click", closeClearPanel);
  $globalClearPanel.appendChild(closeBtn);
}

function closeClearPanel() {
  $globalClearPanel.style.display = "none";
  // Keep innerHTML intact once unlocked, so re-opening via "." or the dot
  // goes straight back to the customize menu instead of re-asking for the
  // code. Only the login step gets wiped away, since that shouldn't
  // persist as visible DOM while hidden.
  if (!modMenuUnlocked) $globalClearPanel.innerHTML = "";
}

function openModMenu() {
  $globalClearPanel.style.display = "block";
  if (modMenuUnlocked) {
    renderModMenu();
  } else {
    renderModMenuLogin();
  }
}

$onlineDot.addEventListener("click", (e) => {
  e.stopPropagation();
  const isOpen = $globalClearPanel.style.display === "block";
  if (isOpen) {
    closeClearPanel();
  } else {
    openModMenu();
  }
});

// "." toggles the menu open/closed once unlocked — but only when the
// person isn't actively typing somewhere (message box, name field, or
// the code input itself), so a literal period in a message doesn't
// accidentally trigger it.
document.addEventListener("keydown", (e) => {
  if (e.key !== ".") return;
  if (!modMenuUnlocked) return;
  const active = document.activeElement;
  const isTypingSomewhere = active && (active.tagName === "TEXTAREA" || active.tagName === "INPUT");
  if (isTypingSomewhere) return;
  const isOpen = $globalClearPanel.style.display === "block";
  if (isOpen) {
    closeClearPanel();
  } else {
    openModMenu();
  }
});

// Click-away no longer closes the panel once unlocked — it stays open
// until explicitly closed via the dot, the Close button, or ".". Before
// unlocking, click-away still dismisses the login prompt.
document.addEventListener("click", (e) => {
  if (!modMenuUnlocked && $globalClearPanel.style.display === "block" && !$globalClearPanel.contains(e.target)) {
    closeClearPanel();
  }
});

/* ── Typing indicator ──────────────────────────────────
 * Fires setTyping() while the user has text in the box, and clears it
 * (stopTyping) 2s after they stop pressing keys, or immediately when they
 * send/clear the message. A short debounce avoids writing to Firebase on
 * every keystroke. */
function handleTypingActivity() {
  const hasText = $msgInput.value.trim().length > 0;
  clearTimeout(typingStopTimer);

  if (hasText) {
    if (!isCurrentlyTyping) {
      isCurrentlyTyping = true;
      ChatBackend.setTyping(myName);
    } else {
      // refresh the timestamp/presence periodically so a long pause
      // doesn't get treated as "still typing" forever if we ever add
      // a server-side expiry later
      ChatBackend.setTyping(myName);
    }
    typingStopTimer = setTimeout(stopTyping, 2000);
  } else {
    stopTyping();
  }
}

function stopTyping() {
  clearTimeout(typingStopTimer);
  if (isCurrentlyTyping) {
    isCurrentlyTyping = false;
    ChatBackend.clearTyping();
  }
}

/* Renders "john, bob, garry, +7 more are typing" from a name array that's
 * already sorted oldest-typing-first by ChatBackend.watchTyping. Only the
 * first 3 are named; everyone else folds into the "+N more" count. This
 * naturally satisfies the rotation behavior: when the 1st person sends,
 * they disappear from the array, the old 4th person becomes the new 3rd,
 * and the "+N more" count drops by one — all from re-sorting on the next
 * Firebase update, no special-case code needed. */
function renderTyping(names) {
  if (names.length === 0) {
    $typingBar.style.display = "none";
    return;
  }
  const shown = names.slice(0, 3);
  const extra = names.length - shown.length;
  let text = shown.map(esc).join(", ");
  if (extra > 0) text += `, +${extra} more`;
  text += (names.length === 1 ? " is typing…" : " are typing…");
  $typingBar.textContent = text;
  $typingBar.style.display = "block";
}

/* ── Wire up events ── */
$changeNameBtn.addEventListener("click", openChangeName);

$sendBtn.addEventListener("click", sendMessage);
$msgInput.addEventListener("keydown", e => {
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});
$msgInput.addEventListener("input", () => { autosizeInput(); handleTypingActivity(); updateCharCounter(); });

/* ── Boot ── */
function init() {
  const usingPlaceholderConfig = FIREBASE_CONFIG.apiKey === "PASTE_YOUR_API_KEY_HERE";
  if (usingPlaceholderConfig) {
    $joinCard.innerHTML = `
      <h2>Chat not set up yet</h2>
      <p>
        This chat needs a free Firebase project connected before it'll work.
        Open this file's code and fill in FIREBASE_CONFIG near the bottom —
        instructions are in the comment right above it.
      </p>
    `;
    return;
  }

  try {
    ChatBackend.init();
  } catch (e) {
    $joinCard.innerHTML = `<h2>Couldn't connect</h2><p>${esc(e.message || "Unknown error")}</p>`;
    return;
  }

  // First-time visitors (no saved name) go straight to name entry, with a
  // "Join as Guest" shortcut. Returning visitors get a "continue as X?"
  // prompt instead, so they don't have to retype their name every visit.
  const savedName = localStorage.getItem(NAME_STORAGE_KEY);
  if (savedName) {
    renderJoinReturning(savedName);
  } else {
    renderJoinNameEntry(false);
  }

  ChatBackend.watchConnection(setConnectionStatus);
  ChatBackend.watchPresenceCount(count => {
    $onlineCount.textContent = count + " online";
  });
  ChatBackend.watchMessages(renderMessage);
  ChatBackend.watchLeaveEvents();
  ChatBackend.watchTyping(renderTyping, () => myName);

  // Upload button starts (and stays) hidden until the mod code is entered
  // AND the "Allow images (me)" toggle is switched on inside the menu —
  // both gates are purely local to this browser session, nothing is
  // fetched or watched from Firebase for this anymore.
  updateUploadButtonVisibility();

  $emptyState.style.display = "flex";
  updateCharCounter();

  // Clear this client's typing flag and release their claimed name if they
  // close/refresh the tab while mid-session (in addition to the
  // onDisconnect() server-side cleanup, this catches the common case
  // faster on the client that's actually leaving).
  window.addEventListener("beforeunload", () => {
    stopTyping();
    ChatBackend.releasePresence();
  });
}

init();
</script>
</body>
</html>
