/* ── Typing indicator ── */
function handleTypingActivity() {
  const hasText = $msgInput.value.trim().length > 0;
  clearTimeout(typingStopTimer);

  if (hasText) {
    if (!isCurrentlyTyping) {
      isCurrentlyTyping = true;
      ChatBackend.setTyping(myName);
    } else {
      ChatBackend.setTyping(myName);
    }
    typingStopTimer = setTimeout(stopTyping, 2000);
  } else {
    stopTyping();
  }
}

function stopTyping() {
  clearTimeout(typingStopTimer);
  if (isCurrentlyTyping) {
    isCurrentlyTyping = false;
    ChatBackend.clearTyping();
  }
}

function renderTyping(names) {
  if (names.length === 0) {
    $typingBar.style.display = "none";
    return;
  }
  const shown = names.slice(0, 3);
  const extra = names.length - shown.length;
  let text = shown.map(esc).join(", ");
  if (extra > 0) text += `, +${extra} more`;
  text += (names.length === 1 ? " is typing…" : " are typing…");
  $typingBar.textContent = text;
  $typingBar.style.display = "block";
}

/* ── Wire up events ── */
$changeNameBtn.addEventListener("click", openChangeName);

$sendBtn.addEventListener("click", sendMessage);
$msgInput.addEventListener("keydown", e => {
  if (e.key === "Enter" && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});
$msgInput.addEventListener("input", () => { autosizeInput(); handleTypingActivity(); updateCharCounter(); });

/* ── Boot ── */
function init() {
  const usingPlaceholderConfig = FIREBASE_CONFIG.apiKey === "PASTE_YOUR_API_KEY_HERE";
  if (usingPlaceholderConfig) {
    $joinCard.innerHTML = `
      <h2>Chat not set up yet</h2>
      <p>
        This chat needs a free Firebase project connected before it'll work.
        Open this file's code and fill in FIREBASE_CONFIG near the bottom —
        instructions are in the comment right above it.
      </p>
    `;
    return;
  }

  try {
    ChatBackend.init();
  } catch (e) {
    $joinCard.innerHTML = `<h2>Couldn't connect</h2><p>${esc(e.message || "Unknown error")}</p>`;
    return;
  }

  const savedName = localStorage.getItem(NAME_STORAGE_KEY);
  if (savedName) {
    renderJoinReturning(savedName);
  } else {
    renderJoinNameEntry(false);
  }

  ChatBackend.watchConnection(setConnectionStatus);
  ChatBackend.watchPresenceCount(count => {
    $onlineCount.textContent = count + " online";
  });
  ChatBackend.watchMessages(renderMessage);
  ChatBackend.watchLeaveEvents();
  ChatBackend.watchTyping(renderTyping, () => myName);

  updateUploadButtonVisibility();

  $emptyState.style.display = "flex";
  updateCharCounter();

  window.addEventListener("beforeunload", () => {
    stopTyping();
    if (isSpectator) {
      ChatBackend.releasePresence();
    } else {
      ChatBackend.releasePresence();
    }
  });
