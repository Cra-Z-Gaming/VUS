    archive:'<svg class="icon-archive" viewBox="0 0 24 24" fill="none"><rect x="3" y="6.5" width="18" height="14" rx="2" fill="currentColor" opacity=".14"/><rect x="3" y="6.5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M3 6.5h18M9.5 6.5v3.5h5V6.5" stroke="currentColor" stroke-width="1.3" fill="none"/><rect x="10.5" y="12" width="3" height="2.5" stroke="currentColor" stroke-width="1.1" fill="none"/></svg>',
    executable:'<svg class="icon-executable" viewBox="0 0 24 24" fill="none"><rect x="2.5" y="4" width="19" height="16" rx="2" fill="currentColor" opacity=".14"/><rect x="2.5" y="4" width="19" height="16" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M6.5 9.5l3 2.5-3 2.5M12 14.5h5.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>',
    generic:'<svg class="icon-generic" viewBox="0 0 24 24" fill="none"><path d="M6.5 2.5h7l4 4v13a1 1 0 0 1-1 1h-10a1 1 0 0 1-1-1v-16a1 1 0 0 1 1-1z" stroke="currentColor" stroke-width="1.3" fill="none"/><path d="M13.5 2.5v4h4" stroke="currentColor" stroke-width="1.3" fill="none"/></svg>'
  };

  /* ============================================================
     STATE
  ============================================================ */
  const nodes = new Map();      // id -> node
  let rootId;
  let currentId;                // id of folder currently being viewed
  let history = [];             // array of folder ids
  let historyIndex = -1;
  let undoStack = [];
  let redoStack = [];
  let nextId = 1;
  let activeThumbUrls = [];      // object urls created for the current render
  let searchMode = false;
  let searchResults = [];

  function genId(){ return 'n' + (nextId++); }

  function makeFolder(name, parentId){
    const node = { id: genId(), name, type:'folder', parentId, children: [], deleted:false };
    nodes.set(node.id, node);
    if(parentId) nodes.get(parentId).children.push(node.id);
    return node;
  }
  function makeFile(name, parentId, file){
    const node = {
      id: genId(), name, type:'file', parentId, file,
      size: file ? file.size : 0,
      lastModified: file ? file.lastModified : Date.now(),
      ext: getExt(name), deleted:false
    };
    nodes.set(node.id, node);
    if(parentId) nodes.get(parentId).children.push(node.id);
    return node;
  }

  /* ============================================================
     HELPERS
  ============================================================ */
  function getExt(name){
    const idx = name.lastIndexOf('.');
    if(idx <= 0) return '';
    return name.slice(idx+1).toLowerCase();
  }

  function getCategory(node){
    if(node.type === 'folder') return 'folder';
    const ext = node.ext;
    if(TEXT_LIKE.has(ext) || HTML_LIKE.has(ext)) return 'text';
    if(IMAGE_LIKE.has(ext)) return 'image';
    if(AUDIO_LIKE.has(ext)) return 'audio';
    if(VIDEO_LIKE.has(ext)) return 'video';
    if(PDF_LIKE.has(ext)) return 'pdf';
    if(ARCHIVE_LIKE.has(ext)) return 'archive';
    if(EXECUTABLE_LIKE.has(ext)) return 'executable';
    return 'generic';
  }

  function humanSize(bytes){
    if(!bytes) return '0 B';
    const units = ['B','KB','MB','GB','TB'];
    let val = bytes, i = 0;
    while(val >= 1024 && i < units.length-1){ val /= 1024; i++; }
    return `${val.toFixed(i>0 && val<10 ? 1 : 0)} ${units[i]}`;
  }

  function formatDate(ts){
    if(!ts) return '—';
    const d = new Date(ts);
    return d.toLocaleDateString(undefined,{year:'numeric',month:'short',day:'numeric'}) +
      ' ' + d.toLocaleTimeString(undefined,{hour:'2-digit',minute:'2-digit'});
  }

  function escapeHtml(str){
    return String(str).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  function guessMime(name){
    const ext = getExt(name);
    return MIME_MAP[ext] || 'application/octet-stream';
  }

  function sortedChildren(node){
    return node.children
      .map(id => nodes.get(id))
      .filter(n => n && !n.deleted)
      .sort((a,b) => {
        if(a.type !== b.type) return a.type === 'folder' ? -1 : 1;
        return a.name.localeCompare(b.name, undefined, {numeric:true, sensitivity:'base'});
      });
  }

  function getPathIds(id){
    const path = [];
    let cur = id;
    while(cur){
      path.unshift(cur);
      cur = nodes.get(cur).parentId;
    }
    return path;
  }

  function getRelativePath(node){
    return getPathIds(node.id).slice(1).map(id => nodes.get(id).name).join('/');
  }

  // Resolve name collisions among non-deleted siblings of the same type.
  function uniqueName(parentId, name, type, excludeId){
    const siblings = nodes.get(parentId).children
      .map(id => nodes.get(id))
      .filter(n => n && !n.deleted && n.type === type && n.id !== excludeId);
    const existing = new Set(siblings.map(n => n.name.toLowerCase()));
    if(!existing.has(name.toLowerCase())) return name;
    const dot = name.lastIndexOf('.');
    const hasExt = type === 'file' && dot > 0;
    const base = hasExt ? name.slice(0, dot) : name;
    const ext = hasExt ? name.slice(dot) : '';
    let i = 1, candidate;
    do { candidate = `${base} (${i})${ext}`; i++; } while(existing.has(candidate.toLowerCase()));
    return candidate;
  }

  function findChildFolder(parentId, name){
    return nodes.get(parentId).children
      .map(id => nodes.get(id))
      .find(n => n && !n.deleted && n.type === 'folder' && n.name === name);
  }

  function ensureFolderPath(parentId, segments){
    let pid = parentId;
    for(const seg of segments){
      if(!seg) continue;
      let existing = findChildFolder(pid, seg);
      if(!existing) existing = makeFolder(seg, pid);
      pid = existing.id;
    }
    return pid;
  }

  function collectIds(node){
    let result = [node.id];
    if(node.type === 'folder'){
      for(const cid of node.children){
        const child = nodes.get(cid);
        if(child) result = result.concat(collectIds(child));
      }
    }
    return result;
  }

  /* ============================================================
     DOM REFERENCES
  ============================================================ */
  const breadcrumb = document.getElementById('breadcrumb');
  const fileList = document.getElementById('fileList');
  const emptyState = document.getElementById('emptyState');
  const statusBar = document.getElementById('statusBar');
  const searchInput = document.getElementById('searchInput');
  const searchCount = document.getElementById('searchCount');
  const dropOverlay = document.getElementById('dropOverlay');
  const contextMenu = document.getElementById('contextMenu');
  const modalBackdrop = document.getElementById('modalBackdrop');
  const renameInput = document.getElementById('renameInput');
  const renameConfirm = document.getElementById('renameConfirm');
  const renameCancel = document.getElementById('renameCancel');
  const modalTitle = document.getElementById('modalTitle');

  const btnHome = document.getElementById('btnHome');
  const btnBack = document.getElementById('btnBack');
  const btnForward = document.getElementById('btnForward');
  const btnUndo = document.getElementById('btnUndo');
  const btnRedo = document.getElementById('btnRedo');
  const btnNewFolder = document.getElementById('btnNewFolder');
  const btnImport = document.getElementById('btnImport');
  const importMenuList = document.getElementById('importMenuList');
  const btnExport = document.getElementById('btnExport');

  const inputSingleFile = document.getElementById('inputSingleFile');
  const inputMultipleFiles = document.getElementById('inputMultipleFiles');
  const inputFolder = document.getElementById('inputFolder');
  const inputProject = document.getElementById('inputProject');

  /* ============================================================
     INITIALISATION
  ============================================================ */
  function init(){
    const root = makeFolder('Home', null);
    rootId = root.id;
    currentId = rootId;
    history = [rootId];
    historyIndex = 0;
    render();
    wireEvents();
  }

  /* ============================================================
     NAVIGATION
  ============================================================ */
  function navigateTo(id, push = true){
    exitSearch();
    currentId = id;
    if(push){
      history = history.slice(0, historyIndex+1);
      history.push(id);
      historyIndex = history.length - 1;
    }
    render();
  }
  function goBack(){ if(historyIndex > 0){ historyIndex--; currentId = history[historyIndex]; exitSearch(); render(); } }
  function goForward(){ if(historyIndex < history.length-1){ historyIndex++; currentId = history[historyIndex]; exitSearch(); render(); } }
  function goHome(){ navigateTo(rootId); }

  /* ============================================================
     RENDERING
  ============================================================ */
  function render(){
    renderBreadcrumb();
    btnBack.disabled = historyIndex <= 0;
    btnForward.disabled = historyIndex >= history.length - 1;
    updateUndoRedoButtons();
    renderFileList();
    renderStatus();
  }

  function renderBreadcrumb(){
    const path = getPathIds(currentId);
    breadcrumb.innerHTML = '';
    path.forEach((id, idx) => {
      const node = nodes.get(id);
      const btn = document.createElement('button');
      btn.className = 'crumb' + (idx === path.length-1 ? ' current' : '');
      btn.textContent = idx === 0 ? 'Home' : node.name;
      btn.title = idx === 0 ? 'Home' : getRelativePath(node);
      btn.addEventListener('click', () => navigateTo(id));
      breadcrumb.appendChild(btn);
      if(idx < path.length-1){
        const sep = document.createElement('span');
        sep.className = 'crumb-sep';
        sep.textContent = '/';
        breadcrumb.appendChild(sep);
      }
    });
  }

  function revokeThumbUrls(){
    for(const url of activeThumbUrls) URL.revokeObjectURL(url);
    activeThumbUrls = [];
  }

  function renderFileList(){
    revokeThumbUrls();
    fileList.innerHTML = '';

    let items;
    if(searchMode){
      items = searchResults;
    } else {
      items = sortedChildren(nodes.get(currentId)).map(n => ({ node: n, path: null }));
    }

    const isEmpty = items.length === 0;
    emptyState.classList.toggle('visible', isEmpty);
    fileList.classList.toggle('hidden', isEmpty);

    if(isEmpty){
      const h2 = emptyState.querySelector('h2');
      const p = emptyState.querySelector('p');
      if(searchMode){
        h2.textContent = 'No matches found';
        p.textContent = `Nothing in this project matches “${searchInput.value}”. Try a different search term.`;
        emptyState.querySelector('.empty-actions').style.display = 'none';
      } else {
        h2.textContent = 'This folder is empty';
        p.textContent = 'Drag and drop files or folders anywhere on this window, or use the buttons below to import something to browse.';
        emptyState.querySelector('.empty-actions').style.display = 'flex';
      }
      return;
    }

    const frag = document.createDocumentFragment();
    for(const item of items) frag.appendChild(buildRow(item.node, item.path));
    fileList.appendChild(frag);
  }

  function buildRow(node, pathHint){
    const row = document.createElement('div');
    row.className = 'file-row';
    row.dataset.id = node.id;
    row.tabIndex = 0;

    // icon / thumbnail
    const iconCell = document.createElement('div');
    iconCell.className = 'col-icon';
    if(node.type === 'folder'){
      iconCell.innerHTML = ICONS.folder;
    } else {
      const cat = getCategory(node);
      if(cat === 'image' && node.file){
        const url = URL.createObjectURL(node.file);
        activeThumbUrls.push(url);
        const img = document.createElement('img');
        img.className = 'thumb';
        img.src = url;
        img.alt = '';
        img.loading = 'lazy';
        img.onerror = () => { iconCell.innerHTML = ICONS.image; };
        iconCell.appendChild(img);
      } else {
        iconCell.innerHTML = ICONS[cat] || ICONS.generic;
      }
    }

    // name (+ path hint for search results)
    const nameCell = document.createElement('div');
    nameCell.className = 'col-name';
    const nameSpan = document.createElement('span');
    nameSpan.className = 'item-name';
    nameSpan.textContent = node.name;
    nameCell.appendChild(nameSpan);
    if(pathHint !== null && pathHint !== undefined){
      const pathSpan = document.createElement('span');
      pathSpan.className = 'item-path';
      pathSpan.textContent = pathHint;
      nameCell.appendChild(pathSpan);
    }

    // type
    const typeCell = document.createElement('div');
    typeCell.className = 'col-type';
    if(node.type === 'folder'){
      typeCell.textContent = 'Folder';
    } else {
      typeCell.textContent = node.ext ? node.ext.toUpperCase() + ' file' : 'File';
    }

    // size
    const sizeCell = document.createElement('div');
    sizeCell.className = 'col-size';
    if(node.type === 'folder'){
      const count = sortedChildren(node).length;
      sizeCell.textContent = `${count} item${count !== 1 ? 's' : ''}`;
    } else {
      sizeCell.textContent = humanSize(node.size);
    }

    // modified
    const modCell = document.createElement('div');
    modCell.className = 'col-modified';
    modCell.textContent = node.type === 'file' ? formatDate(node.lastModified) : '';

    row.append(iconCell, nameCell, typeCell, sizeCell, modCell);

    row.addEventListener('click', () => openOrNavigate(node));
    row.addEventListener('keydown', e => {
      if(e.key === 'Enter') openOrNavigate(node);
    });
    row.addEventListener('contextmenu', e => {
      e.preventDefault();
      showContextMenu(e.pageX, e.pageY, node);
    });
    return row;
  }

  function renderStatus(){
    let files = 0, folders = 0, totalSize = 0;
    for(const node of nodes.values()){
      if(node.id === rootId || node.deleted) continue;
      if(node.type === 'file'){ files++; totalSize += node.size; }
      else folders++;
    }
    const current = nodes.get(currentId);
    const currentCount = sortedChildren(current).length;

    let text = `${folders} folder${folders !== 1 ? 's' : ''} · ${files} file${files !== 1 ? 's' : ''} · ${humanSize(totalSize)} total`;
    if(searchMode){
      text += ` · ${searchResults.length} search result${searchResults.length !== 1 ? 's' : ''}`;
    } else {
      text += ` · ${currentCount} item${currentCount !== 1 ? 's' : ''} here`;
    }
    statusBar.textContent = text;
  }

  function openOrNavigate(node){
    if(node.type === 'folder') navigateTo(node.id);
    else openItem(node);
  }

  /* ============================================================
     SEARCH
  ============================================================ */
  function exitSearch(){
    searchMode = false;
    searchResults = [];
    searchInput.value = '';
    searchCount.textContent = '';
  }

  function performSearch(query){
    const q = query.trim().toLowerCase();
    if(!q){
      exitSearch();
      render();
      return;
    }
    searchMode = true;
    searchResults = [];
    (function walk(node, parts){
      for(const childId of node.children){
        const child = nodes.get(childId);
        if(!child || child.deleted) continue;
        const fullParts = [...parts, child.name];
        if(child.name.toLowerCase().includes(q)){
          searchResults.push({ node: child, path: parts.length ? parts.join('/') : '/' });
        }
        if(child.type === 'folder') walk(child, fullParts);
      }
    })(nodes.get(rootId), []);

    searchResults.sort((a,b) => {
      if(a.node.type !== b.node.type) return a.node.type === 'folder' ? -1 : 1;
      return a.node.name.localeCompare(b.node.name, undefined, {numeric:true, sensitivity:'base'});
    });

    searchCount.textContent = `${searchResults.length} result${searchResults.length !== 1 ? 's' : ''}`;
    renderFileList();
    renderStatus();
  }

  /* ============================================================
     OPENING FILES
  ============================================================ */
  function openWindowOrWarn(){
    const win = window.open('', '_blank');
    if(!win){
      alert('Your browser blocked the new tab. Please allow pop-ups for this page to open files.');
      return null;
    }
    return win;
  }

  function openItem(node){
    const ext = node.ext;
    if(EXECUTABLE_LIKE.has(ext)){
      openInfoPage(node, 'executable');
    } else if(HTML_LIKE.has(ext)){
      openHtmlPreview(node);
    } else if(TEXT_LIKE.has(ext)){
      openTextViewer(node);
    } else if(IMAGE_LIKE.has(ext) || AUDIO_LIKE.has(ext) || VIDEO_LIKE.has(ext) || PDF_LIKE.has(ext)){
      openMedia(node, ext);
    } else {
      openInfoPage(node, 'unknown');
    }
  }

  function openMedia(node, ext){
    const win = openWindowOrWarn();
    if(!win) return;
    const mime = MIME_MAP[ext] || node.file.type || 'application/octet-stream';
    let blob = node.file;
    if(node.file.type !== mime){
      try { blob = node.file.slice(0, node.file.size, mime); } catch(e){ blob = node.file; }
    }
    const url = URL.createObjectURL(blob);
    win.location.href = url;
    // Object URLs are revoked after a delay long enough for the media to load.
    setTimeout(() => URL.revokeObjectURL(url), 5 * 60 * 1000);
  }

  async function openTextViewer(node){
    const win = openWindowOrWarn();
    if(!win) return;
    let text;
    try { text = await node.file.text(); }
    catch(e){ text = '(Unable to read file contents.)'; }

    let display = text;
    let isJson = false;
    if(node.ext === 'json'){
      try { display = JSON.stringify(JSON.parse(text), null, 2); isJson = true; }
      catch(e){ /* not valid JSON, show raw text */ }
    }
    const html = buildViewerPage(node.name, display, isJson, node);
    writeToWindow(win, html);
  }

  async function openHtmlPreview(node){
    const win = openWindowOrWarn();
    if(!win) return;
    let text;
    try { text = await node.file.text(); }
    catch(e){ text = '<p>Unable to read file contents.</p>'; }
    writeToWindow(win, text);
  }

  function openInfoPage(node, kind){
    const win = openWindowOrWarn();
    if(!win) return;
    const downloadUrl = URL.createObjectURL(node.file);
    const html = buildInfoPage(node, kind, downloadUrl);
    writeToWindow(win, html);
    setTimeout(() => URL.revokeObjectURL(downloadUrl), 10 * 60 * 1000);
  }

  function writeToWindow(win, html){
    try {
      win.document.open();
      win.document.write(html);
      win.document.close();
    } catch(e){
      console.error('Failed to render preview', e);
    }
  }

  function buildViewerPage(name, content, isJson, node){
    return `<!DOCTYPE html><html><head><meta charset="utf-8"><title>${escapeHtml(name)}</title>
<style>
  :root{--bg:#0b0d11;--bg-elev:#13161c;--border:#262b34;--text:#e7e9ee;--text-dim:#919aab;--accent:#7aa2ff;--font-mono:"SF Mono","Cascadia Code","Roboto Mono",Consolas,monospace;}
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,"Segoe UI",sans-serif;}
  header{padding:14px 22px;background:var(--bg-elev);border-bottom:1px solid var(--border);font-size:13px;color:var(--text-dim);
    display:flex;align-items:center;gap:10px;position:sticky;top:0;}
  header strong{color:var(--text);font-weight:600;font-size:14px;}
  .badge{background:var(--accent);color:#0b0d11;font-size:11px;font-weight:700;padding:2px 8px;border-radius:999px;}
  .meta{margin-left:auto;font-family:var(--font-mono);font-size:11.5px;}
  pre{margin:0;padding:22px;font-family:var(--font-mono);font-size:13px;line-height:1.65;white-space:pre-wrap;word-break:break-word;color:var(--text);}
</style></head><body>
<header><strong>${escapeHtml(name)}</strong>${isJson ? '<span class="badge">JSON</span>' : ''}<span>VUS File Explorer · text viewer</span><span class="meta">${humanSize(node.size)}</span></header>
<pre>${escapeHtml(content)}</pre>
</body></html>`;
  }

  function buildInfoPage(node, kind, downloadUrl){
    const isExecutable = kind === 'executable';
    const title = isExecutable ? 'Executable file' : 'Unsupported file type';
    const note = isExecutable
      ? 'This file type can run code on your computer, so VUS File Explorer will not execute it. Here is its information instead.'
      : "VUS File Explorer doesn't have a built-in preview for this file type. Here is its information instead.";
    const rows = [
      ['Name', node.name],
      ['Extension', node.ext ? '.' + node.ext : '(none)'],
      ['Size', `${humanSize(node.size)} (${node.size.toLocaleString()} bytes)`],
      ['Last modified', formatDate(node.lastModified)],
      ['Relative path', getRelativePath(node) || node.name],
      ['MIME type', (node.file && node.file.type) || 'unknown']
    ];
    const rowsHtml = rows.map(([k,v]) => `<tr><th>${escapeHtml(k)}</th><td>${escapeHtml(String(v))}</td></tr>`).join('');
    return `<!DOCTYPE html><html><head><meta charset="utf-8"><title>${escapeHtml(node.name)}</title>
<style>
  :root{--bg:#0b0d11;--bg-elev:#13161c;--bg-elev-2:#191d25;--border:#262b34;--text:#e7e9ee;--text-dim:#919aab;--accent:#7aa2ff;--orange:#ffb454;--font-mono:"SF Mono","Cascadia Code","Roboto Mono",Consolas,monospace;}
  *{box-sizing:border-box;}
  body{margin:0;background:var(--bg);color:var(--text);font-family:-apple-system,"Segoe UI",sans-serif;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px;}
  .card{background:var(--bg-elev);border:1px solid var(--border);border-radius:14px;padding:28px 30px;max-width:480px;width:100%;}
  .icon{width:46px;height:46px;border-radius:10px;background:${isExecutable ? 'rgba(255,180,84,.14)' : 'rgba(122,162,255,.14)'};
    display:flex;align-items:center;justify-content:center;margin-bottom:16px;color:${isExecutable ? 'var(--orange)' : 'var(--accent)'};}
  .icon svg{width:24px;height:24px;}
  h1{font-size:17px;margin:0 0 6px;}
  p.note{color:var(--text-dim);font-size:13px;line-height:1.6;margin:0 0 20px;}
  table{width:100%;border-collapse:collapse;font-size:12.5px;margin-bottom:22px;}
  th{text-align:left;color:var(--text-dim);font-weight:500;padding:7px 0;width:130px;vertical-align:top;}
  td{padding:7px 0;font-family:var(--font-mono);word-break:break-all;}
  tr+tr th,tr+tr td{border-top:1px solid var(--border);}
  a.download{display:inline-flex;align-items:center;gap:8px;background:var(--accent);color:#0b0d11;font-weight:600;
    text-decoration:none;padding:10px 18px;border-radius:8px;font-size:13px;}
  a.download:hover{background:#9db8ff;}
</style></head><body>
<div class="card">
  <div class="icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
    ${isExecutable ? '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7.5 9.5l3 2.5-3 2.5M12.5 14.5h5"/>' : '<path d="M6.5 2.5h7l4 4v13a1 1 0 0 1-1 1h-10a1 1 0 0 1-1-1v-16a1 1 0 0 1 1-1z"/><path d="M13.5 2.5v4h4"/>'}
  </svg></div>
  <h1>${title}</h1>
  <p class="note">${note}</p>
  <table>${rowsHtml}</table>
  <a class="download" href="${downloadUrl}" download="${escapeHtml(node.name)}">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 10l5 5 5-5"/><path d="M5 21h14"/></svg>
    Download file
  </a>
</div>
</body></html>`;
  }

  /* ============================================================
     CONTEXT MENU
  ============================================================ */
  function showContextMenu(x, y, node){
    contextMenu.innerHTML = '';

    const label = document.createElement('div');
    label.className = 'menu-label';
    label.textContent = node.name;
    contextMenu.appendChild(label);

    const items = [];
    if(node.type === 'folder'){
      items.push({ label: 'Open', action: () => navigateTo(node.id) });
    } else {
      items.push({ label: 'Open', action: () => openItem(node) });
      items.push({ label: 'Download', action: () => downloadFile(node) });
    }
    items.push({ label: 'Rename', action: () => startRename(node) });
    items.push({
      label: node.type === 'folder' ? 'Delete (recursive)' : 'Delete',
      action: () => deleteNode(node),
      danger: true
    });

    for(const it of items){
      const btn = document.createElement('button');
      btn.textContent = it.label;
      if(it.danger) btn.classList.add('danger');
      btn.addEventListener('click', () => { hideContextMenu(); it.action(); });
      contextMenu.appendChild(btn);
    }

    // position, keeping menu on-screen
    contextMenu.style.left = '0px';
    contextMenu.style.top = '0px';
    contextMenu.classList.add('visible');
    const rect = contextMenu.getBoundingClientRect();
    const maxX = window.innerWidth - rect.width - 8;
    const maxY = window.innerHeight - rect.height - 8;
    contextMenu.style.left = Math.min(x, Math.max(8, maxX)) + 'px';
    contextMenu.style.top = Math.min(y, Math.max(8, maxY)) + 'px';
  }
  function hideContextMenu(){ contextMenu.classList.remove('visible'); }

  function downloadFile(node){
    const url = URL.createObjectURL(node.file);
    const a = document.createElement('a');
    a.href = url;
    a.download = node.name;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 10000);
  }

  /* ============================================================
     RENAME / DELETE / UNDO / REDO
  ============================================================ */
  function startRename(node){
    modalTitle.textContent = `Rename ${node.type}`;
    renameInput.value = node.name;
    modalBackdrop.classList.add('visible');
    requestAnimationFrame(() => { renameInput.focus(); renameInput.select(); });

    function confirmRename(){
      const newName = renameInput.value.trim();
      if(newName && newName !== node.name){
        const oldName = node.name;
        const unique = uniqueName(node.parentId, newName, node.type, node.id);
        node.name = unique;
        if(node.type === 'file') node.ext = getExt(unique);
        pushUndo({ type:'rename', id: node.id, oldName, newName: unique });
        render();
      }
      closeModal();
    }
    renameConfirm.onclick = confirmRename;
    renameCancel.onclick = closeModal;
    renameInput.onkeydown = e => {
      if(e.key === 'Enter') confirmRename();
      if(e.key === 'Escape') closeModal();
    };
  }
  function closeModal(){
    modalBackdrop.classList.remove('visible');
    renameConfirm.onclick = null;
    renameCancel.onclick = null;
    renameInput.onkeydown = null;
  }

  function deleteNode(node){
    if(node.id === rootId) return;
    const ids = collectIds(node).filter(id => !nodes.get(id).deleted);
    if(ids.length === 0) return;
    ids.forEach(id => { nodes.get(id).deleted = true; });
    pushUndo({ type:'delete', ids });

    if(ids.includes(currentId)){
      // The folder being viewed (or an ancestor of it) was just deleted.
      let target = nodes.get(currentId).parentId;
      while(target && nodes.get(target).deleted) target = nodes.get(target).parentId;
      navigateTo(target || rootId);
    } else {
      render();
    }
  }

  function newFolder(){
    const name = uniqueName(currentId, 'New folder', 'folder');
    const node = makeFolder(name, currentId);
    pushUndo({ type:'create', id: node.id });
    render();
  }

  function pushUndo(action){
    undoStack.push(action);
    redoStack = [];
    updateUndoRedoButtons();
  }

  function updateUndoRedoButtons(){
    btnUndo.disabled = undoStack.length === 0;
    btnRedo.disabled = redoStack.length === 0;
  }

  function undo(){
    const action = undoStack.pop();
    if(!action) return;
    switch(action.type){
      case 'delete':
        action.ids.forEach(id => { const n = nodes.get(id); if(n) n.deleted = false; });
        break;
      case 'rename': {
        const n = nodes.get(action.id);
        if(n){ n.name = action.oldName; if(n.type === 'file') n.ext = getExt(n.name); }
        break;
      }
      case 'create': {
        const n = nodes.get(action.id);
        if(n) n.deleted = true;
        break;
      }
    }
    redoStack.push(action);
    render();
  }

  function redo(){
    const action = redoStack.pop();
    if(!action) return;
    switch(action.type){
      case 'delete':
        action.ids.forEach(id => { const n = nodes.get(id); if(n) n.deleted = true; });
        if(action.ids.includes(currentId)){
          let target = nodes.get(currentId).parentId;
          while(target && nodes.get(target).deleted) target = nodes.get(target).parentId;
          currentId = target || rootId;
        }
        break;
      case 'rename': {
        const n = nodes.get(action.id);
        if(n){ n.name = action.newName; if(n.type === 'file') n.ext = getExt(n.name); }
        break;
      }
      case 'create': {
        const n = nodes.get(action.id);
        if(n) n.deleted = false;
        break;
      }
    }
    undoStack.push(action);
    render();
  }

  /* ============================================================
     IMPORTING FILES / FOLDERS
  ============================================================ */
  function importFileList(fileList, useRelativePath){
    if(!fileList || fileList.length === 0) return;
    for(const file of fileList){
      let segments = [];
      let name = file.name;
      if(useRelativePath && file.webkitRelativePath){
        const parts = file.webkitRelativePath.split('/');
        name = parts.pop();
        segments = parts;
      }
      const parentId = ensureFolderPath(currentId, segments);
      const uname = uniqueName(parentId, name, 'file');
      makeFile(uname, parentId, file);
    }
    render();
  }

  function readEntries(reader){
    return new Promise((resolve, reject) => reader.readEntries(resolve, reject));
  }
  function getEntryFile(entry){
    return new Promise((resolve, reject) => entry.file(resolve, reject));
  }

  async function traverseEntry(entry, parentId){
    if(entry.isFile){
      const file = await getEntryFile(entry);
      const uname = uniqueName(parentId, entry.name, 'file');
      makeFile(uname, parentId, file);
    } else if(entry.isDirectory){
      const uname = uniqueName(parentId, entry.name, 'folder');
      const folder = makeFolder(uname, parentId);
      const reader = entry.createReader();
      let all = [];
      let batch;
      do {
        batch = await readEntries(reader);
        all = all.concat(batch);
      } while(batch.length > 0);
      for(const child of all) await traverseEntry(child, folder.id);
    }
  }

  async function importDataTransferItems(items){
    const entries = [];
    for(const item of items){
      if(item.kind !== 'file') continue;
      const entry = item.webkitGetAsEntry ? item.webkitGetAsEntry() : null;
      if(entry){
        entries.push(entry);
      } else {
        const file = item.getAsFile();
        if(file) entries.push({ isFile:true, isDirectory:false, name:file.name, _file:file });
      }
    }
    for(const entry of entries){
      if(entry._file){
        const uname = uniqueName(currentId, entry.name, 'file');
        makeFile(uname, currentId, entry._file);
      } else {
        await traverseEntry(entry, currentId);
      }
    }
    render();
  }

  /* ============================================================
     EXPORT / IMPORT PROJECT (.zip)
  ============================================================ */
  async function exportProject(){
    if(typeof JSZip === 'undefined'){
      alert('The export library failed to load. Check your internet connection and try again.');
      return;
    }
    btnExport.disabled = true;
    btnExport.textContent = 'Exporting…';
    try {
      const zip = new JSZip();
      const manifestEntries = [];

      async function addNode(node, zipFolder, pathPrefix){
        const children = sortedChildren(node);
        if(node.id !== rootId){
          manifestEntries.push({
            path: pathPrefix.slice(0, -1),
            type: 'folder',
            lastModified: null
          });
        }
        if(children.length === 0 && node.id !== rootId){
          zipFolder.file('.vus-empty', '');
          return;
        }
        for(const child of children){
          if(child.type === 'folder'){
            const folder = zipFolder.folder(child.name);
            await addNode(child, folder, pathPrefix + child.name + '/');
          } else {
            const buf = await child.file.arrayBuffer();
            zipFolder.file(child.name, buf, { date: new Date(child.lastModified) });
            manifestEntries.push({
              path: pathPrefix + child.name,
              type: 'file',
              lastModified: child.lastModified,
              size: child.size
            });
          }
        }
      }

      await addNode(nodes.get(rootId), zip, '');
      zip.file('vus-manifest.json', JSON.stringify({
        generator: 'VUS File Explorer', version: 1, entries: manifestEntries
      }, null, 2));

      const blob = await zip.generateAsync({ type:'blob', compression:'DEFLATE' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'vus-export.zip';
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 10000);
    } catch(e){
      console.error(e);
      alert('Export failed: ' + e.message);
    } finally {
      btnExport.disabled = false;
      btnExport.textContent = 'Export';
    }
  }

  async function importProjectZip(file){
    if(typeof JSZip === 'undefined'){
      alert('The import library failed to load. Check your internet connection and try again.');
      return;
    }
    try {
      const zip = await JSZip.loadAsync(file);
      let manifest = null;
      const manifestEntry = zip.file('vus-manifest.json');
      if(manifestEntry){
        try { manifest = JSON.parse(await manifestEntry.async('string')); } catch(e){ manifest = null; }
      }
      const lookup = new Map();
      if(manifest && manifest.entries){
        for(const e of manifest.entries) lookup.set(e.path, e);
      }

      const entries = Object.values(zip.files)
        .filter(e => e.name !== 'vus-manifest.json')
        .sort((a,b) => a.name.localeCompare(b.name));

      for(const entry of entries){
        const cleanPath = entry.name.replace(/\/$/, '');
        const parts = cleanPath.split('/').filter(Boolean);
        const baseName = parts[parts.length-1];

        if(baseName === '.vus-empty'){
          ensureFolderPath(currentId, parts.slice(0, -1));
          continue;
        }
        if(entry.dir){
          ensureFolderPath(currentId, parts);
          continue;
        }

        const fileParts = parts.slice(0, -1);
        const fname = baseName;
        const parentId = ensureFolderPath(currentId, fileParts);
        const arrayBuf = await entry.async('arraybuffer');

        let lastModified = entry.date ? entry.date.getTime() : Date.now();
        const m = lookup.get(cleanPath);
        if(m && m.lastModified) lastModified = m.lastModified;

        const mime = guessMime(fname);
        const blob = new Blob([arrayBuf], { type: mime });
        const pseudoFile = new File([blob], fname, { lastModified, type: mime });

        const uname = uniqueName(parentId, fname, 'file');
        makeFile(uname, parentId, pseudoFile);
      }
      render();
    } catch(e){
      console.error(e);
      alert('Import failed: this does not look like a valid VUS export, or the file is corrupted.');
    }
  }

  /* ============================================================
     EVENT WIRING
  ============================================================ */
  function wireEvents(){
    btnHome.addEventListener('click', goHome);
    btnBack.addEventListener('click', goBack);
    btnForward.addEventListener('click', goForward);
    btnUndo.addEventListener('click', undo);
    btnRedo.addEventListener('click', redo);
    btnNewFolder.addEventListener('click', newFolder);
    btnExport.addEventListener('click', exportProject);

    searchInput.addEventListener('input', () => performSearch(searchInput.value));
    searchInput.addEventListener('keydown', e => { if(e.key === 'Escape'){ exitSearch(); render(); } });

    // import menu
    btnImport.addEventListener('click', e => {
      e.stopPropagation();
      importMenuList.classList.toggle('visible');
    });
    document.addEventListener('click', () => importMenuList.classList.remove('visible'));
    importMenuList.addEventListener('click', e => {
      const action = e.target.closest('button')?.dataset.action;
      if(action) triggerImport(action);
    });

    // empty-state buttons
    emptyState.addEventListener('click', e => {
      const action = e.target.closest('button')?.dataset.action;
      if(action) triggerImport(action);
    });

    function triggerImport(action){
      if(action === 'file') inputSingleFile.click();
      else if(action === 'files') inputMultipleFiles.click();
      else if(action === 'folder') inputFolder.click();
      else if(action === 'project') inputProject.click();
    }

    inputSingleFile.addEventListener('change', e => { importFileList(e.target.files, false); e.target.value=''; });
    inputMultipleFiles.addEventListener('change', e => { importFileList(e.target.files, false); e.target.value=''; });
    inputFolder.addEventListener('change', e => { importFileList(e.target.files, true); e.target.value=''; });
    inputProject.addEventListener('change', async e => {
      const file = e.target.files[0];
      if(file) await importProjectZip(file);
      e.target.value = '';
    });

    // context menu dismissal
    document.addEventListener('click', e => {
      if(!contextMenu.contains(e.target)) hideContextMenu();
    });
    window.addEventListener('scroll', hideContextMenu, true);

    // modal backdrop click closes
    modalBackdrop.addEventListener('click', e => { if(e.target === modalBackdrop) closeModal(); });

    // global keyboard shortcuts
    document.addEventListener('keydown', e => {
      const inModal = modalBackdrop.classList.contains('visible');
      const inSearch = document.activeElement === searchInput;
      if(inModal || inSearch) return;
      const mod = e.ctrlKey || e.metaKey;
      if(mod && e.key.toLowerCase() === 'z' && !e.shiftKey){ e.preventDefault(); undo(); }
      else if(mod && (e.key.toLowerCase() === 'y' || (e.key.toLowerCase() === 'z' && e.shiftKey))){ e.preventDefault(); redo(); }
      else if(e.key === 'Escape'){ exitSearch(); render(); }
    });

    // drag and drop
    let dragCounter = 0;
    window.addEventListener('dragenter', e => {
      e.preventDefault();
      dragCounter++;
      dropOverlay.classList.add('visible');
    });
    window.addEventListener('dragover', e => e.preventDefault());
    window.addEventListener('dragleave', e => {
      dragCounter = Math.max(0, dragCounter - 1);
      if(dragCounter === 0) dropOverlay.classList.remove('visible');
    });
    window.addEventListener('drop', async e => {
      e.preventDefault();
      dragCounter = 0;
      dropOverlay.classList.remove('visible');
      if(e.dataTransfer && e.dataTransfer.items && e.dataTransfer.items.length){
        await importDataTransferItems(Array.from(e.dataTransfer.items));
      }
    });
  }

  init();
})();
</script>
