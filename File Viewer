<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VUS File Explorer</title>
<style>
  :root{
    --bg:#0b0d11;
    --bg-elev:#13161c;
    --bg-elev-2:#191d25;
    --bg-hover:#20242d;
    --bg-active:#262c38;
    --border:#262b34;
    --border-soft:#1c2029;
    --text:#e7e9ee;
    --text-dim:#919aab;
    --text-faint:#5d6675;
    --accent:#7aa2ff;
    --accent-dim:rgba(122,162,255,.14);
    --accent-strong:#9db8ff;
    --green:#6ee7b7;
    --orange:#ffb454;
    --red:#ff6b6b;
    --pink:#ff7eb6;
    --purple:#b694ff;
    --radius:10px;
    --radius-sm:6px;
    --font-ui:-apple-system,BlinkMacSystemFont,"Segoe UI","Inter",Roboto,Helvetica,Arial,sans-serif;
    --font-mono:"SF Mono","Cascadia Code","Roboto Mono",Consolas,monospace;
    --transition:140ms cubic-bezier(.4,0,.2,1);
  }
  *{box-sizing:border-box;}
  html,body{height:100%;}
  body{
    margin:0;background:var(--bg);color:var(--text);
    font-family:var(--font-ui);font-size:13.5px;
    -webkit-font-smoothing:antialiased;
    overflow:hidden;
  }
  button{font-family:inherit;}
  #app{display:flex;flex-direction:column;height:100vh;}

  /* ---------- Toolbar ---------- */
  .toolbar{
    display:flex;align-items:center;gap:10px;
    padding:10px 14px;background:var(--bg-elev);
    border-bottom:1px solid var(--border);
    flex-wrap:wrap;
  }
  .toolbar-group{display:flex;align-items:center;gap:4px;}
  .icon-btn{
    width:32px;height:32px;display:flex;align-items:center;justify-content:center;
    background:transparent;border:1px solid transparent;border-radius:var(--radius-sm);
    color:var(--text-dim);cursor:pointer;transition:background var(--transition),color var(--transition);
    flex-shrink:0;
  }
  .icon-btn svg{width:17px;height:17px;}
  .icon-btn:hover:not(:disabled){background:var(--bg-hover);color:var(--text);}
  .icon-btn:disabled{opacity:.35;cursor:default;}
  .icon-btn.active{color:var(--accent);background:var(--accent-dim);}

  .breadcrumb{
    display:flex;align-items:center;gap:4px;flex:1 1 200px;min-width:60px;
    overflow-x:auto;white-space:nowrap;padding:4px 2px;scrollbar-width:thin;
  }
  .breadcrumb::-webkit-scrollbar{height:4px;}
  .breadcrumb::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
  .crumb{
    background:transparent;border:none;color:var(--text-dim);font-size:13px;
    padding:5px 9px;border-radius:var(--radius-sm);cursor:pointer;
    transition:background var(--transition),color var(--transition);
    white-space:nowrap;flex-shrink:0;
  }
  .crumb:hover{background:var(--bg-hover);color:var(--text);}
  .crumb.current{color:var(--text);font-weight:600;}
  .crumb-sep{color:var(--text-faint);font-size:12px;flex-shrink:0;}

  .search-wrap{
    position:relative;display:flex;align-items:center;
    flex:0 1 280px;min-width:140px;
  }
  .search-wrap svg{
    position:absolute;left:10px;width:14px;height:14px;color:var(--text-faint);pointer-events:none;
  }
  #searchInput{
    width:100%;background:var(--bg-elev-2);border:1px solid var(--border);color:var(--text);
    border-radius:var(--radius-sm);padding:7px 10px 7px 30px;font-size:13px;
    transition:border-color var(--transition),background var(--transition);
  }
  #searchInput::placeholder{color:var(--text-faint);}
  #searchInput:focus{outline:none;border-color:var(--accent);background:var(--bg-elev);}
  .search-count{
    position:absolute;right:10px;font-size:11px;color:var(--text-faint);
    pointer-events:none;
  }

  .btn{
    background:var(--bg-elev-2);border:1px solid var(--border);color:var(--text);
    padding:7px 13px;border-radius:var(--radius-sm);cursor:pointer;font-size:13px;
    transition:background var(--transition),border-color var(--transition);
    white-space:nowrap;
  }
  .btn:hover{background:var(--bg-hover);border-color:var(--text-faint);}
  .btn.primary{background:var(--accent);border-color:var(--accent);color:#0b0d11;font-weight:600;}
  .btn.primary:hover{background:var(--accent-strong);}

  .menu{position:relative;}
  .menu-list{
    position:absolute;top:calc(100% + 6px);right:0;min-width:190px;
    background:var(--bg-elev-2);border:1px solid var(--border);border-radius:var(--radius);
    box-shadow:0 12px 28px rgba(0,0,0,.45);padding:6px;display:none;flex-direction:column;gap:2px;
    z-index:60;
  }
  .menu-list.visible{display:flex;}
  .menu-list button{
    background:transparent;border:none;color:var(--text);text-align:left;
    padding:8px 10px;border-radius:var(--radius-sm);cursor:pointer;font-size:13px;
    display:flex;align-items:center;gap:8px;
  }
  .menu-list button:hover{background:var(--bg-hover);}
  .menu-list .menu-divider{height:1px;background:var(--border);margin:4px 2px;}
  .menu-list small{color:var(--text-faint);font-size:11px;display:block;}

  /* ---------- Workspace ---------- */
  .workspace{flex:1;display:flex;overflow:hidden;}
  .panel{flex:1;display:flex;flex-direction:column;overflow:hidden;position:relative;}

  .list-header,.file-row{
    display:grid;grid-template-columns:42px 1fr 130px 110px 170px;
    align-items:center;gap:12px;padding:0 16px;
  }
  .list-header{
    height:32px;font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;
    color:var(--text-faint);border-bottom:1px solid var(--border-soft);
    background:var(--bg-elev);flex-shrink:0;
  }
  .file-list{flex:1;overflow-y:auto;padding:6px 8px 24px;}
  .file-list.hidden{display:none;}
  .file-row{
    height:42px;border-radius:var(--radius-sm);cursor:pointer;
    transition:background var(--transition);outline-offset:-2px;
  }
  .file-row:hover{background:var(--bg-hover);}
  .file-row:focus{outline:2px solid var(--accent);}
  .col-icon{display:flex;align-items:center;justify-content:center;}
  .col-icon svg{width:19px;height:19px;}
  .thumb{
    width:26px;height:26px;object-fit:cover;border-radius:4px;
    border:1px solid var(--border);background:var(--bg-elev-2);
  }
  .col-name{display:flex;flex-direction:column;min-width:0;justify-content:center;gap:1px;}
  .item-name{
    overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--text);
  }
  .item-path{
    overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    font-family:var(--font-mono);font-size:10.5px;color:var(--text-faint);
  }
  .col-type,.col-size,.col-modified{
    color:var(--text-dim);font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
  }
  .col-modified{font-family:var(--font-mono);font-size:11.5px;}

  /* icon colors */
  .icon-folder{color:var(--accent);}
  .icon-text{color:var(--text-dim);}
  .icon-image{color:var(--green);}
  .icon-audio{color:var(--purple);}
  .icon-video{color:var(--pink);}
  .icon-pdf{color:var(--red);}
  .icon-archive{color:var(--orange);}
  .icon-executable{color:var(--orange);}
  .icon-generic{color:var(--text-faint);}

  /* ---------- Empty state ---------- */
  .empty-state{
    flex:1;display:none;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:40px;color:var(--text-dim);gap:14px;
  }
  .empty-state.visible{display:flex;}
  .empty-state svg{width:56px;height:56px;color:var(--text-faint);}
  .empty-state h2{margin:0;font-size:17px;color:var(--text);font-weight:600;}
  .empty-state p{margin:0;font-size:13px;max-width:380px;line-height:1.6;}
  .empty-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-top:6px;}

  /* ---------- Status bar ---------- */
  .status-bar{
    flex-shrink:0;display:flex;align-items:center;gap:14px;
    padding:7px 16px;background:var(--bg-elev);border-top:1px solid var(--border);
    font-size:11.5px;color:var(--text-faint);font-family:var(--font-mono);
    flex-wrap:wrap;
  }

  /* ---------- Drop overlay ---------- */
  .drop-overlay{
    position:fixed;inset:0;background:rgba(11,13,17,.78);
    display:none;align-items:center;justify-content:center;z-index:100;
    backdrop-filter:blur(2px);
  }
  .drop-overlay.visible{display:flex;}
  .drop-overlay-inner{
    border:2px dashed var(--accent);border-radius:var(--radius);
    padding:60px 90px;color:var(--accent-strong);font-size:18px;font-weight:600;
    display:flex;flex-direction:column;align-items:center;gap:12px;
    animation:pulse 1.6s ease-in-out infinite;
  }
  .drop-overlay-inner svg{width:40px;height:40px;}
  @keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.03);}}

  /* ---------- Context menu ---------- */
  .context-menu{
    position:fixed;display:none;flex-direction:column;gap:2px;min-width:170px;
    background:var(--bg-elev-2);border:1px solid var(--border);border-radius:var(--radius);
    box-shadow:0 14px 32px rgba(0,0,0,.5);padding:6px;z-index:200;
  }
  .context-menu.visible{display:flex;}
  .context-menu button{
    background:transparent;border:none;color:var(--text);text-align:left;
    padding:8px 12px;border-radius:var(--radius-sm);cursor:pointer;font-size:13px;
    display:flex;align-items:center;gap:8px;
  }
  .context-menu button:hover{background:var(--bg-hover);}
  .context-menu button.danger:hover{background:rgba(255,107,107,.12);color:var(--red);}
  .context-menu .menu-label{
    padding:6px 12px 2px;font-size:10.5px;text-transform:uppercase;letter-spacing:.06em;
    color:var(--text-faint);
  }

  /* ---------- Modal ---------- */
  .modal-backdrop{
    position:fixed;inset:0;background:rgba(0,0,0,.55);display:none;
    align-items:center;justify-content:center;z-index:300;
  }
  .modal-backdrop.visible{display:flex;}
  .modal{
    background:var(--bg-elev-2);border:1px solid var(--border);border-radius:var(--radius);
    padding:20px;width:340px;box-shadow:0 20px 50px rgba(0,0,0,.5);
  }
  .modal h3{margin:0 0 12px;font-size:15px;font-weight:600;}
  .modal input{
    width:100%;background:var(--bg);border:1px solid var(--border);color:var(--text);
    padding:9px 10px;border-radius:var(--radius-sm);font-size:13px;
  }
  .modal input:focus{outline:none;border-color:var(--accent);}
  .modal-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:16px;}

  /* ---------- Responsive ---------- */
  @media (max-width:760px){
    .list-header,.file-row{grid-template-columns:36px 1fr 90px;}
    .col-type,.col-modified{display:none;}
    .search-wrap{flex:1 1 100%;order:3;}
    .toolbar{gap:8px;}
  }
  @media (max-width:480px){
    .list-header,.file-row{grid-template-columns:32px 1fr;}
    .col-size{display:none;}
  }

  /* scrollbars */
  ::-webkit-scrollbar{width:10px;height:10px;}
  ::-webkit-scrollbar-track{background:transparent;}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:6px;}
  ::-webkit-scrollbar-thumb:hover{background:var(--text-faint);}
</style>
</head>
<body>
<div id="app">
  <header class="toolbar">
    <div class="toolbar-group nav-group">
      <button class="icon-btn" id="btnHome" title="Home" aria-label="Home">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.5 12 4l9 7.5"/><path d="M5 10v9a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9"/></svg>
      </button>
      <button class="icon-btn" id="btnBack" title="Back" aria-label="Back" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 6l-6 6 6 6"/></svg>
      </button>
      <button class="icon-btn" id="btnForward" title="Forward" aria-label="Forward" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M10 6l6 6-6 6"/></svg>
      </button>
    </div>

    <nav class="breadcrumb" id="breadcrumb" aria-label="Breadcrumb"></nav>

    <div class="search-wrap">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input type="search" id="searchInput" placeholder="Search this project…" autocomplete="off">
      <span class="search-count" id="searchCount"></span>
    </div>

    <div class="toolbar-group edit-group">
      <button class="icon-btn" id="btnUndo" title="Undo" aria-label="Undo" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14 4 9l5-5"/><path d="M4 9h10a6 6 0 0 1 0 12h-1"/></svg>
      </button>
      <button class="icon-btn" id="btnRedo" title="Redo" aria-label="Redo" disabled>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14l5-5-5-5"/><path d="M20 9H10a6 6 0 0 0 0 12h1"/></svg>
      </button>
      <button class="icon-btn" id="btnNewFolder" title="New folder" aria-label="New folder">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a1 1 0 0 1 1-1h4.5l1.5 2H20a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/><path d="M12 11v4M10 13h4"/></svg>
      </button>
    </div>

    <div class="toolbar-group import-group">
      <div class="menu" id="importMenu">
        <button class="btn primary" id="btnImport">Import ▾</button>
        <div class="menu-list" id="importMenuList">
          <button data-action="file">📄 Single file</button>
          <button data-action="files">🗂 Multiple files</button>
          <button data-action="folder">📁 Folder</button>
          <div class="menu-divider"></div>
          <button data-action="project">📦 Project export (.zip)<br><small>Restore a previously exported session</small></button>
        </div>
      </div>
      <button class="btn" id="btnExport" title="Export the current virtual file system as a .zip">Export</button>
    </div>
  </header>

  <main class="workspace" id="workspace">
    <section class="panel">
      <div class="list-header" id="listHeader">
        <span></span>
        <span>Name</span>
        <span>Type</span>
        <span>Size</span>
        <span>Modified</span>
      </div>
      <div class="file-list hidden" id="fileList"></div>
      <div class="empty-state" id="emptyState">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7a1 1 0 0 1 1-1h4.5l1.5 2H20a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1z"/></svg>
        <h2>This folder is empty</h2>
        <p>Drag and drop files or folders anywhere on this window, or use the buttons below to import something to browse.</p>
        <div class="empty-actions">
          <button class="btn" data-action="file">Add a file</button>
          <button class="btn" data-action="files">Add files</button>
          <button class="btn primary" data-action="folder">Add a folder</button>
        </div>
      </div>
    </section>
  </main>

  <footer class="status-bar" id="statusBar"></footer>
</div>

<div class="drop-overlay" id="dropOverlay">
  <div class="drop-overlay-inner">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="M7 10l5 5 5-5"/><path d="M5 21h14"/></svg>
    Drop to import
  </div>
</div>

<div class="context-menu" id="contextMenu"></div>

<div class="modal-backdrop" id="modalBackdrop">
  <div class="modal">
    <h3 id="modalTitle">Rename</h3>
    <input id="renameInput" type="text" spellcheck="false">
    <div class="modal-actions">
      <button class="btn" id="renameCancel">Cancel</button>
      <button class="btn primary" id="renameConfirm">Rename</button>
    </div>
  </div>
</div>

<input type="file" id="inputSingleFile" hidden>
<input type="file" id="inputMultipleFiles" multiple hidden>
<input type="file" id="inputFolder" webkitdirectory multiple hidden>
<input type="file" id="inputProject" accept=".zip,application/zip" hidden>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script>
(() => {
  'use strict';

  /* ============================================================
     CONSTANTS
  ============================================================ */
  const TEXT_LIKE = new Set(['txt','json','xml','csv','log','css','js','ts','jsx','tsx','md','markdown','yml','yaml','ini','conf','cfg','py','java','c','h','cpp','rb','go','rs','php','sql','env','toml','tsv']);
