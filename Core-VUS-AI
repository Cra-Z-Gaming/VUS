<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VUS AI</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #0a0a0d;
  --surface: #101014;
  --panel:   #141418;
  --border:  #202026;
  --accent:  #00ff88;
  --acc-dim: rgba(0,255,136,.10);
  --text:    #dcdcee;
  --muted:   #42425a;
  --red:     #ff3355;
  --blue:    #4488ff;
  --gold:    #ffcc00;
  --mono:    'Space Mono', monospace;
  --display: 'Syne', sans-serif;
  --r:       8px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }

body {
  font-family: var(--mono);
  background: var(--bg);
  color: var(--text);
  display: flex;
  flex-direction: column;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg, transparent, transparent 3px,
    rgba(0,0,0,.04) 3px, rgba(0,0,0,.04) 4px
  );
  pointer-events: none;
  z-index: 9000;
}

/* ── Top Bar ── */
#topbar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  flex-wrap: wrap;
}

.wordmark {
  font-family: var(--display);
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -2px;
  color: var(--accent);
  text-shadow: 0 0 20px rgba(0,255,136,.45);
  white-space: nowrap;
}
.wordmark sup {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 1px;
  vertical-align: super;
}

.model-pill {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--muted);
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 3px 10px;
  white-space: nowrap;
}

/* ── Topbar buttons ── */
.tb-btn {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  padding: 5px 11px;
  cursor: pointer;
  transition: color .15s, border-color .15s, background .15s;
  white-space: nowrap;
  letter-spacing: .3px;
}
.tb-btn:hover { color: var(--text); border-color: #42425a; }
.tb-btn.danger:hover { color: var(--red); border-color: var(--red); background: rgba(255,51,85,.06); }
.tb-btn.hub-btn:hover { color: var(--accent); border-color: var(--accent); background: var(--acc-dim); }
.tb-btn:disabled { opacity: .35; cursor: not-allowed; }

/* ── VUS AI button — red themed ── */
.tb-btn.ai-btn {
  color: var(--red);
  border-color: var(--red);
  background: rgba(255,51,85,.06);
}
.tb-btn.ai-btn:hover {
  color: #fff;
  border-color: var(--red);
  background: rgba(255,51,85,.15);
  box-shadow: 0 0 8px rgba(255,51,85,.30);
}

.tb-spacer { margin-left: auto; }

/* ── Key Selector Dropdown ── */
#keyWrap { position: relative; }

#keyDropBtn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--text);
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  padding: 5px 11px;
  cursor: pointer;
  transition: border-color .15s;
  white-space: nowrap;
}
#keyDropBtn:hover { border-color: var(--accent); }
#keyDropBtn .k-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--muted);
  flex-shrink: 0;
  transition: background .2s;
}
#keyDropBtn .k-dot.active { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
#keyDropBtn .k-dot.inactive { background: var(--red); }
#keyDropBtn .k-caret { font-size: 8px; color: var(--muted); }

#keyMenu {
  display: none;
  position: absolute;
  top: calc(100% + 5px);
  left: 0;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  min-width: 160px;
  z-index: 500;
  overflow: hidden;
  box-shadow: 0 8px 24px rgba(0,0,0,.5);
  animation: fadeUp .12s ease;
}
#keyMenu.open { display: block; }

.km-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  font-size: 11px;
  cursor: pointer;
  color: var(--muted);
  transition: background .1s, color .1s;
  user-select: none;
}
.km-item:hover { background: var(--border); color: var(--text); }
.km-item.selected { color: var(--accent); }
.km-item .km-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--muted);
  flex-shrink: 0;
}
.km-item .km-dot.active   { background: var(--accent); box-shadow: 0 0 5px var(--accent); }
.km-item .km-dot.inactive { background: var(--red); }
.km-item .km-dot.unchecked { background: var(--muted); }
.km-item .km-status {
  margin-left: auto;
  font-size: 9px;
  letter-spacing: .3px;
}
.km-item .km-status.active   { color: var(--accent); }
.km-item .km-status.inactive { color: var(--red); }
.km-item .km-status.unchecked { color: var(--muted); }

/* ── Search Bar ── */
#searchBar {
  display: none;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
#searchBar.open { display: flex; }

#searchInput {
  flex: 1;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--text);
  font-family: var(--mono);
  font-size: 11px;
  padding: 6px 11px;
  outline: none;
  transition: border-color .2s;
}
#searchInput:focus { border-color: var(--accent); }
#searchInput::placeholder { color: var(--muted); }

#searchCount {
  font-size: 10px;
  color: var(--muted);
  white-space: nowrap;
  min-width: 52px;
  text-align: center;
}

.srch-btn {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--muted);
  font-size: 12px;
  width: 26px; height: 26px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: color .15s, border-color .15s;
  flex-shrink: 0;
}
.srch-btn:hover { color: var(--accent); border-color: var(--accent); }
.srch-btn:disabled { opacity: .3; cursor: not-allowed; }

#searchClose {
  background: none;
  border: none;
  color: var(--muted);
  font-size: 14px;
  cursor: pointer;
  padding: 0 3px;
  transition: color .15s;
}
#searchClose:hover { color: var(--red); }

/* search highlight */
.hl { background: rgba(255,204,0,.3); border-radius: 2px; }
.hl.current { background: rgba(255,204,0,.7); color: #000; border-radius: 2px; }

/* ── Chat Area ── */
#chat {
  flex: 1;
  overflow-y: auto;
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
#chat::-webkit-scrollbar { width: 4px; }
#chat::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* ── Messages ── */
.msg {
  display: flex;
  gap: 10px;
  max-width: 760px;
  animation: fadeUp .18s ease;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.msg.user { align-self: flex-end; flex-direction: row-reverse; }
.msg.assistant { align-self: flex-start; }

.avatar {
  width: 28px; height: 28px;
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700;
  flex-shrink: 0; margin-top: 2px;
}
.msg.user .avatar { background: var(--blue); color: #fff; }
.msg.assistant .avatar {
  background: var(--acc-dim);
  border: 1px solid rgba(0,255,136,.25);
  color: var(--accent);
  font-family: var(--display);
  font-size: 9px; letter-spacing: .5px;
}

.bubble {
  padding: 10px 14px;
  border-radius: var(--r);
  font-size: 13px;
  line-height: 1.75;
  max-width: calc(100% - 40px);
  word-break: break-word;
  white-space: pre-wrap;
}
.msg.user .bubble { background: var(--blue); color: #fff; border-bottom-right-radius: 2px; }
.msg.assistant .bubble { background: var(--panel); border: 1px solid var(--border); color: var(--text); border-bottom-left-radius: 2px; }

.bubble code {
  font-family: var(--mono); font-size: 11px;
  background: var(--bg); border: 1px solid var(--border);
  border-radius: 4px; padding: 1px 5px; color: var(--accent);
}
.bubble pre {
  background: var(--bg); border: 1px solid var(--border);
  border-radius: var(--r); padding: 10px 12px;
  overflow-x: auto; margin: 6px 0;
  font-size: 11px; line-height: 1.6; white-space: pre;
}
.bubble pre code { background: none; border: none; padding: 0; color: var(--text); }

.typing-dots { display: flex; gap: 4px; padding: 4px 2px; align-items: center; }
.typing-dots span {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent); animation: dot .9s infinite;
}
.typing-dots span:nth-child(2) { animation-delay: .15s; }
.typing-dots span:nth-child(3) { animation-delay: .3s; }
@keyframes dot {
  0%,60%,100% { opacity:.2; transform:scale(.8); }
  30% { opacity:1; transform:scale(1); }
}

/* ── Welcome ── */
#welcome {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 14px; flex: 1; text-align: center; padding: 40px 20px;
}
.w-logo {
  font-family: var(--display); font-size: 48px;
  font-weight: 900; letter-spacing: -4px;
  color: var(--accent); text-shadow: 0 0 40px rgba(0,255,136,.4); line-height: 1;
}
.w-sub { font-size: 12px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; }

/* ── Confirm Modal ── */
#modalBg {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.7);
  z-index: 8000;
  align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
}
#modalBg.open { display: flex; }
.modal {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px 22px;
  max-width: 340px; width: calc(100% - 32px);
  text-align: center;
  box-shadow: 0 20px 50px rgba(0,0,0,.6);
  animation: fadeUp .16s ease;
}
.modal h3 { font-family: var(--display); font-size: 16px; font-weight: 800; margin-bottom: 8px; color: var(--text); }
.modal p { font-size: 11px; color: var(--muted); line-height: 1.8; margin-bottom: 20px; }
.modal-btns { display: flex; gap: 8px; justify-content: center; }
.m-btn {
  padding: 8px 20px; border-radius: var(--r);
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  cursor: pointer; border: 1px solid transparent; transition: all .15s;
}
.m-cancel { background: var(--surface); border-color: var(--border); color: var(--muted); }
.m-cancel:hover { color: var(--text); border-color: #42425a; }
.m-confirm { background: rgba(255,51,85,.15); border-color: var(--red); color: var(--red); }
.m-confirm:hover { background: rgba(255,51,85,.25); }

/* ── Input Area ── */
#inputArea {
  padding: 12px 16px 14px;
  background: var(--surface);
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
#inputRow {
  display: flex; gap: 8px; align-items: flex-end;
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 10px; padding: 8px 10px 8px 14px;
  transition: border-color .2s;
}
#inputRow:focus-within { border-color: var(--accent); }

#msgInput {
  flex: 1; background: transparent; border: none; outline: none;
  color: var(--text); font-family: var(--mono); font-size: 12px;
  resize: none; min-height: 20px; max-height: 140px;
  line-height: 1.6; scrollbar-width: none;
}
#msgInput::placeholder { color: var(--muted); }
#msgInput::-webkit-scrollbar { display: none; }

#sendBtn {
  width: 32px; height: 32px; border-radius: 6px; border: none;
  background: var(--accent); color: #000; font-size: 14px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: filter .15s, transform .1s;
}
#sendBtn:hover:not(:disabled) { filter: brightness(1.15); }
#sendBtn:active:not(:disabled) { transform: scale(.93); }
#sendBtn:disabled { opacity: .35; cursor: not-allowed; }

#hint { font-size: 9px; color: var(--muted); text-align: center; margin-top: 7px; letter-spacing: .5px; }
</style>
</head>
