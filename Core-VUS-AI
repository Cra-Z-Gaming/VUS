<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VUS AI</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:      #0a0a0d;
  --surface: #101014;
  --panel:   #141418;
  --border:  #202026;
  --accent:  #00ff88;
  --acc-dim: rgba(0,255,136,.10);
  --text:    #dcdcee;
  --muted:   #42425a;
  --red:     #ff3355;
  --blue:    #4488ff;
  --gold:    #ffcc00;
  --mono:    'Space Mono', monospace;
  --display: 'Syne', sans-serif;
  --r:       8px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }

body {
  font-family: var(--mono);
  background: var(--bg);
  color: var(--text);
  display: flex;
  flex-direction: column;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg, transparent, transparent 3px,
    rgba(0,0,0,.04) 3px, rgba(0,0,0,.04) 4px
  );
  pointer-events: none;
  z-index: 9000;
}

/* ── Top Bar ── */
#topbar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 9px 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  flex-wrap: wrap;
}

.wordmark {
  font-family: var(--display);
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -2px;
  color: var(--accent);
  text-shadow: 0 0 20px rgba(0,255,136,.45);
  white-space: nowrap;
}
.wordmark sup {
  font-family: var(--mono);
  font-size: 9px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 1px;
  vertical-align: super;
}

/* ── Topbar buttons ── */
.tb-btn {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--muted);
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  padding: 5px 11px;
  cursor: pointer;
  transition: color .15s, border-color .15s, background .15s;
  white-space: nowrap;
  letter-spacing: .3px;
}
.tb-btn:hover { color: var(--text); border-color: #42425a; }
.tb-btn.danger:hover { color: var(--red); border-color: var(--red); background: rgba(255,51,85,.06); }
.tb-btn.hub-btn:hover { color: var(--accent); border-color: var(--accent); background: var(--acc-dim); }
.tb-btn:disabled { opacity: .35; cursor: not-allowed; }

/* ── VUS AI button — red themed ── */
.tb-btn.ai-btn {
  color: var(--red);
  border-color: var(--red);
  background: rgba(255,51,85,.06);
}
.tb-btn.ai-btn:hover {
  color: #fff;
  border-color: var(--red);
  background: rgba(255,51,85,.15);
  box-shadow: 0 0 8px rgba(255,51,85,.30);
}

/* ── CHECK button — accent themed ── */
.tb-btn.check-btn {
  color: var(--accent);
  border-color: var(--accent);
  background: var(--acc-dim);
}
.tb-btn.check-btn:hover:not(:disabled) {
  background: rgba(0,255,136,.18);
  box-shadow: 0 0 8px rgba(0,255,136,.30);
}
.tb-btn.check-btn.checking {
  color: var(--gold);
  border-color: var(--gold);
  background: rgba(255,204,0,.08);
}

.tb-spacer { margin-left: auto; }

/* ── Generic Dropdown (used by both Key selector and Model selector) ── */
.dd-wrap { position: relative; }

.dd-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--text);
  font-family: var(--mono);
  font-size: 10px;
  font-weight: 700;
  padding: 5px 11px;
  cursor: pointer;
  transition: border-color .15s;
  white-space: nowrap;
  max-width: 220px;
}
.dd-btn:hover { border-color: var(--accent); }
.dd-btn .dd-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 160px;
}
.dd-btn .k-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--muted);
  flex-shrink: 0;
  transition: background .2s;
}
.dd-btn .k-dot.active    { background: var(--accent); box-shadow: 0 0 6px var(--accent); }
.dd-btn .k-dot.inactive  { background: var(--red); }
.dd-btn .k-dot.checking  { background: var(--gold); animation: pulse 1s infinite; }
.dd-btn .k-caret { font-size: 8px; color: var(--muted); flex-shrink: 0; }

@keyframes pulse {
  0%,100% { opacity: 1; }
  50%     { opacity: .35; }
}

.dd-menu {
  display: none;
  position: absolute;
  top: calc(100% + 5px);
  left: 0;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  min-width: 200px;
  max-height: 320px;
  overflow-y: auto;
  z-index: 500;
  box-shadow: 0 8px 24px rgba(0,0,0,.5);
  animation: fadeUp .12s ease;
}
.dd-menu.open { display: block; }

.km-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  font-size: 11px;
  cursor: pointer;
  color: var(--muted);
  transition: background .1s, color .1s;
  user-select: none;
}
.km-item:hover { background: var(--border); color: var(--text); }
.km-item.selected { color: var(--accent); }
.km-item.dimmed { opacity: .45; }
.km-item .km-label {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.km-item .km-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--muted);
  flex-shrink: 0;
}
.km-item .km-dot.active    { background: var(--accent); box-shadow: 0 0 5px var(--accent); }
.km-item .km-dot.inactive  { background: var(--red); }
.km-item .km-dot.unchecked { background: var(--muted); }
.km-item .km-dot.checking  { background: var(--gold); animation: pulse 1s infinite; }
.km-item .km-status {
  margin-left: auto;
  font-size: 9px;
  letter-spacing: .3px;
  flex-shrink: 0;
}
.km-item .km-status.active    { color: var(--accent); }
.km-item .km-status.inactive  { color: var(--red); }
.km-item .km-status.unchecked { color: var(--muted); }
.km-item .km-status.checking  { color: var(--gold); }
.km-item.km-action { color: var(--muted); font-style: normal; border-top: 1px solid var(--border); }
.km-item.km-action:hover { color: var(--accent); }

/* ── Search Bar ── */
#searchBar {
  display: none;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
#searchBar.open { display: flex; }

#searchInput {
  flex: 1;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--text);
  font-family: var(--mono);
  font-size: 11px;
  padding: 6px 11px;
  outline: none;
  transition: border-color .2s;
}
#searchInput:focus { border-color: var(--accent); }
#searchInput::placeholder { color: var(--muted); }

#searchCount {
  font-size: 10px;
  color: var(--muted);
  white-space: nowrap;
  min-width: 52px;
  text-align: center;
}

.srch-btn {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--r);
  color: var(--muted);
  font-size: 12px;
  width: 26px; height: 26px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: color .15s, border-color .15s;
  flex-shrink: 0;
}
.srch-btn:hover { color: var(--accent); border-color: var(--accent); }
.srch-btn:disabled { opacity: .3; cursor: not-allowed; }

#searchClose {
  background: none;
  border: none;
  color: var(--muted);
  font-size: 14px;
  cursor: pointer;
  padding: 0 3px;
  transition: color .15s;
}
#searchClose:hover { color: var(--red); }

/* search highlight */
.hl { background: rgba(255,204,0,.3); border-radius: 2px; }
.hl.current { background: rgba(255,204,0,.7); color: #000; border-radius: 2px; }

/* ── Chat Area ── */
#chat {
  flex: 1;
  overflow-y: auto;
  padding: 20px 16px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
#chat::-webkit-scrollbar { width: 4px; }
#chat::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* ── Messages ── */
.msg {
  display: flex;
  gap: 10px;
  max-width: 760px;
  animation: fadeUp .18s ease;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.msg.user { align-self: flex-end; flex-direction: row-reverse; }
.msg.assistant { align-self: flex-start; }

.avatar {
  width: 28px; height: 28px;
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700;
  flex-shrink: 0; margin-top: 2px;
}
.msg.user .avatar { background: var(--blue); color: #fff; }
.msg.assistant .avatar {
  background: var(--acc-dim);
  border: 1px solid rgba(0,255,136,.25);
  color: var(--accent);
  font-family: var(--display);
  font-size: 9px; letter-spacing: .5px;
}

.bubble {
  padding: 10px 14px;
  border-radius: var(--r);
  font-size: 13px;
  line-height: 1.75;
  max-width: calc(100% - 40px);
  word-break: break-word;
  white-space: pre-wrap;
}
.msg.user .bubble { background: var(--blue); color: #fff; border-bottom-right-radius: 2px; }
.msg.assistant .bubble { background: var(--panel); border: 1px solid var(--border); color: var(--text); border-bottom-left-radius: 2px; }

.bubble code {
  font-family: var(--mono); font-size: 11px;
  background: var(--bg); border: 1px solid var(--border);
  border-radius: 4px; padding: 1px 5px; color: var(--accent);
}
.bubble pre {
  background: var(--bg); border: 1px solid var(--border);
  border-radius: var(--r); padding: 10px 12px;
  overflow-x: auto; margin: 6px 0;
  font-size: 11px; line-height: 1.6; white-space: pre;
}
.bubble pre code { background: none; border: none; padding: 0; color: var(--text); }

.typing-dots { display: flex; gap: 4px; padding: 4px 2px; align-items: center; }
.typing-dots span {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--accent); animation: dot .9s infinite;
}
.typing-dots span:nth-child(2) { animation-delay: .15s; }
.typing-dots span:nth-child(3) { animation-delay: .3s; }
@keyframes dot {
  0%,60%,100% { opacity:.2; transform:scale(.8); }
  30% { opacity:1; transform:scale(1); }
}

/* ── Welcome ── */
#welcome {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 14px; flex: 1; text-align: center; padding: 40px 20px;
}
.w-logo {
  font-family: var(--display); font-size: 48px;
  font-weight: 900; letter-spacing: -4px;
  color: var(--accent); text-shadow: 0 0 40px rgba(0,255,136,.4); line-height: 1;
}
.w-sub { font-size: 12px; color: var(--muted); letter-spacing: 2px; text-transform: uppercase; }

/* ── Confirm Modal ── */
#modalBg {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,.7);
  z-index: 8000;
  align-items: center; justify-content: center;
  backdrop-filter: blur(4px);
}
#modalBg.open { display: flex; }
.modal {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 24px 22px;
  max-width: 340px; width: calc(100% - 32px);
  text-align: center;
  box-shadow: 0 20px 50px rgba(0,0,0,.6);
  animation: fadeUp .16s ease;
}
.modal h3 { font-family: var(--display); font-size: 16px; font-weight: 800; margin-bottom: 8px; color: var(--text); }
.modal p { font-size: 11px; color: var(--muted); line-height: 1.8; margin-bottom: 20px; }
.modal-btns { display: flex; gap: 8px; justify-content: center; }
.m-btn {
  padding: 8px 20px; border-radius: var(--r);
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  cursor: pointer; border: 1px solid transparent; transition: all .15s;
}
.m-cancel { background: var(--surface); border-color: var(--border); color: var(--muted); }
.m-cancel:hover { color: var(--text); border-color: #42425a; }
.m-confirm { background: rgba(255,51,85,.15); border-color: var(--red); color: var(--red); }
.m-confirm:hover { background: rgba(255,51,85,.25); }

/* ── Input Area ── */
#inputArea {
  padding: 12px 16px 14px;
  background: var(--surface);
  border-top: 1px solid var(--border);
  flex-shrink: 0;
}
#inputRow {
  display: flex; gap: 8px; align-items: flex-end;
  background: var(--panel); border: 1px solid var(--border);
  border-radius: 10px; padding: 8px 10px 8px 14px;
  transition: border-color .2s;
}
#inputRow:focus-within { border-color: var(--accent); }

#msgInput {
  flex: 1; background: transparent; border: none; outline: none;
  color: var(--text); font-family: var(--mono); font-size: 12px;
  resize: none; min-height: 20px; max-height: 140px;
  line-height: 1.6; scrollbar-width: none;
}
#msgInput::placeholder { color: var(--muted); }
#msgInput::-webkit-scrollbar { display: none; }

#sendBtn {
  width: 32px; height: 32px; border-radius: 6px; border: none;
  background: var(--accent); color: #000; font-size: 14px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: filter .15s, transform .1s;
}
#sendBtn:hover:not(:disabled) { filter: brightness(1.15); }
#sendBtn:active:not(:disabled) { transform: scale(.93); }
#sendBtn:disabled { opacity: .35; cursor: not-allowed; }

#hint { font-size: 9px; color: var(--muted); text-align: center; margin-top: 7px; letter-spacing: .5px; }
</style>
</head>
<body>

<div id="topbar">
  <div class="wordmark">VUS<sup>AI</sup></div>

  <!-- Model selector -->
  <div id="modelWrap" class="dd-wrap">
    <button id="modelDropBtn" class="dd-btn" onclick="toggleModelMenu()">
      <span class="k-dot unchecked" id="modelActiveDot"></span>
      <span class="dd-label" id="modelActiveLabel">Loading…</span>
      <span class="k-caret">▼</span>
    </button>
    <div id="modelMenu" class="dd-menu"></div>
  </div>

  <!-- Key selector -->
  <div id="keyWrap" class="dd-wrap">
    <button id="keyDropBtn" class="dd-btn" onclick="toggleKeyMenu()">
      <span class="k-dot unchecked" id="activeDot"></span>
      <span class="dd-label" id="activeKeyLabel">Loading…</span>
      <span class="k-caret">▼</span>
    </button>
    <div id="keyMenu" class="dd-menu"></div>
  </div>

  <!-- Check -->
  <button id="checkBtn" class="tb-btn check-btn" onclick="checkAll()" title="Refresh and test all keys and models">⟳ CHECK</button>

  <span class="tb-spacer"></span>

  <!-- Search -->
  <button class="tb-btn" onclick="toggleSearch()" title="Search chat">⌕ Search</button>

  <!-- Hub -->
  <button class="tb-btn hub-btn" onclick="openHub()" title="Back to VUS Hub">⬡ Hub</button>

  <!-- VUS AI -->
  <button class="tb-btn ai-btn" onclick="openVUSAI()" title="Open VUS AI Assistant">⬡ VUS Help</button>

  <!-- Clear -->
  <button class="tb-btn danger" onclick="promptClear()">✕ Clear</button>
</div>

<!-- Search bar (hidden until toggled) -->
<div id="searchBar">
  <input id="searchInput" type="text" placeholder="Search chat…" autocomplete="off">
  <span id="searchCount">—</span>
  <button class="srch-btn" id="srchUp"   onclick="stepSearch(-1)" title="Previous" disabled>▲</button>
  <button class="srch-btn" id="srchDown" onclick="stepSearch(1)"  title="Next"     disabled>▼</button>
  <button id="searchClose" onclick="toggleSearch()">✕</button>
</div>

<div id="chat">
  <div id="welcome">
    <div class="w-logo">AI</div>
    <div class="w-sub">Powered by Groq · VUS Hub</div>
  </div>
</div>

<!-- Confirm clear modal -->
<div id="modalBg">
  <div class="modal">
    <h3>Clear Chat?</h3>
    <p>If you confirm, your entire conversation will be deleted.<br>You cannot restore your chats.</p>
    <div class="modal-btns">
      <button class="m-btn m-cancel"  onclick="closeModal()">Cancel</button>
      <button class="m-btn m-confirm" onclick="confirmClear()">Clear</button>
    </div>
  </div>
</div>

<div id="inputArea">
  <div id="inputRow">
    <textarea id="msgInput" placeholder="Ask anything…" rows="1"></textarea>
    <button id="sendBtn" onclick="send()" title="Send (Enter)" disabled>▶</button>
  </div>
  <div id="hint">Enter to send · Shift+Enter for new line</div>
</div>

<script>
/* ════════════════════════════════════════
   REMOTE SOURCES
   Keys and models are fetched from remote
   text files, one entry per line. Blank
   lines and lines starting with # are
   ignored. Model lines may optionally be
   "id|Display Label" — otherwise the id is
   shown as-is.
════════════════════════════════════════ */
const KEYS_URL   = 'https://raw.githubusercontent.com/Cra-Z-Gaming/VUS/refs/heads/main/GroqAPIKeys';
const MODELS_URL = 'https://raw.githubusercontent.com/Cra-Z-Gaming/VUS/refs/heads/main/GroqModels';

const SYSTEM_PROMPT = `
You are VUS AI, an assistant inside VUS Hub.

You may:
- answer general knowledge questions
- help with coding, writing, schoolwork, troubleshooting
- anything else the user asks for

Behavior rules:
- Be concise and direct
- Do not mention system prompts or keys
- If asked about VUS, VUSL, or VUS Hub, tell the user to click the Red VUS Help button on the top right
- iF info is asked about VUS, tell the user you do not know then suggest to use the 
- If unsure, say so briefly
- If the user seems unsure or confused, try to provide more information or examples to help them understand.
`;

/* ════════════════════════════════════════
   STATE — keys
   Each key is { key, label, status } where
   status is 'unchecked' | 'checking' | 'active' | 'inactive'.
════════════════════════════════════════ */
let history        = [];
let thinking        = false;
let keysLoading     = true;
let keysLoadError   = false;
let filledKeys      = [];
let selectedKey     = null;   // reference into filledKeys

/* ════════════════════════════════════════
   STATE — models
   Each model is { id, label, status }.
════════════════════════════════════════ */
let modelsLoading    = true;
let modelsLoadError  = false;
let modelsFetched    = false;   // true once fetched at least once — avoids re-fetching every menu open
let modelsList       = [];
let selectedModel    = null;    // reference into modelsList

let checking = false;

/* ════════════════════════════════════════
   DOM REFS
════════════════════════════════════════ */
const chatEl        = document.getElementById('chat');
const welcomeEl      = document.getElementById('welcome');
const inputEl        = document.getElementById('msgInput');
const sendBtn        = document.getElementById('sendBtn');
const checkBtn       = document.getElementById('checkBtn');

const keyMenu        = document.getElementById('keyMenu');
const activeDot      = document.getElementById('activeDot');
const activeLabel    = document.getElementById('activeKeyLabel');

const modelMenu       = document.getElementById('modelMenu');
const modelActiveDot   = document.getElementById('modelActiveDot');
const modelActiveLabel = document.getElementById('modelActiveLabel');

const modalBg        = document.getElementById('modalBg');
const searchBar      = document.getElementById('searchBar');
const searchInput    = document.getElementById('searchInput');
const searchCount    = document.getElementById('searchCount');
const srchUp         = document.getElementById('srchUp');
const srchDown       = document.getElementById('srchDown');

/* ════════════════════════════════════════
   LOAD KEYS FROM REMOTE SOURCE
════════════════════════════════════════ */
async function loadKeys() {
  keysLoading = true;
  keysLoadError = false;
  activeLabel.textContent = 'Loading…';
  updateSendAvailability();

  try {
    const res = await fetch(KEYS_URL + '?v=' + Date.now(), { cache: 'no-store' });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const raw = await res.text();

    filledKeys = raw
      .split('\n')
      .map(line => line.trim())
      .filter(line => line !== '' && !line.startsWith('#'))
      .map((k, i) => ({ key: k, label: 'Key ' + (i + 1), status: 'unchecked' }));

    selectedKey = filledKeys.length > 0 ? filledKeys[0] : null;
    keysLoading = false;
  } catch (e) {
    console.error('Failed to load keys from remote source:', e);
    filledKeys = [];
    selectedKey = null;
    keysLoading = false;
    keysLoadError = true;
  }

  buildKeyMenu();
  updateSendAvailability();
}

/* ════════════════════════════════════════
   LOAD MODELS FROM REMOTE SOURCE
   Fetched once per page load unless
   force=true (used by the CHECK button).
════════════════════════════════════════ */
async function loadModels(force = false) {
  if (modelsFetched && !force) {
    buildModelMenu();
    return;
  }

  modelsLoading = true;
  modelsLoadError = false;
  modelActiveLabel.textContent = 'Loading…';
  buildModelMenu();
  updateSendAvailability();

  try {
    const res = await fetch(MODELS_URL + '?v=' + Date.now(), { cache: 'no-store' });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const raw = await res.text();

    modelsList = raw
      .split('\n')
      .map(line => line.trim())
      .filter(line => line !== '' && !line.startsWith('#'))
      .map(line => {
        const [id, label] = line.split('|').map(s => s && s.trim());
        return { id, label: label || id, status: 'unchecked' };
      });

    selectedModel = modelsList.length > 0 ? modelsList[0] : null;
    modelsLoading = false;
    modelsFetched = true;
  } catch (e) {
    console.error('Failed to load models from remote source:', e);
    modelsList = [];
    selectedModel = null;
    modelsLoading = false;
    modelsLoadError = true;
    modelsFetched = false;
  }

  buildModelMenu();
  updateSendAvailability();
}

function updateSendAvailability() {
  sendBtn.disabled = keysLoading || modelsLoading || thinking || checking;
}

/* ════════════════════════════════════════
   KEY SELECTOR
════════════════════════════════════════ */
function sortKeysList() {
  const rank = { active: 0, unchecked: 1, checking: 1, inactive: 2 };
  filledKeys = filledKeys
    .map((k, i) => ({ k, i }))
    .sort((a, b) => (rank[a.k.status] - rank[b.k.status]) || (a.i - b.i))
    .map(x => x.k);
}

function buildKeyMenu() {
  keyMenu.innerHTML = '';

  if (keysLoading) {
    const el = document.createElement('div');
    el.className = 'km-item';
    el.textContent = 'Loading keys…';
    keyMenu.appendChild(el);
    activeLabel.textContent = 'Loading…';
    activeDot.className = 'k-dot unchecked';
    return;
  }

  if (keysLoadError) {
    const el = document.createElement('div');
    el.className = 'km-item';
    el.textContent = 'Failed to load keys';
    keyMenu.appendChild(el);
    const retry = document.createElement('div');
    retry.className = 'km-item km-action';
    retry.textContent = '↻ Retry';
    retry.onclick = loadKeys;
    keyMenu.appendChild(retry);
    activeLabel.textContent = 'No Key';
    activeDot.className = 'k-dot inactive';
    return;
  }

  if (filledKeys.length === 0) {
    const el = document.createElement('div');
    el.className = 'km-item';
    el.textContent = 'No keys configured';
    keyMenu.appendChild(el);
    activeLabel.textContent = 'No Key';
    activeDot.className = 'k-dot unchecked';
    return;
  }

  sortKeysList();

  filledKeys.forEach(k => {
    const el = document.createElement('div');
    const st = k.status;
    const isSelected = selectedKey === k;
    el.className = 'km-item' + (isSelected ? ' selected' : '') + (st === 'inactive' ? ' dimmed' : '');
    el.innerHTML = `
      <span class="km-dot ${st}"></span>
      <span class="km-label">${k.label}</span>
      <span class="km-status ${st}">${st === 'unchecked' ? '—' : st === 'checking' ? 'Checking…' : st === 'active' ? 'Active' : 'Inactive'}</span>
    `;
    el.onclick = () => selectKey(k);
    keyMenu.appendChild(el);
  });

  updateKeyDropBtn();
}

function selectKey(k) {
  selectedKey = k;
  buildKeyMenu();
  keyMenu.classList.remove('open');
}

function updateKeyDropBtn() {
  const st = selectedKey ? selectedKey.status : 'unchecked';
  activeDot.className = 'k-dot ' + st;
  activeLabel.textContent = selectedKey ? selectedKey.label : 'No Key';
}

function toggleKeyMenu() {
  modelMenu.classList.remove('open');
  keyMenu.classList.toggle('open');
}

/* ════════════════════════════════════════
   MODEL SELECTOR
   Working models (green) sort to the top,
   failing models (red) sort to the bottom,
   untested models (grey) stay in the middle.
════════════════════════════════════════ */
function sortModelsList() {
  const rank = { active: 0, unchecked: 1, checking: 1, inactive: 2 };
  modelsList = modelsList
    .map((m, i) => ({ m, i }))
    .sort((a, b) => (rank[a.m.status] - rank[b.m.status]) || (a.i - b.i))
    .map(x => x.m);
}

function buildModelMenu() {
  modelMenu.innerHTML = '';

  if (modelsLoading) {
    const el = document.createElement('div');
    el.className = 'km-item';
    el.textContent = 'Loading models…';
    modelMenu.appendChild(el);
    modelActiveLabel.textContent = 'Loading…';
    modelActiveDot.className = 'k-dot unchecked';
    return;
  }

  if (modelsLoadError) {
    const el = document.createElement('div');
    el.className = 'km-item';
    el.textContent = 'Failed to load models';
    modelMenu.appendChild(el);
    const retry = document.createElement('div');
    retry.className = 'km-item km-action';
    retry.textContent = '↻ Retry';
    retry.onclick = () => loadModels(true);
    modelMenu.appendChild(retry);
    modelActiveLabel.textContent = 'No Model';
    modelActiveDot.className = 'k-dot inactive';
    return;
  }

  if (modelsList.length === 0) {
    const el = document.createElement('div');
    el.className = 'km-item';
    el.textContent = 'No models configured';
    modelMenu.appendChild(el);
    modelActiveLabel.textContent = 'No Model';
    modelActiveDot.className = 'k-dot unchecked';
    return;
  }

  sortModelsList();

  modelsList.forEach(m => {
    const el = document.createElement('div');
    const st = m.status;
    const isSelected = selectedModel === m;
    el.className = 'km-item' + (isSelected ? ' selected' : '') + (st === 'inactive' ? ' dimmed' : '');
    el.innerHTML = `
      <span class="km-dot ${st}"></span>
      <span class="km-label">${m.label}</span>
      <span class="km-status ${st}">${st === 'unchecked' ? '—' : st === 'checking' ? 'Checking…' : st === 'active' ? 'Working' : 'Failing'}</span>
    `;
    el.onclick = () => selectModel(m);
    modelMenu.appendChild(el);
  });

  updateModelDropBtn();
}

function selectModel(m) {
  selectedModel = m;
  buildModelMenu();
  modelMenu.classList.remove('open');
}

function updateModelDropBtn() {
  const st = selectedModel ? selectedModel.status : 'unchecked';
  modelActiveDot.className = 'k-dot ' + st;
  modelActiveLabel.textContent = selectedModel ? selectedModel.label : 'No Model';
}

function toggleModelMenu() {
  keyMenu.classList.remove('open');
  modelMenu.classList.toggle('open');
}

// Close either menu when clicking outside
document.addEventListener('click', e => {
  if (!document.getElementById('keyWrap').contains(e.target)) {
    keyMenu.classList.remove('open');
  }
  if (!document.getElementById('modelWrap').contains(e.target)) {
    modelMenu.classList.remove('open');
  }
});

/* ════════════════════════════════════════
   CHECK — refreshes keys + models from
   their remote sources, then tests every
   key and every model with a minimal
   request. Working entries sort to the
   top, failing ones sink to the bottom.
════════════════════════════════════════ */
async function checkAll() {
  if (checking) return;
  checking = true;
  checkBtn.disabled = true;
  checkBtn.classList.add('checking');
  checkBtn.textContent = '⟳ Checking…';
  updateSendAvailability();

  await loadKeys();
  await loadModels(true);

  if (filledKeys.length === 0 || modelsList.length === 0) {
    checking = false;
    checkBtn.disabled = false;
    checkBtn.classList.remove('checking');
    checkBtn.textContent = '⟳ CHECK';
    updateSendAvailability();
    return;
  }

  // Mark everything as checking
  filledKeys.forEach(k => k.status = 'checking');
  modelsList.forEach(m => m.status = 'checking');
  buildKeyMenu();
  buildModelMenu();

  // Test each key against the first available model
  const testModelId = modelsList[0].id;
  for (const k of filledKeys) {
    try {
      await tryKey(k, testModelId, true);
      k.status = 'active';
    } catch {
      k.status = 'inactive';
    }
    buildKeyMenu();
  }

  // Test each model using a working key if we found one, otherwise the first key
  const workingKey = filledKeys.find(k => k.status === 'active') || filledKeys[0];
  for (const m of modelsList) {
    try {
      await tryKey(workingKey, m.id, true);
      m.status = 'active';
    } catch {
      m.status = 'inactive';
    }
    buildModelMenu();
  }

  // Point the current selection at a working key/model if the current one isn't working
  if (!selectedKey || selectedKey.status !== 'active') {
    const wk = filledKeys.find(k => k.status === 'active');
    if (wk) selectedKey = wk;
  }
  if (!selectedModel || selectedModel.status !== 'active') {
    const wm = modelsList.find(m => m.status === 'active');
    if (wm) selectedModel = wm;
  }

  buildKeyMenu();
  buildModelMenu();

  checking = false;
  checkBtn.disabled = false;
  checkBtn.classList.remove('checking');
  checkBtn.textContent = '⟳ CHECK';
  updateSendAvailability();
}

