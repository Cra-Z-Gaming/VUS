// Close modal on background click
modalBg.addEventListener('click', e => { if (e.target === modalBg) closeModal(); });

/* ════════════════════════════════════════
   SEARCH
════════════════════════════════════════ */
let searchMatches = [];
let searchCurrent = -1;

function toggleSearch() {
  const isOpen = searchBar.classList.toggle('open');
  if (isOpen) {
    searchInput.focus();
  } else {
    clearSearch();
  }
}

function clearSearch() {
  searchInput.value = '';
  removeHighlights();
  searchMatches = [];
  searchCurrent = -1;
  searchCount.textContent = '—';
  srchUp.disabled   = true;
  srchDown.disabled = true;
}

searchInput.addEventListener('input', () => runSearch());
searchInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') { e.preventDefault(); stepSearch(e.shiftKey ? -1 : 1); }
  if (e.key === 'Escape') toggleSearch();
});

function removeHighlights() {
  chatEl.querySelectorAll('.hl').forEach(el => {
    el.replaceWith(document.createTextNode(el.textContent));
  });
  // Merge adjacent text nodes
  chatEl.querySelectorAll('.bubble').forEach(b => b.normalize());
}

function runSearch() {
  removeHighlights();
  searchMatches = [];
  searchCurrent = -1;

  const q = searchInput.value.trim();
  if (!q) {
    searchCount.textContent = '—';
    srchUp.disabled   = true;
    srchDown.disabled = true;
    return;
  }

  const regex = new RegExp(escapeRegex(q), 'gi');

  // Walk all text nodes inside bubbles
  chatEl.querySelectorAll('.bubble').forEach(bubble => {
    highlightInNode(bubble, regex);
  });

  searchMatches = Array.from(chatEl.querySelectorAll('.hl'));

  if (searchMatches.length === 0) {
    searchCount.textContent = '0 / 0';
    srchUp.disabled   = true;
    srchDown.disabled = true;
    return;
  }

  srchUp.disabled   = false;
  srchDown.disabled = false;
  stepSearch(1);
}

function highlightInNode(node, regex) {
  if (node.nodeType === Node.TEXT_NODE) {
    const text = node.textContent;
    let match, lastIdx = 0;
    const frag = document.createDocumentFragment();
    regex.lastIndex = 0;
    while ((match = regex.exec(text)) !== null) {
      if (match.index > lastIdx) {
        frag.appendChild(document.createTextNode(text.slice(lastIdx, match.index)));
      }
      const span = document.createElement('span');
      span.className = 'hl';
      span.textContent = match[0];
      frag.appendChild(span);
      lastIdx = regex.lastIndex;
    }
    if (lastIdx < text.length) frag.appendChild(document.createTextNode(text.slice(lastIdx)));
    if (frag.childNodes.length > 1 || (frag.firstChild && frag.firstChild.nodeName === 'SPAN')) {
      node.parentNode.replaceChild(frag, node);
    }
  } else if (node.nodeType === Node.ELEMENT_NODE && node.nodeName !== 'SCRIPT' && node.nodeName !== 'STYLE') {
    Array.from(node.childNodes).forEach(child => highlightInNode(child, regex));
  }
}

function stepSearch(dir) {
  if (searchMatches.length === 0) return;
  if (searchCurrent >= 0) searchMatches[searchCurrent].classList.remove('current');
  searchCurrent = (searchCurrent + dir + searchMatches.length) % searchMatches.length;
  const target = searchMatches[searchCurrent];
  target.classList.add('current');
  searchCount.textContent = (searchCurrent + 1) + ' / ' + searchMatches.length;

  // Scroll into view with padding so it's never clipped
  const chatRect   = chatEl.getBoundingClientRect();
  const targetRect = target.getBoundingClientRect();
  const pad = 60;
  if (targetRect.top < chatRect.top + pad) {
    chatEl.scrollTop -= (chatRect.top + pad - targetRect.top);
  } else if (targetRect.bottom > chatRect.bottom - pad) {
    chatEl.scrollTop += (targetRect.bottom - chatRect.bottom + pad);
  }
}

function escapeRegex(s) {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

/* ════════════════════════════════════════
   INPUT
════════════════════════════════════════ */
inputEl.addEventListener('input', () => {
  inputEl.style.height = 'auto';
  inputEl.style.height = Math.min(inputEl.scrollHeight, 140) + 'px';
});

inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
});

/* ════════════════════════════════════════
   MARKDOWN-LITE RENDERER
════════════════════════════════════════ */
function renderText(raw) {
  let out = raw.replace(/```(\w*)\n?([\s\S]*?)```/g, (_, _lang, code) =>
    `<pre><code>${escHtml(code.trim())}</code></pre>`
  );
  out = out.replace(/`([^`]+)`/g, (_, c) => `<code>${escHtml(c)}</code>`);
  out = out.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  out = out.replace(/\n/g, '<br>');
  return out;
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

/* ════════════════════════════════════════
   MESSAGES
════════════════════════════════════════ */
function appendMsg(role, content, isTyping = false) {
  if (welcomeEl && welcomeEl.parentNode === chatEl) chatEl.removeChild(welcomeEl);

  const wrap = document.createElement('div');
  wrap.className = 'msg ' + role;

  const av = document.createElement('div');
  av.className = 'avatar';
  av.textContent = role === 'user' ? 'YOU' : 'AI';

  const bub = document.createElement('div');
  bub.className = 'bubble';

  if (isTyping) {
    bub.innerHTML = '<div class="typing-dots"><span></span><span></span><span></span></div>';
  } else {
    bub.innerHTML = role === 'assistant' ? renderText(content) : escHtml(content);
  }

  wrap.appendChild(av);
  wrap.appendChild(bub);
  chatEl.appendChild(wrap);
  chatEl.scrollTop = chatEl.scrollHeight;

  return { wrap, bub };
}

/* ════════════════════════════════════════
   API CALL
   test=true sends a minimal 1-token probe
   used by checkAll(); test=false sends the
   real conversation.
════════════════════════════════════════ */
async function tryKey(keyObj, modelId, test = false) {
  const body = test
    ? { model: modelId, max_tokens: 1, messages: [{ role: 'user', content: 'hi' }] }
    : { model: modelId, max_tokens: 1024, messages: [{ role: 'system', content: SYSTEM_PROMPT }, ...history] };

  const res = await fetch('https://api.groq.com/openai/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': 'Bearer ' + keyObj.key
    },
    body: JSON.stringify(body)
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err?.error?.message || 'HTTP ' + res.status);
  }
  return res.json();
}

async function send() {
  const text = inputEl.value.trim();
  if (!text || thinking || checking) return;

  if (keysLoading || modelsLoading) {
    alert('Still loading keys/models, please wait a moment and try again.');
    return;
  }

  if (keysLoadError || filledKeys.length === 0) {
    alert('No API keys available. Could not load keys from the remote source, or none are configured there.');
    return;
  }

  if (modelsLoadError || modelsList.length === 0 || !selectedModel) {
    alert('No model available. Could not load models from the remote source, or none are configured there.');
    return;
  }

  thinking = true;
  updateSendAvailability();
  inputEl.value = '';
  inputEl.style.height = 'auto';
  clearSearch();

  appendMsg('user', text);
  history.push({ role: 'user', content: text });

  const { bub: typingBub } = appendMsg('assistant', '', true);

  const modelId = selectedModel.id;

  // Try the selected key first, then fall back through the rest
  const tryOrder = [selectedKey, ...filledKeys.filter(k => k !== selectedKey)];

  let data = null;
  let usedKey = null;

  for (const k of tryOrder) {
    try {
      data = await tryKey(k, modelId);
      usedKey = k;
      k.status = 'active';
      buildKeyMenu();
      break;
    } catch {
      k.status = 'inactive';
      buildKeyMenu();
    }
  }

  selectedModel.status = data ? 'active' : 'inactive';
  buildModelMenu();

  if (data) {
    const reply = data.choices?.[0]?.message?.content || '(no response)';
    typingBub.innerHTML = renderText(reply);
    history.push({ role: 'assistant', content: reply });
    if (usedKey !== selectedKey) selectedKey = usedKey;
    buildKeyMenu();
  } else {
    typingBub.innerHTML = `<span style="color:var(--red)">⚠ System Inactive — all keys failed for this model. Try a different model or run CHECK.</span>`;
  }

  chatEl.scrollTop = chatEl.scrollHeight;
  thinking = false;
  updateSendAvailability();
  inputEl.focus();
}

/* ════════════════════════════════════════
   INIT — load + test everything on startup
════════════════════════════════════════ */
checkAll();
